---
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const bounties = (await getCollection("bounty")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const bountyPath = `${base}bounty/`;
---

<div id="bounty-list" class="bounty-list">
  {
    bounties.map((bounty) => (
      <a
        href={bountyPath + bounty.slug}
        class:list={[
          "bounty-list__item",
          { "is-active": currentPath.startsWith(bountyPath + bounty.slug) },
        ]}
      >
        <div class="bounty-list__meta">
          <span>{bounty.data.date.toLocaleDateString()}</span>
          <span>{bounty.data.deadline?.toLocaleDateString() ?? "open"}</span>
        </div>
        <h3 class="bounty-list__title">{bounty.data.title}</h3>
        <p class="bounty-list__summary">{bounty.data.summary}</p>
        {bounty.data.winner && <span class="bounty-list__winner">{bounty.data.winner}</span>}
      </a>
    ))
  }
</div>

<style>
  .bounty-list {
    display: grid;
    gap: 1rem;
  }

  .bounty-list__item {
    display: grid;
    gap: 0.75rem;
    padding: 1.2rem 1.25rem;
    border-radius: var(--card-radius);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    color: inherit;
    text-decoration: none;
    box-shadow: var(--card-shadow);
    transition:
      transform var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .bounty-list__item:hover {
    transform: translateY(var(--card-hover-lift));
    border-color: var(--color-border-hover);
    box-shadow: var(--card-shadow-hover);
  }

  .bounty-list__item:focus-visible {
    outline: none;
    transform: translateY(var(--card-hover-lift));
    border-color: var(--color-primary-link);
    box-shadow: var(--focus-shadow);
  }

  .bounty-list__item.is-active {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(239, 245, 255, 0.88)),
      rgba(255, 255, 255, 0.9);
    border-color: rgba(var(--color-primary-rgb), 0.18);
    box-shadow: 0 18px 30px rgba(var(--color-primary-rgb), 0.08);
  }

  .bounty-list__meta {
    display: flex;
    justify-content: space-between;
    gap: 0.95rem;
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .bounty-list__title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .bounty-list__summary {
    margin: 0;
    color: var(--color-body);
    line-height: 1.6;
  }

  .bounty-list__winner {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    padding: 0.35rem 0.6rem;
    border-radius: var(--radius-pill);
    background: rgba(var(--color-primary-rgb), 0.08);
    color: var(--color-primary-link);
    font-size: 0.8rem;
    font-weight: 700;
  }
</style>
