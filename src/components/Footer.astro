---
/**
 * Footer.astro
 *
 * Site-wide footer component with theme-aware styling.
 * Displays the copyright notice and logo.
 */
import lichtFeldLogo from '../assets/lichtfeld-logo.svg';
import core11Logo from '../assets/core11-logo.svg';
import { VOLINGA_URL } from '@/constants/project';

const base = import.meta.env.BASE_URL;
const volingaLogo = `${base}static/volinga-logo.png`;
const launchYear = 2025;
const currentYear = new Date().getFullYear();
const copyrightLabel =
  currentYear > launchYear ? `© ${launchYear}-${currentYear} LichtFeld` : `© ${launchYear} LichtFeld`;
---

<div class="container content-frame px-4">
  <footer class="site-footer py-3 my-4">
    <!-- Supported by section -->
    <div class="d-flex flex-column align-items-center mb-3 pb-3 border-bottom">
      <p class="text-body-secondary mb-2 small">Supported by</p>
      <div class="sponsor-logos">
        <a
          href="https://www.core11.eu/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit Core11 website"
          class="sponsor-logo"
        >
          <img src={core11Logo.src} alt="Core11" class="sponsor-logo__image" />
        </a>
        <a
          href={VOLINGA_URL}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Visit Volinga website"
          class="sponsor-logo sponsor-logo--secondary"
        >
          <img src={volingaLogo} alt="Volinga" class="sponsor-logo__image sponsor-logo__image--secondary" />
        </a>
      </div>
    </div>

    <!-- Footer content -->
    <div class="d-flex flex-wrap justify-content-between align-items-center">
      <p class="col-md-4 mb-0 site-footer__copyright">{copyrightLabel}</p>
      <a
        href={base}
        class="col-md-4 d-flex align-items-center justify-content-center mb-3 mb-md-0 me-md-auto text-decoration-none"
        aria-label="LichtFeld Studio Home"
      >
        <img src={lichtFeldLogo.src} alt="LichtFeld Studio" class="site-footer__logo" />
      </a>
    </div>
  </footer>
</div>

<style>
  /**
   * Footer styling with theme-aware colors.
   */
  .site-footer {
    padding-top: 2rem !important;
    border-top: 1px solid rgba(15, 23, 42, 0.08) !important;
    border-color: transparent !important;
  }

  .site-footer__copyright {
    color: var(--color-muted);
    font-weight: 600;
  }

  .site-footer__logo {
    height: 20px;
    opacity: 0.78;
    transition: opacity var(--transition-fast, 150ms) ease-out;
  }

  .site-footer__logo:hover {
    opacity: 1;
  }

  .sponsor-logo {
    display: inline-flex;
    justify-content: center;
    transition: opacity var(--transition-fast, 150ms) ease-out;
  }

  .sponsor-logo:hover {
    opacity: 1 !important;
  }

  .sponsor-logos {
    display: grid;
    justify-items: center;
    gap: 0.75rem;
  }

  .sponsor-logo__image {
    height: 30px;
    opacity: 0.85;
  }

  .sponsor-logo__image--secondary {
    height: 48px;
  }
</style>
