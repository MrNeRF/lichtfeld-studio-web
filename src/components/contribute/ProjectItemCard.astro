---
import type { ContributionProjectItem } from "@/services/github";

interface Props {
  item: ContributionProjectItem;
}

const { item } = Astro.props;
const updatedLabel = item.updatedAt
  ? new Date(item.updatedAt).toLocaleDateString(undefined, {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;
---

<article class="project-item-card">
  <div class="project-item-card__meta">
    <span class="project-item-card__type">{item.itemType}</span>
    {item.status && <span class="project-item-card__status">{item.status}</span>}
  </div>

  <h3 class="project-item-card__title">
    <a href={item.link} target="_blank" rel="noopener noreferrer">
      {item.title}
    </a>
  </h3>

  <div class="project-item-card__content" set:html={item.bodyHtml} />

  <div class="project-item-card__footer">
    {item.repoLabel && <span class="project-item-card__repo">{item.repoLabel}</span>}
    <div class="project-item-card__links">
      {updatedLabel && <span class="project-item-card__updated">Updated {updatedLabel}</span>}
      <a href={item.link} target="_blank" rel="noopener noreferrer" class="project-item-card__action">Open item</a>
    </div>
  </div>
</article>

<style>
  .project-item-card {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: var(--card-padding);
    border-radius: var(--card-radius);
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    box-shadow: var(--card-shadow);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease;
  }

  .project-item-card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(90deg, rgba(20, 87, 255, 0.24), rgba(20, 87, 255, 0));
    pointer-events: none;
  }

  .project-item-card:hover {
    transform: translateY(var(--card-hover-lift));
    border-color: var(--color-border-hover);
    box-shadow: var(--card-shadow-hover);
  }

  .project-item-card:focus-within {
    transform: translateY(var(--card-hover-lift));
    border-color: var(--color-primary-link);
    box-shadow: var(--focus-shadow), var(--card-shadow-hover);
  }

  .project-item-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--card-gap);
    margin-bottom: 1.05rem;
  }

  .project-item-card__type,
  .project-item-card__status {
    display: inline-flex;
    align-items: center;
    min-height: 1.85rem;
    padding: 0.22rem 0.8rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-item-card__type {
    background: rgba(20, 87, 255, 0.08);
    color: var(--color-primary-link);
  }

  .project-item-card__status {
    background: rgba(15, 23, 42, 0.06);
    color: #475467;
  }

  .project-item-card__title {
    margin: 0 0 0.95rem;
    font-size: 1.3rem;
    line-height: 1.18;
  }

  .project-item-card__title a {
    color: var(--color-heading);
    text-decoration: none;
    transition: color 0.18s ease, box-shadow 0.18s ease;
  }

  .project-item-card__title a:hover {
    color: var(--color-primary-link);
  }

  .project-item-card__content {
    color: var(--color-body);
    line-height: 1.6;
    flex: 1;
  }

  .project-item-card__content :global(p:last-child) {
    margin-bottom: 0;
  }

  .project-item-card__content :global(strong) {
    color: var(--color-heading);
  }

  .project-item-card__footer {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-end;
    margin-top: 1.1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border-subtle);
  }

  .project-item-card__repo,
  .project-item-card__updated {
    font-size: 0.82rem;
    color: var(--color-muted);
  }

  .project-item-card__links {
    display: flex;
    gap: 0.95rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .project-item-card__action {
    color: var(--color-primary-link);
    font-weight: 700;
    text-decoration: none;
    transition: color 0.18s ease, box-shadow 0.18s ease;
  }

  .project-item-card__action:hover {
    color: var(--color-primary-link-hover);
  }

  .project-item-card__title a:focus-visible,
  .project-item-card__action:focus-visible {
    outline: none;
    border-radius: 0.4rem;
    box-shadow: var(--focus-shadow);
  }

  @media (max-width: 575.98px) {
    .project-item-card__footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .project-item-card__links {
      justify-content: flex-start;
    }
  }
</style>
