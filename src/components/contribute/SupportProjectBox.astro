---
import { CRYPTO_WALLET_BITCOIN, DONORBOX_URL, GITHUB_SPONSORS_URL, PAYPAL_URL } from "@/constants/project";

interface Props {
  sectionId?: string;
  class?: string;
}

const base = import.meta.env.BASE_URL;
const { sectionId = "support-the-project", class: className = "" } = Astro.props;
const headingId = `${sectionId}-heading`;
const customAmountId = `${sectionId}-custom-amount`;
---

<div class:list={["shell", "shell--spacious", "support-box", className]} data-support-box>
  <div class="support-box__layout">
    <div class="support-box__intro">
      <div class="support-box__header">
        <div class="support-box__icon" aria-hidden="true">
          <svg class="bi" width="1.5em" height="1.5em">
            <use href={`${base}static/bootstrap-icons.svg#heart-fill`}></use>
          </svg>
        </div>
        <div class="section-heading section-heading--support">
          <h2 id={headingId} class="support-box__title">Support the Project</h2>
          <a class="section-anchor" href={`#${sectionId}`} aria-label="Link to support section">
            <svg class="bi" width="1em" height="1em" aria-hidden="true">
              <use href={`${base}static/bootstrap-icons.svg#link-45deg`}></use>
            </svg>
          </a>
        </div>
      </div>
      <p class="support-box__desc">
        Support ongoing LichtFeld Studio development through the platform you prefer.
      </p>
    </div>

    <div class="support-box__panel">
      <p class="support-box__label">Choose an amount and funding path</p>

      <div class="donate-amounts" role="radiogroup" aria-label="Select donation amount">
        <button type="button" class="donate-amount" data-amount="5" aria-pressed="false">$5</button>
        <button type="button" class="donate-amount" data-amount="10" aria-pressed="true">$10</button>
        <button type="button" class="donate-amount" data-amount="25" aria-pressed="false">$25</button>
        <button type="button" class="donate-amount" data-amount="100" aria-pressed="false">$100</button>
        <div class="donate-amount-custom">
          <span class="donate-amount-custom__prefix">$</span>
          <input
            type="number"
            class="donate-amount-custom__input"
            id={customAmountId}
            placeholder="Other"
            min="1"
            aria-label="Enter custom donation amount"
            data-custom-amount
          />
        </div>
      </div>

      <div class="donate-providers">
        <a
          class="donate-provider donate-provider--paypal"
          href={PAYPAL_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-provider="paypal"
          data-base-url={PAYPAL_URL}
          aria-label="Donate via PayPal"
        >
          <svg class="bi" width="1.25em" height="1.25em" aria-hidden="true">
            <use href={`${base}static/bootstrap-icons.svg#paypal`}></use>
          </svg>
          PayPal
        </a>
        <a
          class="donate-provider donate-provider--donorbox"
          href={DONORBOX_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-provider="donorbox"
          data-base-url={DONORBOX_URL}
          aria-label="Donate via DonorBox"
        >
          <svg class="bi" width="1.25em" height="1.25em" aria-hidden="true">
            <use href={`${base}static/bootstrap-icons.svg#gift-fill`}></use>
          </svg>
          DonorBox
        </a>
        <a
          class="donate-provider donate-provider--github"
          href={GITHUB_SPONSORS_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-provider="github"
          aria-label="Sponsor on GitHub"
        >
          <svg class="bi" width="1.25em" height="1.25em" aria-hidden="true">
            <use href={`${base}static/bootstrap-icons.svg#github`}></use>
          </svg>
          GitHub Sponsors
        </a>
        <button
          type="button"
          class="donate-provider donate-provider--bitcoin"
          data-provider="bitcoin"
          data-wallet={CRYPTO_WALLET_BITCOIN}
          aria-label="Copy Bitcoin wallet address"
        >
          <svg class="bi" width="1.25em" height="1.25em" aria-hidden="true">
            <use href={`${base}static/bootstrap-icons.svg#currency-bitcoin`}></use>
          </svg>
          Bitcoin
        </button>
      </div>
    </div>
  </div>

  <div class="donate-bitcoin-popup" aria-hidden="true" data-bitcoin-popup>
    <div class="donate-bitcoin-popup__content">
      <p class="donate-bitcoin-popup__label">Bitcoin Wallet Address</p>
      <div class="donate-bitcoin-popup__address">
        <code data-btc-wallet-display>{CRYPTO_WALLET_BITCOIN}</code>
        <button type="button" class="donate-bitcoin-popup__copy" aria-label="Copy wallet address" data-copy-btc-btn>
          <svg class="bi" width="1em" height="1em" aria-hidden="true">
            <use href={`${base}static/bootstrap-icons.svg#clipboard`}></use>
          </svg>
        </button>
      </div>
      <p class="donate-bitcoin-popup__hint" data-btc-copy-status>Click to copy</p>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-support-box]").forEach((box) => {
    const amountButtons = box.querySelectorAll<HTMLButtonElement>(".donate-amount");
    const customInput = box.querySelector<HTMLInputElement>("[data-custom-amount]");
    const paypalLink = box.querySelector<HTMLAnchorElement>('[data-provider="paypal"]');
    const donorboxLink = box.querySelector<HTMLAnchorElement>('[data-provider="donorbox"]');
    const bitcoinBtn = box.querySelector<HTMLButtonElement>('[data-provider="bitcoin"]');
    const bitcoinPopup = box.querySelector<HTMLElement>("[data-bitcoin-popup]");
    const copyBtcBtn = box.querySelector<HTMLButtonElement>("[data-copy-btc-btn]");
    const btcCopyStatus = box.querySelector<HTMLElement>("[data-btc-copy-status]");
    const btcWalletDisplay = box.querySelector<HTMLElement>("[data-btc-wallet-display]");

    let selectedAmount = 10;

    function updateAmountSelection(activeButton: HTMLButtonElement | null) {
      amountButtons.forEach((btn) => {
        btn.setAttribute("aria-pressed", "false");
      });

      if (activeButton) {
        activeButton.setAttribute("aria-pressed", "true");
      }

      if (activeButton && customInput) {
        customInput.value = "";
      }
    }

    function updateProviderUrls() {
      if (paypalLink) {
        const baseUrl = paypalLink.dataset.baseUrl || "";
        paypalLink.href = `${baseUrl}/${selectedAmount}`;
      }

      if (donorboxLink) {
        const baseUrl = donorboxLink.dataset.baseUrl || "";
        donorboxLink.href = `${baseUrl}?amount=${selectedAmount}`;
      }
    }

    amountButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        selectedAmount = parseInt(btn.dataset.amount || "10", 10);
        updateAmountSelection(btn);
        updateProviderUrls();
      });
    });

    if (customInput) {
      customInput.addEventListener("input", () => {
        const value = parseInt(customInput.value, 10);

        if (value > 0) {
          selectedAmount = value;
          updateAmountSelection(null);
          updateProviderUrls();
        }
      });

      customInput.addEventListener("focus", () => {
        updateAmountSelection(null);
      });
    }

    if (bitcoinBtn && bitcoinPopup) {
      bitcoinBtn.addEventListener("click", () => {
        const isHidden = bitcoinPopup.getAttribute("aria-hidden") === "true";
        bitcoinPopup.setAttribute("aria-hidden", isHidden ? "false" : "true");
      });
    }

    if (copyBtcBtn && btcWalletDisplay && btcCopyStatus) {
      copyBtcBtn.addEventListener("click", async () => {
        const address = btcWalletDisplay.textContent || "";

        try {
          await navigator.clipboard.writeText(address);
          btcCopyStatus.textContent = "Copied!";
          btcCopyStatus.classList.add("copied");

          setTimeout(() => {
            btcCopyStatus.textContent = "Click to copy";
            btcCopyStatus.classList.remove("copied");
          }, 2000);
        } catch (err) {
          console.error("Failed to copy:", err);
          btcCopyStatus.textContent = "Failed to copy";
        }
      });
    }

    updateProviderUrls();
  });
</script>

<style>
  .support-box {
    margin-inline: 0;
  }

  .support-box__layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.75rem;
    align-items: start;
  }

  .support-box__intro {
    max-width: 32rem;
  }

  .support-box__header {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .support-box__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.9rem;
    background: linear-gradient(135deg, #1457ff, #1d4ed8);
    color: white;
    box-shadow: 0 14px 28px rgba(20, 87, 255, 0.18);
  }

  .support-box__icon svg {
    fill: currentColor;
  }

  .section-heading {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    max-width: fit-content;
  }

  .section-heading > :first-child {
    min-width: 0;
    flex: 1 1 auto;
  }

  .section-anchor {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 2rem;
    height: 2rem;
    margin-top: 0.15rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.72);
    color: #64748b;
    text-decoration: none;
    box-shadow: 0 10px 18px rgba(15, 23, 42, 0.04);
    transition:
      transform 0.18s ease,
      color 0.18s ease,
      background-color 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .section-anchor:hover {
    transform: translateY(-1px);
    color: var(--color-primary-link);
    background: rgba(255, 255, 255, 0.96);
    border-color: rgba(37, 99, 235, 0.24);
    box-shadow: 0 14px 24px rgba(15, 23, 42, 0.07);
  }

  .section-anchor:focus-visible {
    outline: none;
    transform: translateY(-1px);
    color: var(--color-primary-link);
    background: rgba(255, 255, 255, 0.96);
    border-color: var(--color-primary-link);
    box-shadow: var(--focus-shadow);
  }

  .bi {
    vertical-align: -0.125em;
  }

  .support-box__title {
    font-size: clamp(1.9rem, 3.2vw, 2.5rem);
    color: #101828;
    margin: 0;
  }

  .support-box__desc {
    color: #475569;
    font-size: 1rem;
    margin: 0;
    max-width: 34rem;
    text-align: left;
    line-height: 1.72;
  }

  .support-box__panel {
    padding: 1.35rem;
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 18px 28px rgba(15, 23, 42, 0.04);
    backdrop-filter: blur(12px);
  }

  .support-box__label {
    margin: 0 0 1rem;
    color: #344054;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .donate-amounts {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .donate-amount {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 4.5rem;
    padding: 0.75rem 1.25rem;
    font-size: 1rem;
    font-weight: 700;
    color: #344054;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 999px;
    cursor: pointer;
    transition:
      transform 0.15s ease,
      border-color 0.15s ease,
      box-shadow 0.15s ease,
      background-color 0.15s ease;
  }

  .donate-amount:hover {
    transform: translateY(-1px);
    border-color: rgba(20, 87, 255, 0.18);
    background: rgba(255, 255, 255, 0.95);
  }

  .donate-amount[aria-pressed="true"] {
    background: linear-gradient(135deg, #1457ff, #1d4ed8);
    border-color: rgba(20, 87, 255, 0.2);
    color: white;
    box-shadow: 0 14px 24px rgba(20, 87, 255, 0.2);
  }

  .donate-amount-custom {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 999px;
    padding-left: 0.75rem;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }

  .donate-amount-custom:focus-within {
    border-color: #1457ff;
    box-shadow: var(--focus-shadow);
  }

  .donate-amount-custom__prefix {
    font-weight: 600;
    color: #64748b;
  }

  .donate-amount-custom__input {
    width: 5rem;
    padding: 0.75rem 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: #1e293b;
    background: transparent;
    border: none;
    outline: none;
  }

  .donate-amount-custom__input::placeholder {
    color: #94a3b8;
    font-weight: 500;
  }

  .donate-amount-custom__input::-webkit-outer-spin-button,
  .donate-amount-custom__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .donate-amount-custom__input[type="number"] {
    -moz-appearance: textfield;
  }

  .donate-providers {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 0.75rem;
  }

  .donate-provider {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease,
      filter 0.15s ease;
  }

  .donate-provider svg {
    flex-shrink: 0;
    fill: currentColor;
  }

  .donate-provider--paypal {
    background: #0070ba;
    color: white;
  }

  .donate-provider--paypal:hover {
    background: #005ea6;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 14px 24px rgba(0, 112, 186, 0.22);
  }

  .donate-provider--donorbox {
    background: #28a745;
    color: white;
  }

  .donate-provider--donorbox:hover {
    background: #218838;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 14px 24px rgba(40, 167, 69, 0.22);
  }

  .donate-provider--github {
    background: #24292f;
    color: white;
  }

  .donate-provider--github:hover {
    background: #1b1f23;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 14px 24px rgba(36, 41, 47, 0.22);
  }

  .donate-provider--bitcoin {
    background: #f7931a;
    color: white;
  }

  .donate-provider--bitcoin:hover {
    background: #e8850f;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 14px 24px rgba(247, 147, 26, 0.22);
  }

  .donate-bitcoin-popup {
    display: none;
    margin-top: 1rem;
    margin-inline: auto;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.82);
    border-radius: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.08);
    max-width: 400px;
  }

  .donate-bitcoin-popup[aria-hidden="false"] {
    display: block;
    animation: fade-in 0.2s ease;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .donate-bitcoin-popup__label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #64748b;
    margin-bottom: 0.5rem;
  }

  .donate-bitcoin-popup__address {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 0.75rem;
  }

  .donate-bitcoin-popup__address code {
    flex: 1;
    font-size: 0.8125rem;
    color: #1e293b;
    word-break: break-all;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
  }

  .donate-bitcoin-popup__copy {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    cursor: pointer;
    transition: all 0.15s ease;
    color: #64748b;
  }

  .donate-bitcoin-popup__copy:hover {
    background: #f1f5f9;
    border-color: #cbd5e1;
    color: #475569;
  }

  .donate-bitcoin-popup__hint {
    font-size: 0.75rem;
    color: #94a3b8;
    margin-top: 0.5rem;
    text-align: center;
  }

  .donate-bitcoin-popup__hint.copied {
    color: #059669;
    font-weight: 500;
  }

  @media (max-width: 767.98px) {
    .support-box {
      padding: 1.5rem;
      border-radius: 1.25rem;
    }

    .support-box__layout {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .support-box__title {
      font-size: 1.25rem;
    }
  }

  @media (max-width: 575.98px) {
    .donate-amounts {
      gap: 0.5rem;
    }

    .donate-amount {
      min-width: 3.5rem;
      padding: 0.625rem 1rem;
      font-size: 0.9375rem;
    }

    .donate-providers {
      flex-direction: column;
    }

    .donate-provider {
      width: 100%;
    }
  }
</style>
