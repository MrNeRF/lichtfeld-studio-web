---
/**
 * Scene selection card for the Showcase page.
 *
 * Displays a preview image and metadata for a 3D Gaussian Splat scene.
 * When clicked, the scene is loaded into the viewer.
 *
 * Uses a data-scene-id attribute for client-side scene switching.
 *
 * @module components/showcase/SceneCard
 */
import type { SceneConfig } from "@/constants/scenes";
import { renderSceneAttributionHtml } from "@/script/showcase/runtime/renderSceneAttributionHtml";

interface Props {
  /**
   * Scene configuration from the registry.
   */
  scene: SceneConfig;

  /**
   * Whether this scene is currently selected.
   */
  isSelected?: boolean;

  /**
   * Base path for asset URLs.
   */
  basePath?: string;
}

const { scene, isSelected = false, basePath = "" } = Astro.props;

/**
 * Construct the preview image URL.
 * Falls back to a placeholder if no preview is defined.
 */
const previewImagePath = scene.previewImage
  ? `${basePath}static/${scene.folderName}/${scene.previewImage}`
  : `${basePath}static/${scene.folderName}/preview.webp`;
const attributionHtml = renderSceneAttributionHtml(scene.credits);
---

<button
  class:list={["scene-card", { "scene-card--selected": isSelected }]}
  data-scene-id={scene.id}
  data-scene-folder={scene.folderName}
  type="button"
  aria-pressed={isSelected}
  aria-label={`Select ${scene.name} scene`}
>
  <!-- Preview image container -->
  <div class="scene-card__image-container">
    <img src={previewImagePath} alt={`Preview of ${scene.name}`} class="scene-card__image" loading="lazy" />

    <!-- Selection indicator overlay (eye = currently visible) -->
    <div class="scene-card__selected-indicator" aria-hidden="true">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        width="20"
        height="20"
      >
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
    </div>
  </div>

  <!-- Scene metadata -->
  <div class="scene-card__body">
    <h3 class="scene-card__title">{scene.name}</h3>
    <p class="scene-card__description">{scene.description}</p>

    {attributionHtml && <span class="scene-card__attribution" set:html={`Source: ${attributionHtml}`} />}
  </div>
</button>

<style>
  /**
   * Scene card styling with interactive states.
   * Uses CSS custom properties for theming consistency.
   */
  .scene-card {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100%;
    padding: 0;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: var(--card-radius);
    box-shadow: var(--card-shadow);
    cursor: pointer;
    overflow: hidden;
    text-align: left;
    font-family: inherit;
    transition:
      box-shadow 0.2s ease-in-out,
      transform 0.2s ease-in-out,
      border-color 0.2s ease-in-out;
  }

  .scene-card:hover {
    transform: translateY(var(--card-hover-lift));
    box-shadow: var(--card-shadow-hover);
    border-color: var(--color-border-hover);
  }

  /* Focus state for keyboard navigation */
  .scene-card:focus-visible {
    outline: none;
    border-color: var(--color-primary-link);
    box-shadow: var(--focus-shadow), var(--card-shadow-hover);
  }

  /* Selected state */
  .scene-card--selected {
    border-color: var(--color-primary-link);
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.22);
  }

  .scene-card--selected:hover {
    border-color: var(--color-primary-link);
  }

  /* Image container with aspect ratio */
  .scene-card__image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: rgba(241, 245, 249, 0.9);
  }

  .scene-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  /* Subtle zoom on hover */
  .scene-card:hover .scene-card__image {
    transform: scale(1.05);
  }

  /* Selection indicator (eye icon = currently visible) */
  .scene-card__selected-indicator {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: linear-gradient(135deg, #2563eb, #0ea5e9);
    border-radius: 50%;
    color: white;
    opacity: 0;
    transform: scale(0.8);
    transition:
      opacity 0.2s ease-in-out,
      transform 0.2s ease-in-out;
  }

  .scene-card--selected .scene-card__selected-indicator {
    opacity: 1;
    transform: scale(1);
  }

  /* Card body with text content */
  .scene-card__body {
    padding: var(--card-padding);
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .scene-card__title {
    margin: 0 0 0.7rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-heading);
  }

  .scene-card__description {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    flex-grow: 1;
  }

  .scene-card__attribution {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.9rem;
    line-height: 1.35;
    letter-spacing: 0.02em;
    color: rgba(156, 163, 175, 0.82);
  }

  .scene-card__attribution :global(a) {
    color: inherit;
    text-decoration-thickness: 0.04em;
    text-decoration-color: rgba(156, 163, 175, 0.22);
    text-underline-offset: 0.1em;
    transition:
      color 0.15s ease,
      text-decoration-color 0.15s ease;
  }

  .scene-card__attribution :global(a:hover) {
    color: rgba(107, 114, 128, 0.88);
    text-decoration-color: rgba(107, 114, 128, 0.35);
  }
</style>
