---
/**
 * StackedBarChart.astro
 *
 * A stacked bar chart component using ApexCharts for visualizing download
 * counts per period, with each version as a colored segment within each bar.
 *
 * Props:
 *   - id: Unique identifier for the chart container
 *   - height: Chart height in pixels (default: 400)
 *   - title: Optional chart title
 */

interface Props {
  id?: string;
  height?: number;
  title?: string;
}

const { id = "stacked-bar-chart", height = 400, title } = Astro.props;
---

<div class="stacked-bar-chart" data-chart-id={id}>
  {title && <h3 class="stacked-bar-chart__title">{title}</h3>}

  <div class="stacked-bar-chart__container" id={id} style={`height: ${height}px;`}>
    <div class="stacked-bar-chart__loading">
      <div class="stacked-bar-chart__spinner"></div>
      <span>Loading chart data...</span>
    </div>
  </div>
</div>

<script>
  import ApexCharts from "apexcharts";

  const CHART_COLORS = [
    "#0dcaf0", // Cyan (oldest version, bottom of stack)
    "#20c997", // Teal
    "#198754", // Green
    "#ffc107", // Yellow
    "#fd7e14", // Orange
    "#dc3545", // Red
    "#d63384", // Pink
    "#6f42c1", // Indigo
    "#6610f2", // Purple
    "#0d6efd", // Primary blue (newest version, top of stack)
  ];

  interface ChartDataPoint {
    x: number;
    y: number;
  }

  interface ChartSeries {
    name: string;
    data: ChartDataPoint[];
  }

  function formatTimestamp(timestamp: number, granularity: "daily" | "weekly" | "monthly"): string {
    const date = new Date(timestamp);

    if (granularity === "daily") {
      return date.toLocaleDateString(undefined, { month: "short", day: "numeric" });
    } else if (granularity === "weekly") {
      return `Week of ${date.toLocaleDateString(undefined, { month: "short", day: "numeric" })}`;
    } else {
      return date.toLocaleDateString(undefined, { month: "short", year: "2-digit" });
    }
  }

  function createChartOptions(
    series: ChartSeries[],
    granularity: "daily" | "weekly" | "monthly",
    containerHeight: number,
  ): ApexCharts.ApexOptions {
    return {
      chart: {
        type: "bar",
        height: containerHeight,
        stacked: true,
        fontFamily: "inherit",
        redrawOnParentResize: true,
        toolbar: {
          show: true,
          tools: {
            download: true,
            selection: false,
            zoom: true,
            zoomin: false,
            zoomout: false,
            pan: false,
            reset: true,
          },
        },
        animations: {
          enabled: true,
          easing: "easeinout",
          speed: 400,
        },
        zoom: {
          enabled: true,
          type: "x",
        },
        events: {
          mounted: (chart) => {
            chart.windowResizeHandler();
          },
        },
      },
      colors: CHART_COLORS.slice(-series.length),
      dataLabels: {
        enabled: false,
      },
      plotOptions: {
        bar: {
          columnWidth: granularity === "monthly" ? "40%" : granularity === "weekly" ? "50%" : "60%",
          borderRadius: 2,
          borderRadiusApplication: "end",
          borderRadiusWhenStacked: "last",
        },
      },
      series: series,
      xaxis: {
        type: "datetime",
        labels: {
          formatter: (value: string) => {
            return formatTimestamp(parseInt(value), granularity);
          },
          style: {
            colors: "#6c757d",
            fontSize: "11px",
          },
        },
        axisBorder: {
          show: false,
        },
        axisTicks: {
          show: false,
        },
      },
      yaxis: {
        labels: {
          formatter: (value: number) => {
            return new Intl.NumberFormat().format(Math.round(value));
          },
          style: {
            colors: "#6c757d",
            fontSize: "11px",
          },
        },
      },
      legend: {
        position: "bottom",
        horizontalAlign: "center",
        fontSize: "12px",
        markers: {
          size: 8,
          strokeWidth: 0,
          offsetX: -4,
        },
        itemMargin: {
          horizontal: 12,
          vertical: 4,
        },
      },
      tooltip: {
        shared: false,
        intersect: true,
        x: {
          formatter: (value: number) => {
            return formatTimestamp(value, granularity);
          },
        },
        y: {
          formatter: (value: number) => {
            return new Intl.NumberFormat().format(value) + " downloads";
          },
        },
      },
      grid: {
        borderColor: "#e9ecef",
        strokeDashArray: 4,
        padding: {
          left: 16,
          right: 16,
          top: 8,
          bottom: 8,
        },
        xaxis: {
          lines: {
            show: false,
          },
        },
      },
      responsive: [
        {
          breakpoint: 576,
          options: {
            legend: {
              position: "bottom",
              horizontalAlign: "center",
              fontSize: "11px",
            },
          },
        },
      ],
    };
  }

  document.addEventListener("DOMContentLoaded", () => {
    const chartContainers = document.querySelectorAll(".stacked-bar-chart");
    const charts = new Map<string, ApexCharts>();

    chartContainers.forEach((container) => {
      const chartElement = container.querySelector(".stacked-bar-chart__container");
      const chartId = (chartElement as HTMLElement)?.id;

      if (!chartElement || !chartId) return;

      container.addEventListener("chartdata", ((event: CustomEvent) => {
        const { series, granularity } = event.detail;

        const loading = container.querySelector(".stacked-bar-chart__loading");

        if (loading) {
          loading.remove();
        }

        if (charts.has(chartId)) {
          charts.get(chartId)?.destroy();
        }

        const containerHeight = (chartElement as HTMLElement).offsetHeight || 400;
        const options = createChartOptions(series, granularity, containerHeight);
        const chart = new ApexCharts(chartElement, options);

        chart.render();
        charts.set(chartId, chart);
      }) as EventListener);
    });
  });
</script>

<style>
  .stacked-bar-chart {
    width: 100%;
  }

  .stacked-bar-chart__title {
    margin-bottom: 1rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .stacked-bar-chart__container {
    width: 100%;
    padding: 1rem 0.5rem 0.5rem;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 1.25rem;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
  }

  .stacked-bar-chart__loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 1rem;
    color: #64748b;
  }

  .stacked-bar-chart__spinner {
    width: 2rem;
    height: 2rem;
    border: 3px solid rgba(148, 163, 184, 0.18);
    border-top-color: #2563eb;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .stacked-bar-chart :global(.apexcharts-toolbar) {
    z-index: 10;
  }

  .stacked-bar-chart :global(.apexcharts-legend) {
    justify-content: center;
  }

  .stacked-bar-chart :global(.apexcharts-menu) {
    border: 1px solid rgba(148, 163, 184, 0.16);
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
  }
</style>
