---
/**
 * BlogPostLayout.astro
 *
 * Single-column article layout for blog posts: a centered reading column
 * inside a shell surface, followed by a "more posts" card row. Reuses the
 * shared kicker/shell/card design tokens from the rest of the site.
 */
import type { CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import BlogCard from "@/components/BlogCard.astro";
import { formatBlogTag, resolveBlogImage } from "@/utils/blog";

interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;
const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith("/") ? base.slice(0, -1) : base;

const postImage = resolveBlogImage(base, post.data.image);
const imageAlt = post.data.imageAlt ?? `${post.data.title} preview`;
const description = post.data.description ?? post.data.summary;

const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const morePosts = posts.filter((entry) => entry.slug !== post.slug).slice(0, 2);
const breadcrumbs = [
  { name: "Home", url: base },
  { name: "Blog", url: `${cleanBase}/blog/` },
  { name: post.data.title, url: `${cleanBase}/blog/${post.slug}/` },
];
---

<Layout
  title={post.data.title}
  description={description}
  image={postImage}
  imageAlt={imageAlt}
  keywords={post.data.tags}
  section={post.data.category}
  ogType="article"
  publishedDate={post.data.date}
  modifiedDate={post.data.updatedDate ?? post.data.date}
  breadcrumbs={breadcrumbs}
>
  <section class="blog-post-page">
    <div class="container blog-post-frame px-4 py-5">
      <article class="shell blog-post">
        <a href={`${cleanBase}/blog/`} class="blog-post__back">
          <span aria-hidden="true">←</span>
          All posts
        </a>

        <header class="blog-post__header">
          <p class="kicker">{post.data.category}</p>
          <h1 class="blog-post__title">{post.data.title}</h1>
          <p class="blog-post__summary">{post.data.summary}</p>
          <p class="blog-post__byline">
            <time datetime={post.data.date.toISOString()}>{dateFormatter.format(post.data.date)}</time>
            <span class="blog-post__byline-sep" aria-hidden="true">·</span>
            <span>{post.data.author}</span>
            {
              post.data.updatedDate && (
                <>
                  <span class="blog-post__byline-sep" aria-hidden="true">
                    ·
                  </span>
                  <span>Updated {dateFormatter.format(post.data.updatedDate)}</span>
                </>
              )
            }
          </p>
        </header>

        <figure class="blog-post__figure">
          <img src={postImage} alt={imageAlt} loading="eager" />
        </figure>

        <div class="blog-post__content prose">
          <slot />
        </div>

        {
          post.data.tags.length > 0 && (
            <footer class="blog-post__footer">
              <ul class="blog-post__tags" aria-label="Post tags">
                {post.data.tags.map((tag) => (
                  <li>{formatBlogTag(tag)}</li>
                ))}
              </ul>
            </footer>
          )
        }
      </article>

      {
        morePosts.length > 0 && (
          <aside class="shell mt-4" aria-labelledby="more-posts-heading">
            <div class="section-head">
              <div>
                <p class="kicker mb-2">Keep reading</p>
                <h2 id="more-posts-heading" class="section-title">
                  More from the blog
                </h2>
              </div>
              <a href={`${cleanBase}/blog/`} class="section-link">All posts</a>
            </div>

            <div class="blog-post__more-grid mt-4">
              {morePosts.map((entry) => (
                <BlogCard post={entry} />
              ))}
            </div>
          </aside>
        )
      }
    </div>
  </section>
</Layout>

<style>
  .blog-post-page {
    background: var(--page-bg);
  }

  .blog-post-frame {
    max-width: 56rem !important;
  }

  .blog-post {
    padding: clamp(1.5rem, 4vw, 2.75rem);
  }

  .blog-post__back {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1.6rem;
    color: var(--color-primary-link);
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 700;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .blog-post__back:hover {
    color: var(--color-primary-link-hover);
  }

  .blog-post__title {
    margin: 0 0 0.9rem;
    color: var(--color-heading);
    font-size: clamp(2.1rem, 5vw, 3.3rem);
    line-height: 1.02;
  }

  .blog-post__summary {
    margin: 0;
    max-width: 42rem;
    color: var(--color-body-strong);
    font-size: 1.08rem;
    line-height: 1.76;
  }

  .blog-post__byline {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.55rem;
    margin: 1.1rem 0 0;
    color: var(--color-muted);
    font-size: 0.92rem;
    font-weight: 600;
  }

  .blog-post__byline-sep {
    color: rgba(102, 112, 133, 0.55);
  }

  .blog-post__figure {
    margin: 1.7rem 0 0;
    overflow: hidden;
    border-radius: 1.2rem;
    border: 1px solid var(--card-border);
    background: #101828;
    box-shadow: var(--card-shadow);
  }

  .blog-post__figure img {
    display: block;
    width: 100%;
    aspect-ratio: 2 / 1;
    object-fit: cover;
  }

  .blog-post__content {
    margin-top: 2.1rem;
  }

  .blog-post__footer {
    margin-top: 2.2rem;
    padding-top: 1.3rem;
    border-top: 1px solid var(--color-border-subtle);
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .blog-post__tags li {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.68rem;
    border-radius: var(--radius-pill);
    background: rgba(var(--color-primary-rgb), 0.07);
    border: 1px solid rgba(var(--color-primary-rgb), 0.14);
    color: var(--color-primary-link);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .blog-post__more-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 767.98px) {
    .blog-post__more-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
