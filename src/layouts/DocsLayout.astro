---
import Layout from "@/layouts/Layout.astro";

interface Props {
  title: string;
  description: string;
  headings: Array<{ depth: number; slug: string; text: string }>;
  docEntries: Array<{ slug: string; data: { title: string; order: number } }>;
  currentSlug: string;
}

const { title, description, headings, docEntries, currentSlug } = Astro.props;
const base = import.meta.env.BASE_URL;
const normalize = (p: string) => (p.endsWith("/") ? p.slice(0, -1) : p);
const cleanBase = normalize(base);

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<Layout title={title} description={description}>
  <section class="docs-page">
    <div class="container content-frame px-4 py-5">
      <div class="row g-4">
        <div class="col-12 col-lg-4 order-1 order-lg-2">
          <aside class="shell shell--compact docs-sidebar">
            <p class="kicker">Documentation</p>
            <nav class="docs-sidebar__nav">
              {
                docEntries.map((entry) => (
                  <a
                    href={`${cleanBase}/docs/${entry.slug}`}
                    class:list={["docs-sidebar__link", { "is-active": entry.slug === currentSlug }]}
                  >
                    {entry.data.title}
                  </a>
                ))
              }
            </nav>

            {
              tocHeadings.length > 0 && (
                <>
                  <div class="docs-sidebar__sep docs-sidebar__sep--desktop" />
                  <p class="docs-sidebar__toc-label docs-sidebar__toc-label--desktop">On this page</p>
                  <nav class="docs-sidebar__toc docs-sidebar__toc--desktop">
                    {tocHeadings.map((h) => (
                      <a
                        href={`#${h.slug}`}
                        class:list={["docs-sidebar__toc-link", { "docs-sidebar__toc-link--h3": h.depth === 3 }]}
                        data-heading-slug={h.slug}
                      >
                        {h.text}
                      </a>
                    ))}
                  </nav>
                  <details class="docs-toc-disclosure">
                    <summary>On this page</summary>
                    <nav class="docs-sidebar__toc docs-sidebar__toc--mobile" aria-label="On this page">
                      {tocHeadings.map((h) => (
                        <a
                          href={`#${h.slug}`}
                          class:list={["docs-sidebar__toc-link", { "docs-sidebar__toc-link--h3": h.depth === 3 }]}
                          data-heading-slug={h.slug}
                        >
                          {h.text}
                        </a>
                      ))}
                    </nav>
                  </details>
                </>
              )
            }
          </aside>
        </div>
        <div class="col-12 col-lg-8 order-2 order-lg-1">
          <article class="shell docs-article">
            <p class="kicker">{title}</p>
            <div class="docs-article__content prose">
              <slot />
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  function initTocObserver() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".docs-sidebar__toc-link");
    if (!tocLinks.length) return;

    const slugToLinks = new Map<string, HTMLAnchorElement[]>();
    tocLinks.forEach((link) => {
      const slug = link.dataset.headingSlug;
      if (!slug) return;

      const links = slugToLinks.get(slug) ?? [];
      links.push(link);
      slugToLinks.set(slug, links);
    });

    const headingEls = Array.from(slugToLinks.keys())
      .map((slug) => document.getElementById(slug))
      .filter(Boolean) as HTMLElement[];

    if (!headingEls.length) return;

    const setActive = (slug: string) => {
      tocLinks.forEach((l) => l.classList.remove("is-active"));
      const activeLinks = slugToLinks.get(slug) ?? [];
      activeLinks.forEach((link) => link.classList.add("is-active"));
    };

    const navHeight = parseInt(getComputedStyle(document.documentElement).getPropertyValue("--nav-height")) || 60;
    const rootMargin = `${-(navHeight + 24)}px 0px -66% 0px`;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      { rootMargin, threshold: 0 },
    );

    headingEls.forEach((el) => observer.observe(el));
  }

  function initCodeCopy() {
    document.querySelectorAll<HTMLPreElement>(".docs-article__content pre").forEach((pre) => {
      const wrapper = document.createElement("div");
      wrapper.className = "code-block";
      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const btn = document.createElement("button");
      btn.className = "code-copy";
      btn.setAttribute("aria-label", "Copy code");
      btn.innerHTML =
        '<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5.5" y="5.5" width="9" height="9" rx="1.5"/><path d="M10.5 5.5V3a1.5 1.5 0 0 0-1.5-1.5H3A1.5 1.5 0 0 0 1.5 3v6A1.5 1.5 0 0 0 3 10.5h2.5"/></svg>';
      wrapper.appendChild(btn);

      btn.addEventListener("click", () => {
        const code = pre.querySelector("code");
        const text = (code || pre).textContent || "";
        navigator.clipboard.writeText(text).then(() => {
          btn.classList.add("is-copied");
          btn.innerHTML =
            '<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3.5 8.5 6.5 11.5 12.5 4.5"/></svg>';
          setTimeout(() => {
            btn.classList.remove("is-copied");
            btn.innerHTML =
              '<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5.5" y="5.5" width="9" height="9" rx="1.5"/><path d="M10.5 5.5V3a1.5 1.5 0 0 0-1.5-1.5H3A1.5 1.5 0 0 0 1.5 3v6A1.5 1.5 0 0 0 3 10.5h2.5"/></svg>';
          }, 1500);
        });
      });
    });
  }

  function initAll() {
    initTocObserver();
    initCodeCopy();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAll, { once: true });
  } else {
    initAll();
  }
</script>

<style>
  .docs-page {
    background: var(--page-bg);
  }

  .docs-page .row,
  .docs-page [class*="col-"],
  .docs-sidebar,
  .docs-article,
  .docs-article__content {
    min-width: 0;
  }

  .docs-article__content {
    max-width: 100%;
    overflow-wrap: break-word;
  }

  .docs-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + 1.25rem);
  }

  /* The sidebar sits to the right of the article on large screens; a hairline
     border keeps it reading as a distinct column now that the glass shells are flat. */
  @media (min-width: 992px) {
    .docs-sidebar {
      border-left: 1px solid var(--color-border-subtle);
      padding-left: 1.5rem;
    }
  }

  .docs-sidebar__nav {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .docs-sidebar__link {
    display: block;
    padding: 0.65rem 0.85rem;
    border-radius: 0.85rem;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--color-heading);
    text-decoration: none;
    transition:
      background 0.15s ease-in-out,
      box-shadow 0.15s ease-in-out;
  }

  .docs-sidebar__link:hover {
    background: rgba(var(--color-primary-rgb), 0.04);
  }

  .docs-sidebar__link.is-active {
    background: rgba(var(--color-primary-rgb), 0.08);
    box-shadow: inset 0 0 0 1px rgba(var(--color-primary-rgb), 0.14);
  }

  .docs-sidebar__sep {
    height: 1px;
    background: var(--color-border-subtle);
    margin: 0.75rem 0;
  }

  .docs-sidebar__toc-label {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    margin: 0 0 0.4rem;
    padding: 0 0.85rem;
  }

  .docs-sidebar__toc {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    max-height: 60vh;
    overflow-y: auto;
  }

  .docs-toc-disclosure {
    display: none;
  }

  .docs-sidebar__toc-link {
    display: block;
    padding: 0.3rem 0.85rem;
    font-size: 0.84rem;
    color: var(--color-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition:
      color 0.15s ease-in-out,
      border-color 0.15s ease-in-out;
  }

  .docs-sidebar__toc-link--h3 {
    padding-left: 1.85rem;
  }

  .docs-sidebar__toc-link:hover {
    color: var(--color-primary-link);
  }

  .docs-sidebar__toc-link.is-active {
    color: var(--color-primary-link);
    border-left-color: var(--color-primary);
  }

  .docs-article {
    padding-bottom: clamp(1.75rem, 3vw, 2.75rem);
  }

  /* Markdown typography comes from the shared .prose class (src/styles/prose.css). */

  @media (max-width: 991.98px) {
    .docs-sidebar {
      position: static;
      top: auto;
      /* Stacked above the article on small screens: separate with a hairline. */
      border-bottom: 1px solid var(--color-border-subtle);
      padding-bottom: 0.9rem;
    }

    .docs-sidebar__nav {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.45rem;
    }

    .docs-sidebar__link {
      min-height: 2.75rem;
      padding: 0.62rem 0.75rem;
      font-size: 0.86rem;
      border-radius: var(--rounded-lg);
    }

    .docs-sidebar__sep--desktop,
    .docs-sidebar__toc-label--desktop,
    .docs-sidebar__toc--desktop {
      display: none;
    }

    .docs-toc-disclosure {
      display: block;
      margin-top: 0.75rem;
      border-top: 1px solid var(--color-border-subtle);
      padding-top: 0.75rem;
    }

    .docs-toc-disclosure summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 2.75rem;
      padding: 0.62rem 0.75rem;
      border: 1px solid var(--color-border-subtle);
      border-radius: var(--rounded-lg);
      color: var(--color-heading);
      cursor: pointer;
      font-weight: 800;
      list-style: none;
    }

    .docs-toc-disclosure summary::-webkit-details-marker {
      display: none;
    }

    .docs-toc-disclosure summary::after {
      content: "＋";
      color: var(--color-muted);
      font-size: 1rem;
      line-height: 1;
    }

    .docs-toc-disclosure[open] summary::after {
      content: "−";
    }

    .docs-sidebar__toc {
      max-height: none;
      margin-top: 0.55rem;
      padding-block: 0.2rem;
    }
  }

  @media (max-width: 575.98px) {
    .docs-sidebar__nav {
      grid-template-columns: 1fr;
    }
  }
</style>
