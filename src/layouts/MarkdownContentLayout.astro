---
/**
 * A reusable layout for pages that display markdown content fetched from a remote URL.
 * It handles fetching, parsing, and rendering the content within a standardized, styled container.
 *
 * Props:
 *  - title?: string — An optional main heading to display on the page (also used for SEO).
 *  - description?: string — Meta description for SEO.
 *  - sourceUrl: string — The raw URL of the markdown file to fetch.
 */
import Layout from "@/layouts/Layout.astro";
import { getRemoteMarkdownAsHtml } from "@/services/remote-content";
import { SITE } from "@/config/site.config";

interface Props {
  /** Page title for display and SEO */
  title?: string;
  /** Meta description for SEO */
  description?: string;
  /** Raw URL of the markdown file to fetch */
  sourceUrl: string;
}

const { title, description, sourceUrl } = Astro.props;

// Fetch and parse the remote markdown content at build time.
const contentHtml = await getRemoteMarkdownAsHtml(sourceUrl);

// SEO: Use provided description or generate a default based on title
const seoTitle = title || "Documentation";
const seoDescription = description || `${seoTitle} - ${SITE.tagline}`;
---

<Layout title={seoTitle} description={seoDescription}>
  <div class="container px-4 py-5">
    <div class="row">
      <div class="col-lg-10 mx-auto">
        <article class="shell markdown-content prose">
          {title && <h1 class="pb-2 border-bottom">{title}</h1>}
          <div set:html={contentHtml} />
        </article>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Markdown typography comes from the shared .prose class (src/styles/prose.css). */
  .markdown-content {
    padding-bottom: clamp(1.75rem, 3vw, 2.75rem);
  }
</style>
