---
/**
 * alternatives.astro
 *
 * Curation page: Best 3D Gaussian Splatting Software 2025
 * Targets searches for "best 3d gaussian splatting software", "gaussian splatting tools",
 * "3dgs software comparison", "gaussian splatting software alternatives"
 */
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config/site.config";
import {
  GITHUB_REPO_URL,
  GITHUB_RELEASES_URL,
  GITHUB_WIKI_URL,
  DISCORD_URL,
  GITHUB_SPONSORS_URL,
  PAYPAL_URL,
  DONORBOX_URL,
} from "@/constants/project";

const base = import.meta.env.BASE_URL;

// SEO metadata
const seoTitle = "Best 3D Gaussian Splatting Software 2025: Top Tools Compared";
const seoDescription =
  "Discover the best 3D Gaussian Splatting software. Compare LichtFeld Studio, Brush, NerfStudio, SuperSplat, and more. Features, pricing, and recommendations.";

// Tool data for curation
const tools = [
  {
    id: "lichtfeld-studio",
    name: "LichtFeld Studio",
    tagline: "Open-source 3D Gaussian Splatting platform",
    type: "open-source",
    price: "Free",
    license: "GPL-3.0",
    platforms: ["Windows", "Linux"],
    featured: true,
    badges: ["Top Pick", "Open Source", "Free Forever"],
    features: [
      "Native C++23/CUDA training",
      "Full editing suite (brush, lasso, polygon)",
      "Python plugin system + MCP",
      "Save & resume training",
      "Registry-based plugin installs",
    ],
    website: GITHUB_REPO_URL,
    downloadUrl: GITHUB_RELEASES_URL,
    docsUrl: GITHUB_WIKI_URL,
    compareUrl: `${base}vs/postshot/`,
  },
  {
    id: "brush",
    name: "Brush",
    tagline: "Cross-platform 3D Gaussian Splatting training and viewer",
    type: "open-source",
    price: "Free",
    license: "Apache-2.0",
    platforms: ["Windows", "Linux", "macOS", "Web"],
    featured: false,
    badges: ["WebGPU", "Rust", "Cross-Platform"],
    features: [
      "3D Gaussian Splatting training",
      "WebGPU-based rendering",
      "Cross-platform (desktop and web)",
      "No installation required for web",
      "PLY import/export",
      "Written in Rust",
    ],
    website: "https://github.com/ArthurBrussee/brush",
    compareUrl: `${base}vs/brush/`,
  },
  {
    id: "nerfstudio",
    name: "NerfStudio",
    tagline: "Research framework for neural radiance fields",
    type: "open-source",
    price: "Free",
    license: "Apache-2.0",
    platforms: ["Windows", "macOS", "Linux"],
    featured: false,
    badges: ["Research-Grade", "Python", "Extensible"],
    features: [
      "Multiple NeRF methods",
      "Gaussian Splatting support",
      "Python-based framework",
      "Extensive documentation",
      "Academic focus",
      "Viewer included",
    ],
    website: "https://docs.nerf.studio/",
  },
  {
    id: "supersplat",
    name: "SuperSplat",
    tagline: "Web-based Gaussian Splatting viewer and editor",
    type: "open-source",
    price: "Free",
    license: "MIT",
    platforms: ["Any (Web-based)"],
    featured: false,
    badges: ["Web Viewer", "Editor", "PlayCanvas"],
    features: [
      "Browser-based editor",
      "Visual splat editing",
      "PLY import/export",
      "Camera controls",
      "Export to various formats",
      "No install needed",
    ],
    website: "https://playcanvas.com/supersplat/editor/",
  },
];

// Comparison table data
const comparisonFeatures = [
  { feature: "Price", category: "General" },
  { feature: "License", category: "General" },
  { feature: "Platforms", category: "General" },
  { feature: "Native Training", category: "Core Features" },
  { feature: "Real-time Viewer", category: "Core Features" },
  { feature: "Editing Tools", category: "Core Features" },
  { feature: "Plugin System", category: "Extensibility" },
  { feature: "Python API", category: "Extensibility" },
  { feature: "MCP Integration", category: "Extensibility" },
  { feature: "Save/Resume Training", category: "Core Features" },
  { feature: "Multi-GPU Support", category: "Performance" },
  { feature: "Source Code Access", category: "General" },
];

const comparisonData: Record<string, Record<string, string | boolean>> = {
  "lichtfeld-studio": {
    Price: "Free",
    License: "GPL-3.0",
    Platforms: "Windows, Linux",
    "Native Training": true,
    "Real-time Viewer": true,
    "Editing Tools": "Full Suite",
    "Plugin System": "Python + MCP",
    "Python API": true,
    "MCP Integration": true,
    "Save/Resume Training": true,
    "Multi-GPU Support": false,
    "Source Code Access": "Full",
  },
  postshot: {
    Price: "Paid",
    License: "Proprietary",
    Platforms: "Windows, macOS",
    "Native Training": true,
    "Real-time Viewer": true,
    "Editing Tools": "Basic",
    "Plugin System": false,
    "Python API": false,
    "MCP Integration": false,
    "Save/Resume Training": false,
    "Multi-GPU Support": false,
    "Source Code Access": "None",
  },
  brush: {
    Price: "Free",
    License: "Apache-2.0",
    Platforms: "Windows, Linux, macOS, Web",
    "Native Training": true,
    "Real-time Viewer": true,
    "Editing Tools": "Basic",
    "Plugin System": false,
    "Python API": false,
    "MCP Integration": false,
    "Save/Resume Training": false,
    "Multi-GPU Support": false,
    "Source Code Access": "Full",
  },
  nerfstudio: {
    Price: "Free",
    License: "Apache-2.0",
    Platforms: "Windows, macOS, Linux",
    "Native Training": true,
    "Real-time Viewer": true,
    "Editing Tools": "Basic",
    "Plugin System": "Extensible",
    "Python API": true,
    "MCP Integration": false,
    "Save/Resume Training": true,
    "Multi-GPU Support": true,
    "Source Code Access": "Full",
  },
  supersplat: {
    Price: "Free",
    License: "MIT",
    Platforms: "Any (Web-based)",
    "Native Training": false,
    "Real-time Viewer": true,
    "Editing Tools": "Viewer + Basic",
    "Plugin System": false,
    "Python API": false,
    "MCP Integration": false,
    "Save/Resume Training": false,
    "Multi-GPU Support": false,
    "Source Code Access": "Full",
  },
};

// FAQ data
const faqs = [
  {
    question: "What is 3D Gaussian Splatting software?",
    answer:
      "3D Gaussian Splatting software enables the creation, editing, and rendering of 3D scenes represented as collections of 3D Gaussians. These tools convert photos or video into interactive 3D scenes that can be viewed in real-time, exported to game engines, or used in production workflows.",
  },
  {
    question: "Is free 3DGS software as good as paid options?",
    answer:
      "Yes, and often better. LichtFeld Studio, our top pick, is completely free and open source yet offers more features and competitive (often superior) performance compared to commercial alternatives like Postshot. Free and open source doesn't mean lower quality — our native C++23/CUDA core delivers professional-grade performance at zero cost. The open-source nature means continuous improvements from the community and no vendor lock-in.",
  },
  {
    question: "Which tool is best for beginners?",
    answer:
      "For beginners, LichtFeld Studio offers the most complete package with an intuitive interface and comprehensive documentation on Windows and Linux. For macOS users, we recommend Brush—it provides excellent cross-platform support with native macOS training (both Intel and Apple Silicon), WebGPU-based rendering (no CUDA required), and a polished interface. For quick experimentation without installation, SuperSplat's web-based editor is ideal.",
  },
  {
    question: "Can I use these tools commercially?",
    answer:
      "All the tools listed here allow commercial use under their respective open-source licenses (GPL-3.0, Apache-2.0, MIT). Always check the specific license for your use case.",
  },
  {
    question: "What hardware do I need?",
    answer:
      "For training 3D Gaussian Splats, an NVIDIA GPU with at least 8GB VRAM is recommended. Viewing and editing can work on less powerful hardware. Web-based tools like SuperSplat and Brush can run on any device with a modern browser.",
  },
  {
    question: "Can I switch between tools?",
    answer:
      "Yes! Most tools use standard PLY format for 3D Gaussians, allowing you to train in one tool and edit in another. For example, you can train with Brush and edit with LichtFeld Studio or SuperSplat.",
  },
];

// Schema.org structured data
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Best 3D Gaussian Splatting Software 2025",
  description: seoDescription,
  itemListElement: tools.map((tool, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "SoftwareApplication",
      name: tool.name,
      description: tool.tagline,
      applicationCategory: "DeveloperApplication",
      operatingSystem: tool.platforms,
      offers: {
        "@type": "Offer",
        price: tool.price === "Free" ? "0" : tool.price,
        priceCurrency: "USD",
      },
      url: tool.website,
    },
  })),
};

const comparisonSchema = {
  "@context": "https://schema.org",
  "@type": "Comparison",
  name: "3D Gaussian Splatting Software Comparison",
  description: "Comparison of top 3DGS tools including features, pricing, and platforms",
};
---

<Layout title={seoTitle} description={seoDescription}>
  {/* Schema.org structured data */}
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(comparisonSchema)} />

  {/* Hero Section */}
  <header class="alt-hero">
    <div class="container content-frame px-4 px-md-6 py-16">
      <div class="alt-hero__content">
        <div class="alt-hero__badge">
          <i class="bi bi-award"></i>
          <span>2026 Software Guide</span>
        </div>
        <h1 class="alt-hero__title">Best 3D Gaussian Splatting Software</h1>
        <p class="alt-hero__subtitle">
          The complete guide to 3DGS tools. Compare the top 4 Gaussian Splatting applications with features,
          pricing, and our expert recommendations.
        </p>
        <div class="alt-hero__stats">
          <div class="alt-hero__stat">
            <span class="alt-hero__stat-number">5</span>
            <span class="alt-hero__stat-label">Tools Compared</span>
          </div>
          <div class="alt-hero__stat">
            <span class="alt-hero__stat-number">100%</span>
            <span class="alt-hero__stat-label">Free Options</span>
          </div>
        </div>
        <div class="alt-hero__cta">
          <a href="#top-picks" class="btn btn-primary btn-lg alt-hero__btn-primary">
            <i class="bi bi-trophy mr-2"></i>
            See Top Picks
          </a>
          <a href="#comparison-table" class="btn btn-outline-primary btn-lg alt-hero__btn-secondary">
            <i class="bi bi-table mr-2"></i>
            Full Comparison
          </a>
        </div>
      </div>
    </div>
  </header>

  {/* What to Look For Section */}
  <section id="what-to-look-for" class="alt-section hash-section">
    <div class="container content-frame px-4 px-md-6 py-16">
      <div class="shell shell--spacious">
        <div class="alt-section__header">
          <p class="kicker">Buyer's Guide</p>
          <h2 class="alt-section__title">What to Look for in 3DGS Software</h2>
          <p class="alt-section__desc">Key features that separate great tools from mediocre ones.</p>
        </div>

        <div class="alt-features-grid">
          <div class="alt-feature-card">
            <div class="alt-feature-card__icon">
              <i class="bi bi-cpu"></i>
            </div>
            <h3 class="alt-feature-card__title">Native Training</h3>
            <p class="alt-feature-card__desc">
              Look for tools with native C++/CUDA training cores for speed and efficiency. Save/resume capabilities are
              essential for long training runs.
            </p>
          </div>
          <div class="alt-feature-card">
            <div class="alt-feature-card__icon">
              <i class="bi bi-brush"></i>
            </div>
            <h3 class="alt-feature-card__title">Editing Tools</h3>
            <p class="alt-feature-card__desc">
              Brush, lasso, polygon selection, masking, and cropping tools let you clean up and refine your splats after
              training.
            </p>
          </div>
          <div class="alt-feature-card">
            <div class="alt-feature-card__icon">
              <i class="bi bi-plug"></i>
            </div>
            <h3 class="alt-feature-card__title">Extensibility</h3>
            <p class="alt-feature-card__desc">
              Python plugins and MCP integration enable custom workflows and automation. Essential for production
              environments.
            </p>
          </div>
          <div class="alt-feature-card">
            <div class="alt-feature-card__icon">
              <i class="bi bi-display"></i>
            </div>
            <h3 class="alt-feature-card__title">Platform Support</h3>
            <p class="alt-feature-card__desc">
              Consider your OS (Windows, Linux, macOS) and whether you need web-based access for collaboration or
              demonstrations.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Top Picks / Featured Tools */}
  <section id="top-picks" class="alt-section hash-section">
    <div class="container content-frame px-4 px-md-6 py-16">
      <div class="shell shell--spacious alt-shell--highlight">
        <div class="alt-section__header">
          <p class="kicker">Editor's Choice</p>
          <h2 class="alt-section__title">The Best 3D Gaussian Splatting Tools</h2>
          <p class="alt-section__desc">Our top recommendations based on features, value, and user experience.</p>
        </div>

        <div class="alt-tools-grid">
          {
            tools.map((tool) => (
              <article class:list={["alt-tool-card", tool.featured && "alt-tool-card--featured"]}>
                {tool.featured && (
                  <div class="alt-tool-card__ribbon">
                    <i class="bi bi-star-fill" />
                    <span>Top Pick</span>
                  </div>
                )}

                <div class="alt-tool-card__header">
                  <div class="alt-tool-card__badges">
                    {tool.badges.map((badge) => (
                      <span class:list={["alt-tool-card__badge", badge === "Top Pick" && "alt-tool-card__badge--top"]}>
                        {badge}
                      </span>
                    ))}
                  </div>
                  <h3 class="alt-tool-card__name">{tool.name}</h3>
                  <p class="alt-tool-card__tagline">{tool.tagline}</p>
                </div>

                <div class="alt-tool-card__meta">
                  <div class="alt-tool-card__details">
                    <span class="alt-tool-card__price">{tool.price}</span>
                    <span class="alt-tool-card__separator">•</span>
                    <span class="alt-tool-card__license">{tool.license}</span>
                  </div>
                </div>

                <div class="alt-tool-card__platforms">
                  {tool.platforms.map((platform) => (
                    <span class="alt-tool-card__platform">
                      <i class:list={["bi", platform === "Windows" ? "bi-windows" : platform === "macOS" ? "bi-apple" : "bi-laptop"]} />
                      {platform}
                    </span>
                  ))}
                </div>

                <ul class="alt-tool-card__features">
                  {tool.features.slice(0, 4).map((feature) => (
                    <li>
                      <i class="bi bi-check-lg" />
                      {feature}
                    </li>
                  ))}
                </ul>

                <div class="alt-tool-card__actions">
                  {tool.downloadUrl ? (
                    <a href={tool.downloadUrl} class="btn btn-primary alt-tool-card__btn" target="_blank" rel="noopener noreferrer">
                      <i class="bi bi-download mr-2" />
                      Download
                    </a>
                  ) : (
                    <a href={tool.website} class="btn btn-primary alt-tool-card__btn" target="_blank" rel="noopener noreferrer">
                      <i class="bi bi-box-arrow-up-right mr-2" />
                      Visit Website
                    </a>
                  )}
                  {tool.compareUrl && (
                    <a href={tool.compareUrl} class="btn btn-outline-primary alt-tool-card__btn alt-tool-card__btn--secondary">
                      <i class="bi bi-arrow-left-right mr-2" />
                      Compare
                    </a>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  {/* Comparison Table */}
  <section id="comparison-table" class="alt-section hash-section">
    <div class="container content-frame px-4 px-md-6 py-16">
      <div class="shell shell--spacious">
        <div class="alt-section__header">
          <p class="kicker">Side-by-Side</p>
          <h2 class="alt-section__title">Complete Comparison Table</h2>
          <p class="alt-section__desc">Every feature compared across all recommended tools plus commercial alternatives.</p>
        </div>

        <div class="alt-table-wrapper">
          <table class="alt-table">
            <thead>
              <tr>
                <th class="alt-table__feature">Feature</th>
                {tools.map((tool) => (
                  <th class:list={["alt-table__tool", tool.featured && "alt-table__tool--featured"]}>
                    <span class="alt-table__tool-name">{tool.name}</span>
                    {tool.featured && <span class="alt-table__tool-badge">Top Pick</span>}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {comparisonFeatures.map((row) => (
                <tr>
                  <td class="alt-table__feature">
                    <span class="alt-table__feature-name">{row.feature}</span>
                    <span class="alt-table__feature-category">{row.category}</span>
                  </td>
                  {tools.map((tool) => {
                    const value = comparisonData[tool.id][row.feature];
                    return (
                      <td class:list={["alt-table__cell", tool.featured && "alt-table__cell--featured"]}>
                        {typeof value === "boolean" ? (
                          value ? (
                            <span class="alt-table__yes">
                              <i class="bi bi-check-lg" /> Yes
                            </span>
                          ) : (
                            <span class="alt-table__no">
                              <i class="bi bi-x-lg" /> No
                            </span>
                          )
                        ) : (
                          <span class="alt-table__value">{value}</span>
                        )}
                      </td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="alt-table-legend">
          <div class="alt-table-legend__item">
            <span class="alt-table-legend__icon alt-table-legend__icon--yes">
              <i class="bi bi-check-lg" />
            </span>
            <span>Available</span>
          </div>
          <div class="alt-table-legend__item">
            <span class="alt-table-legend__icon alt-table-legend__icon--no">
              <i class="bi bi-x-lg" />
            </span>
            <span>Not Available</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Free vs Paid */}
  <section id="free-vs-paid" class="alt-section hash-section">
    <div class="container content-frame px-4 px-md-6 py-16">
      <div class="shell shell--spacious">
        <div class="alt-section__header">
          <p class="kicker">Pricing Models</p>
          <h2 class="alt-section__title">Free vs Paid Options</h2>
          <p class="alt-section__desc">
            <strong>Free and open source doesn't mean lower quality.</strong> Paid subscriptions don't guarantee better
            performance. LichtFeld Studio delivers professional-grade performance at zero cost.
          </p>
        </div>

        <div class="alt-comparison-cards">
          <div class="alt-comparison-card alt-comparison-card--free">
            <div class="alt-comparison-card__header">
              <div class="alt-comparison-card__icon">
                <i class="bi bi-gift"></i>
              </div>
              <h3 class="alt-comparison-card__title">Free & Open Source</h3>
              <p class="alt-comparison-card__subtitle">All tools listed are 100% free — with no performance compromise</p>
            </div>
            <ul class="alt-comparison-card__list">
              <li>
                <i class="bi bi-check-lg" />
                <span>No licensing costs ever</span>
              </li>
              <li>
                <i class="bi bi-check-lg" />
                <span>Full source code access</span>
              </li>
              <li>
                <i class="bi bi-check-lg" />
                <span>Professional-grade performance</span>
              </li>
              <li>
                <i class="bi bi-check-lg" />
                <span>No subscription fees, no feature gates</span>
              </li>
              <li>
                <i class="bi bi-check-lg" />
                <span>Community-driven development</span>
              </li>
              <li>
                <i class="bi bi-check-lg" />
                <span>No vendor lock-in</span>
              </li>
              <li>
                <i class="bi bi-check-lg" />
                <span>Customize and extend</span>
              </li>
            </ul>
            <div class="alt-comparison-card__examples">
              <span class="alt-comparison-card__examples-label">Examples:</span>
              <span class="alt-comparison-card__examples-list">LichtFeld Studio, NerfStudio, Brush, SuperSplat</span>
            </div>
            <div class="alt-comparison-card__examples" style="margin-top: 0.75rem;">
              <span class="alt-comparison-card__examples-label">Libraries:</span>
              <span class="alt-comparison-card__examples-list">
                <a href="https://github.com/nerfstudio-project/gsplat" target="_blank" rel="noopener noreferrer">gsplat</a> - CUDA-accelerated Gaussian Splatting library
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Open Source vs Commercial */}
  <section id="open-source" class="alt-section hash-section">
    <div class="container content-frame px-4 px-md-6 py-16">
      <div class="shell shell--spacious alt-shell--gradient">
        <div class="alt-section__header">
          <p class="kicker">Licensing</p>
          <h2 class="alt-section__title">Open Source vs Commercial</h2>
          <p class="alt-section__desc">Why open source leads in the 3D Gaussian Splatting space.</p>
        </div>

        <div class="alt-oss-advantages">
          <div class="alt-oss-card">
            <div class="alt-oss-card__icon">
              <i class="bi bi-unlock"></i>
            </div>
            <h3 class="alt-oss-card__title">No Lock-in</h3>
            <p class="alt-oss-card__desc">
              Your work is always yours. Export to standard formats and switch tools anytime without losing access to
              your projects.
            </p>
          </div>
          <div class="alt-oss-card">
            <div class="alt-oss-card__icon">
              <i class="bi bi-code-slash"></i>
            </div>
            <h3 class="alt-oss-card__title">Full Transparency</h3>
            <p class="alt-oss-card__desc">
              See exactly how the algorithms work. Modify, extend, or audit the code to match your specific needs and
              security requirements.
            </p>
          </div>
          <div class="alt-oss-card">
            <div class="alt-oss-card__icon">
              <i class="bi bi-people"></i>
            </div>
            <h3 class="alt-oss-card__title">Community Innovation</h3>
            <p class="alt-oss-card__desc">
              Open source projects benefit from contributions worldwide. Bugs get fixed faster, features evolve based on
              real user needs.
            </p>
          </div>
          <div class="alt-oss-card">
            <div class="alt-oss-card__icon">
              <i class="bi bi-infinity"></i>
            </div>
            <h3 class="alt-oss-card__title">Forever Free</h3>
            <p class="alt-oss-card__desc">
              No subscription renewals, no feature tiers, no surprise price increases. Free today, free tomorrow, free
              forever.
            </p>
          </div>
        </div>

        <div class="alt-oss-cta">
          <p class="alt-oss-cta__text">
            <strong>LichtFeld Studio</strong> is proudly open source under GPL-3.0, ensuring these freedoms are
            protected for all users.
          </p>
          <a href={GITHUB_REPO_URL} class="btn btn-primary alt-oss-cta__btn" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-github mr-2"></i>
            View Source on GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Platform Availability */}
  <section id="platforms" class="alt-section hash-section">
    <div class="container content-frame px-4 px-md-6 py-16">
      <div class="shell shell--spacious">
        <div class="alt-section__header">
          <p class="kicker">Compatibility</p>
          <h2 class="alt-section__title">Platform Availability</h2>
          <p class="alt-section__desc">Which tools run on your operating system.</p>
        </div>

        <div class="alt-platforms">
          <div class="alt-platform alt-platform--windows">
            <div class="alt-platform__icon">
              <i class="bi bi-windows"></i>
            </div>
            <h3 class="alt-platform__name">Windows</h3>
