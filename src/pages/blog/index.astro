---
/**
 * Blog index.
 *
 * The newest post always leads as the featured card; earlier posts follow
 * in a card grid. Surfaces reuse the shared shell/kicker/card design tokens.
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import BlogCard from "@/components/BlogCard.astro";
import { resolveBlogImage } from "@/utils/blog";

const base = import.meta.env.BASE_URL;
const cleanBase = base.endsWith("/") ? base.slice(0, -1) : base;

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const [latestPost, ...earlierPosts] = posts;

const dateFormatter = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const seoTitle = "LichtFeld Studio Blog";
const seoDescription =
  "Read LichtFeld Studio release notes, project updates, and technical writeups about 3D Gaussian Splatting workflows, plugins, and the application.";
---

<Layout title={seoTitle} description={seoDescription}>
  <section class="blog-page">
    <div class="container content-frame px-4 py-5">
      <div class="shell blog-hero">
        <div class="blog-hero__copy">
          <p class="kicker">LichtFeld Studio</p>
          <h1 class="blog-hero__title">Blog</h1>
          <p class="blog-hero__lead">
            Release notes, engineering deep dives, and project updates from the LichtFeld Studio project.
          </p>
        </div>

        {
          latestPost && (
            <a href={`${cleanBase}/blog/${latestPost.slug}/`} class="blog-featured">
              <img
                src={resolveBlogImage(base, latestPost.data.image)}
                alt={latestPost.data.imageAlt ?? `${latestPost.data.title} preview`}
                loading="eager"
              />
              <div class="blog-featured__body">
                <p class="blog-featured__meta">
                  <span class="blog-featured__flag">Latest</span>
                  <span>{latestPost.data.category}</span>
                  <time datetime={latestPost.data.date.toISOString()}>{dateFormatter.format(latestPost.data.date)}</time>
                </p>
                <h2 class="blog-featured__title">{latestPost.data.title}</h2>
                <p class="blog-featured__summary">{latestPost.data.summary}</p>
              </div>
            </a>
          )
        }
      </div>

      {
        earlierPosts.length > 0 && (
          <section class="shell mt-4" aria-labelledby="blog-listing-heading">
            <div class="section-head">
              <div>
                <p class="kicker mb-2">Archive</p>
                <h2 id="blog-listing-heading" class="section-title">
                  Earlier posts
                </h2>
              </div>
            </div>

            <div class="blog-grid mt-4">
              {earlierPosts.map((post) => (
                <BlogCard post={post} />
              ))}
            </div>
          </section>
        )
      }
    </div>
  </section>
</Layout>

<style>
  .blog-page {
    background: var(--page-bg);
  }

  .blog-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
    gap: clamp(1.4rem, 3vw, 2.6rem);
    align-items: stretch;
  }

  .blog-hero__copy {
    align-self: center;
  }

  .blog-hero__title {
    margin: 0 0 0.9rem;
    color: var(--color-heading);
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    line-height: 0.96;
  }

  .blog-hero__lead {
    margin: 0;
    max-width: 26rem;
    color: #344054;
    font-size: 1.06rem;
    line-height: 1.76;
  }

  .blog-featured {
    display: grid;
    min-height: 100%;
    overflow: hidden;
    border-radius: 1.2rem;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    color: var(--color-heading);
    text-decoration: none;
    box-shadow: var(--card-shadow);
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .blog-featured:hover {
    transform: translateY(-3px);
    border-color: var(--color-border-hover);
    box-shadow: var(--card-shadow-hover);
  }

  .blog-featured:focus-visible {
    outline: none;
    border-color: var(--color-primary-link);
    box-shadow: var(--focus-shadow);
  }

  .blog-featured img {
    display: block;
    width: 100%;
    aspect-ratio: 2 / 1;
    object-fit: cover;
    background: #101828;
  }

  .blog-featured__body {
    padding: 1.2rem 1.35rem 1.4rem;
  }

  .blog-featured__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.8rem;
    margin: 0 0 0.65rem;
    color: var(--color-muted);
    font-family: var(--font-display);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .blog-featured__flag {
    display: inline-flex;
    align-items: center;
    padding: 0.22rem 0.55rem;
    border-radius: 999px;
    background: rgba(20, 87, 255, 0.09);
    color: var(--color-primary-link);
    box-shadow: inset 0 0 0 1px rgba(20, 87, 255, 0.16);
  }

  .blog-featured__meta time {
    margin-left: auto;
  }

  .blog-featured__title {
    margin: 0 0 0.55rem;
    color: var(--color-heading);
    font-size: 1.55rem;
    line-height: 1.12;
  }

  .blog-featured__summary {
    margin: 0;
    color: var(--color-body);
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 991.98px) {
    .blog-hero {
      grid-template-columns: 1fr;
    }

    .blog-hero__title {
      font-size: clamp(2.35rem, 7vw, 3.05rem);
    }

    .blog-hero__lead {
      max-width: 42rem;
    }

    .blog-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 575.98px) {
    .blog-featured__title {
      font-size: 1.35rem;
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
