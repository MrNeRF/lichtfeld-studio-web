---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const bountySponsors = [
  { name: "Martin Casado", href: "https://x.com/martin_casado", total: 1000 },
  { name: "Nils Pihl", href: "https://x.com/broodsugar", total: 1000 },
  { name: "Janusch Patas", href: "https://x.com/janusch_patas", total: 800 },
  { name: "Vincent Woo", href: "https://vincentwoo.com/", total: 600 },
  { name: "Anton Obukhov", href: "https://github.com/toshas", total: 200 },
  { name: "Chris at KIRI", href: "https://x.com/ChrisAtKIRI", total: 200 },
  { name: "Florian Hahlbohm", href: "https://x.com/fhahlbohm", total: 100 },
  { name: "Mazeyar Moeini", href: "https://x.com/mazy1998", total: 100 },
  { name: "Yehe Liu", href: "https://x.com/YeheLiu", total: 100 },
  {
    name: "Drew Moffitt",
    href: "https://www.linkedin.com/in/drew-moffitt-gisp-0a4522157?utm_source=share&utm_campaign=share_via&utm_content=profile&utm_medium=ios_app",
    total: 100,
  },
  { name: "Julien Blanchon", href: "https://github.com/julien-blanchon", total: 100 },
];

const bounties = (await getCollection("bounty")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const seoTitle = "Bounties";
const seoDescription =
  "Explore LichtFeld Studio bounties, current challenges, and the sponsors funding paid open-source outcomes.";
---

<Layout title={seoTitle} description={seoDescription}>
  <section class="bounty-hub">
    <div class="container content-frame px-4 py-5">
      <div class="shell bounty-hub__hero">
        <p class="kicker">Bounties</p>
        <h1 class="bounty-hub__title">Bounties funded by the LichtFeld Studio community</h1>
        <p class="bounty-hub__lead">
          This page is the starting point for bounty work: who funded payouts, which challenges are open, and which
          bounties already produced results.
        </p>
      </div>

      <section class="shell shell--compact bounty-sponsors-shell" aria-labelledby="bounty-sponsors-heading">
        <div class="bounty-sponsors-intro">
          <p class="kicker">Bounty sponsors</p>
          <h2 id="bounty-sponsors-heading" class="bounty-sponsors-intro__title">
            Bounty sponsors by cumulative payout
          </h2>
          <p class="bounty-sponsors-intro__copy">
            Ordered by cumulative paid bounty funding. Bounties 3 and 4 had no payout.
          </p>
        </div>

        <div class="bounty-sponsor-list" role="list" aria-label="Bounty sponsors ordered by cumulative contribution">
          {
            bountySponsors.map((sponsor, index) => (
              <a
                href={sponsor.href}
                target="_blank"
                rel="noopener noreferrer"
                class="bounty-sponsor-list__item"
                role="listitem"
                aria-label={`Open ${sponsor.name}`}
              >
                <span class="bounty-sponsor-list__rank">{index + 1}</span>
                <span class="bounty-sponsor-list__name">{sponsor.name}</span>
                <span class="bounty-sponsor-list__total">${sponsor.total.toLocaleString()}</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="shell shell--compact bounty-listing" aria-labelledby="bounty-listing-heading">
        <div class="bounty-listing__intro">
          <p class="kicker">All bounties</p>
          <h2 id="bounty-listing-heading" class="bounty-listing__title">Browse current and past challenges</h2>
        </div>

        <div class="bounty-listing__grid">
          {
            bounties.map((bounty) => (
              <a href={`/bounty/${bounty.slug}`} class="bounty-entry">
                <div class="bounty-entry__meta">
                  <span>{bounty.data.date.toLocaleDateString()}</span>
                  <span>{bounty.data.deadline?.toLocaleDateString() ?? "Open deadline"}</span>
                </div>
                <h3 class="bounty-entry__title">{bounty.data.title}</h3>
                <p class="bounty-entry__summary">{bounty.data.summary}</p>
                {bounty.data.winner && <p class="bounty-entry__winner">{bounty.data.winner}</p>}
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </section>
</Layout>

<style>
  .bounty-hub {
    background: var(--page-bg);
  }

  .bounty-hub__hero {
    max-width: 54rem;
    margin-bottom: 1.25rem;
  }

  .bounty-hub__title {
    margin: 0 0 0.75rem;
    color: var(--color-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.08;
  }

  .bounty-hub__lead {
    margin: 0;
    color: var(--color-body);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .bounty-listing {
    margin-top: 1rem;
  }

  .bounty-sponsors-intro,
  .bounty-listing__intro {
    margin-bottom: 0.7rem;
  }

  .bounty-sponsors-intro__title,
  .bounty-listing__title {
    margin: 0 0 0.25rem;
    color: var(--color-heading);
    font-size: 1.6rem;
    line-height: 1.15;
  }

  .bounty-sponsors-intro__copy {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .bounty-sponsor-list {
    display: grid;
    gap: 0.35rem;
  }

  .bounty-sponsor-list__item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.55rem;
    align-items: center;
    padding: 0.42rem 0.65rem;
    border-radius: 0.7rem;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--card-border);
    color: inherit;
    text-decoration: none;
    box-shadow: var(--card-shadow);
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .bounty-sponsor-list__item:hover,
  .bounty-entry:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-hover);
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.04);
  }

  .bounty-sponsor-list__item:focus-visible,
  .bounty-entry:focus-visible {
    outline: none;
    transform: translateY(-2px);
    border-color: var(--color-primary-link);
    box-shadow:
      var(--focus-shadow),
      0 8px 18px rgba(15, 23, 42, 0.04);
  }

  .bounty-sponsor-list__rank {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.1);
    color: #2563eb;
    font-size: 0.7rem;
    font-weight: 800;
  }

  .bounty-sponsor-list__name {
    color: var(--color-heading);
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .bounty-sponsor-list__total {
    color: #334155;
    font-size: 0.84rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .bounty-listing__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .bounty-entry {
    display: grid;
    gap: 0.55rem;
    padding: 1rem;
    border-radius: var(--card-radius);
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--card-border);
    color: inherit;
    text-decoration: none;
    box-shadow: var(--card-shadow);
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .bounty-entry__meta {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    color: var(--color-muted);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .bounty-entry__title {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.1rem;
    line-height: 1.25;
  }

  .bounty-entry__summary {
    margin: 0;
    color: var(--color-body);
    line-height: 1.55;
  }

  .bounty-entry__winner {
    margin: 0;
    color: var(--color-primary-link);
    font-size: 0.9rem;
    font-weight: 700;
  }

  @media (max-width: 991.98px) {
    .bounty-listing__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 575.98px) {
    .bounty-sponsor-list__item {
      grid-template-columns: 1fr;
      gap: 0.35rem;
      align-items: flex-start;
    }

    .bounty-sponsor-list__total {
      white-space: normal;
    }

    .bounty-entry__meta {
      flex-direction: column;
      gap: 0.2rem;
    }
  }
</style>
