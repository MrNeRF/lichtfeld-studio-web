---
/**
 * The main "Contribute" page for the website.
 * This page shows contribution paths, funding options, and a contributor face wall.
 */
import Layout from "@/layouts/Layout.astro";
import ContributorsWall from "@/components/contribute/ContributorsWall.astro";
import SupportProjectBox from "@/components/contribute/SupportProjectBox.astro";
import { GITHUB_REPO_URL } from "@/constants/project";

const base = import.meta.env.BASE_URL;
const contributionLanes = [
  {
    title: "Write code",
    copy: "Implement features, fix bugs, and improve core platform behavior.",
    href: GITHUB_REPO_URL,
    external: true,
  },
  {
    title: "Docs",
    copy: "Improve guides, API notes, setup instructions, and workflow examples.",
    href: `${base}docs/`,
  },
  {
    title: "Report bugs",
    copy: "Open reproducible issues with logs, steps, versions, and screenshots.",
    href: `${GITHUB_REPO_URL}/issues`,
    external: true,
  },
  {
    title: "Training data",
    copy: "Share datasets that help test reconstruction, training quality, and edge cases.",
  },
  {
    title: "Gallery splats",
    copy: "Submit high-quality splats that can be featured in the public gallery.",
    href: `${base}showcase/`,
  },
  {
    title: "Funding",
    copy: "Back development through donations or annual sponsoring.",
    href: "#support-the-project",
  },
];

const sponsoringTiers = [
  {
    name: "Platinum",
    amount: "$50,000+",
    description: "Foundational-level sponsorship for major long-term platform support.",
    benefits: [
      "For the remainder of 2026, every Platinum sponsor is acknowledged as a Foundational Sponsor.",
      "Foundational logo placement persists on the homepage even if the sponsorship later ends.",
      "Regular sync calls are included.",
      "Includes all Gold, Silver, and Bronze benefits.",
    ],
    tone: "platinum",
  },
  {
    name: "Gold",
    amount: "$15,000 - $49,999",
    description: "Major annual backing for sustained product, tooling, and platform work.",
    benefits: [
      "Social media coverage for the sponsorship.",
      "Logo placement on the LichtFeld Studio startup overlay.",
      "Mention on the repository and homepage social preview cards.",
      "Includes all Silver and Bronze benefits.",
    ],
    tone: "gold",
  },
  {
    name: "Silver",
    amount: "$5,000 - $14,999",
    description: "Meaningful backing that helps accelerate engineering and research.",
    benefits: [
      "Logo placement near the top of the homepage sponsor wall.",
      "Logo placement in the repository sponsor acknowledgements.",
      "Includes all Bronze benefits.",
    ],
    tone: "silver",
  },
  {
    name: "Bronze",
    amount: "$500 - $4,999",
    description: "Supportive annual backing for companies investing in the project and community.",
    benefits: [
      "Name with link on the homepage sponsor wall.",
      "Access to all builds released during the sponsorship year.",
    ],
    tone: "bronze",
  },
];

// SEO metadata for the contribute page
const seoTitle = "Contribute";
const seoDescription =
  "Join LichtFeld Studio development. Browse the live GitHub Projects backlog, pick up open issues, support the project, and meet the contributors shipping the platform.";
---

<Layout title={seoTitle} description={seoDescription}>
  <section class="contribute-page">
    <div class="container content-frame px-4 py-5">
      <div class="contribute-top-grid">
        <div class="shell contribute-shell--hero">
          <div class="contribute-hero__copy">
            <p class="kicker">Contribute</p>
            <h1 class="contribute-title">Build features, fix problems, and support the project</h1>
            <p class="contribute-lead mb-0">
              Write code, improve docs, report bugs, share training data, submit gallery-ready splats, or fund the
              work.
            </p>
          </div>

          <div class="contribute-hero__lanes" aria-label="Contribution paths">
            {
              contributionLanes.map((lane) =>
                lane.href ? (
                  <a
                    href={lane.href}
                    target={lane.external ? "_blank" : undefined}
                    rel={lane.external ? "noopener noreferrer" : undefined}
                    class="contribute-hero__lane"
                  >
                    <strong>{lane.title}</strong>
                    <span>{lane.copy}</span>
                  </a>
                ) : (
                  <div class="contribute-hero__lane">
                    <strong>{lane.title}</strong>
                    <span>{lane.copy}</span>
                  </div>
                ),
              )
            }
          </div>
        </div>
      </div>

      <section
        id="support-the-project"
        class="contribute-support-panel mt-4"
        aria-labelledby="support-the-project-heading"
      >
        <SupportProjectBox />
      </section>

      <section id="sponsoring" class="shell contribute-sponsoring mt-4" aria-labelledby="sponsoring-heading">
        <div class="sponsoring-intro">
          <p class="kicker mb-3">Sponsoring</p>
          <div class="section-heading">
            <h2 id="sponsoring-heading" class="sponsoring-title">Sponsoring LichtFeld Studio</h2>
            <a class="section-anchor" href="#sponsoring" aria-label="Link to sponsoring section">
              <svg class="bi" width="1em" height="1em" aria-hidden="true">
                <use href={`${base}static/bootstrap-icons.svg#link-45deg`}></use>
              </svg>
            </a>
          </div>
          <p class="sponsoring-copy">
            Sponsoring tiers reflect the current annual support program behind long-term platform work.
          </p>
        </div>

        <article class="foundational-sponsoring-card">
          <p class="foundational-sponsoring-card__label">Foundational</p>
          <h3 class="foundational-sponsoring-card__title">Recognized for helping kickstart the platform</h3>
          <p class="foundational-sponsoring-card__desc">
            Reserved for early platform-level backing and long-term project support.
          </p>
        </article>

        <div class="sponsoring-tier-grid">
          {
            sponsoringTiers.map((tier) => (
              <article class={`sponsoring-tier-card sponsoring-tier-card--${tier.tone}`}>
                <div class="sponsoring-tier-card__header">
                  <p class="sponsoring-tier-card__name">{tier.name}</p>
                </div>
                <p class="sponsoring-tier-card__amount">
                  {tier.amount}
                  <span class="sponsoring-tier-card__amount-note">per year</span>
                </p>
                <p class="sponsoring-tier-card__desc">{tier.description}</p>
                <ul class="sponsoring-tier-card__benefits">
                  {tier.benefits.map((benefit) => <li>{benefit}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>
    </div>

    <section class="contribute-contributors">
      <ContributorsWall />
    </section>
  </section>
</Layout>

<style>
  .contribute-page {
    background: var(--page-bg);
  }

  .contribute-top-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }

  .contribute-shell--hero {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(420px, 1fr);
    gap: clamp(2rem, 5vw, 4.25rem);
    align-items: end;
    min-width: 0;
    min-height: 100%;
    padding: clamp(2rem, 4vw, 3.5rem);
  }

  .contribute-hero__copy {
    min-width: 0;
    max-width: 46rem;
  }

  .contribute-title {
    margin: 0 0 0.9rem;
    color: var(--color-heading);
    font-size: clamp(2.7rem, 5vw, 4.2rem);
    line-height: 0.98;
    max-width: 15ch;
    overflow-wrap: break-word;
    text-wrap: balance;
  }

  .contribute-lead {
    color: #344054;
    font-size: 1.06rem;
    line-height: 1.76;
    min-width: 0;
    max-width: 42rem;
    overflow-wrap: break-word;
  }

  .contribute-hero__lanes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    min-width: 0;
    margin-top: 0;
  }

  .contribute-hero__lane {
    min-width: 0;
    padding: 1rem 1.1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.62);
    border: 1px solid rgba(15, 23, 42, 0.08);
    box-shadow: 0 10px 18px rgba(15, 23, 42, 0.03);
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      background-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  a.contribute-hero__lane:hover {
    transform: translateY(-2px);
    border-color: rgba(20, 87, 255, 0.18);
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 16px 26px rgba(15, 23, 42, 0.06);
  }

  a.contribute-hero__lane:focus-visible {
    outline: none;
    transform: translateY(-2px);
    box-shadow: var(--focus-shadow), 0 16px 26px rgba(15, 23, 42, 0.06);
  }

  .contribute-hero__lane strong {
    display: block;
    color: var(--color-heading);
    font-size: 0.98rem;
    line-height: 1.2;
  }

  .contribute-hero__lane span {
    display: block;
    margin-top: 0.35rem;
    color: var(--color-muted);
    font-size: 0.88rem;
    line-height: 1.5;
    overflow-wrap: break-word;
  }

  .contribute-support-panel {
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }

  .contribute-sponsoring {
    display: grid;
    gap: 1rem;
  }

  .section-heading {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    max-width: fit-content;
  }

  .section-heading > :first-child {
    min-width: 0;
    flex: 1 1 auto;
  }

  .section-anchor {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 2rem;
    height: 2rem;
    margin-top: 0.15rem;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.18);
    background: rgba(255, 255, 255, 0.72);
    color: #64748b;
    text-decoration: none;
    box-shadow: 0 10px 18px rgba(15, 23, 42, 0.04);
    transition:
      transform 0.18s ease,
      color 0.18s ease,
      background-color 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .section-anchor:hover {
    transform: translateY(-1px);
    color: var(--color-primary-link);
    background: rgba(255, 255, 255, 0.96);
    border-color: rgba(37, 99, 235, 0.24);
    box-shadow: 0 14px 24px rgba(15, 23, 42, 0.07);
  }

  .section-anchor:focus-visible {
    outline: none;
    transform: translateY(-1px);
    color: var(--color-primary-link);
    background: rgba(255, 255, 255, 0.96);
    border-color: var(--color-primary-link);
    box-shadow: var(--focus-shadow);
  }

  .bi {
    vertical-align: -0.125em;
  }

  .sponsoring-intro {
    max-width: 56rem;
    margin-bottom: 0.75rem;
  }

  .sponsoring-title {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(2rem, 4vw, 2.9rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
  }

  .sponsoring-copy {
    margin: 1rem 0 0;
    color: var(--color-body);
    font-size: 1.04rem;
    line-height: 1.72;
    max-width: 44rem;
  }

  .foundational-sponsoring-card {
    display: grid;
    gap: 0.65rem;
    padding: 1.45rem;
    border-radius: 1.35rem;
    background:
      radial-gradient(circle at top right, rgba(201, 114, 52, 0.12), transparent 30%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(255, 251, 245, 0.92));
    border: 1px solid rgba(194, 89, 37, 0.12);
    box-shadow: 0 18px 30px rgba(15, 23, 42, 0.05);
  }

  .foundational-sponsoring-card__label {
    margin: 0;
    color: #b45309;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .foundational-sponsoring-card__title {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(1.35rem, 2.2vw, 1.75rem);
    line-height: 1.12;
  }

  .foundational-sponsoring-card__desc {
    margin: 0;
    color: var(--color-body);
    line-height: 1.65;
  }

  .sponsoring-tier-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .sponsoring-tier-card {
    --tier-rgb: 148, 163, 184;
    --tier-chip-bg: rgba(var(--tier-rgb), 0.1);
    --tier-chip-color: rgb(var(--tier-rgb));
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-height: 100%;
    padding: 1.45rem;
    border-radius: 1.35rem;
    background:
      radial-gradient(circle at top right, rgba(var(--tier-rgb), 0.14), transparent 40%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(252, 252, 253, 0.88));
    border: 1px solid rgba(var(--tier-rgb), 0.2);
    box-shadow: 0 16px 28px rgba(15, 23, 42, 0.05);
    overflow: hidden;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .sponsoring-tier-card::before {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: calc(1.35rem - 1px);
    border: 1px solid rgba(255, 255, 255, 0.52);
    pointer-events: none;
  }

  .sponsoring-tier-card::after {
    content: "";
    position: absolute;
    top: -3.5rem;
    right: -2.5rem;
    width: 10rem;
    height: 10rem;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(var(--tier-rgb), 0.22), transparent 72%);
    filter: blur(12px);
    pointer-events: none;
    opacity: 0.9;
  }

  .sponsoring-tier-card:hover {
    transform: translateY(-2px);
    border-color: rgba(var(--tier-rgb), 0.28);
    box-shadow: 0 20px 34px rgba(15, 23, 42, 0.07);
  }

  .sponsoring-tier-card > * {
    position: relative;
    z-index: 1;
  }

  .sponsoring-tier-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .sponsoring-tier-card__name {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    margin: 0;
    padding: 0.42rem 0.78rem;
    border-radius: 999px;
    background: var(--tier-chip-bg);
    color: var(--tier-chip-color);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .sponsoring-tier-card__amount {
    margin: 0;
    color: var(--color-heading);
    font-size: clamp(1.45rem, 2.2vw, 1.8rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .sponsoring-tier-card__amount-note {
    display: block;
    margin-top: 0.28rem;
    color: rgba(71, 85, 105, 0.82);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .sponsoring-tier-card__desc {
    margin: 0;
    color: #526073;
    line-height: 1.7;
  }

  .sponsoring-tier-card__benefits {
    display: grid;
    gap: 0.55rem;
    margin: 0.15rem 0 0;
    padding: 0.95rem 0 0;
    border-top: 1px solid rgba(var(--tier-rgb), 0.14);
    list-style: none;
    color: #334155;
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .sponsoring-tier-card__benefits li {
    display: grid;
    grid-template-columns: 0.45rem minmax(0, 1fr);
    gap: 0.6rem;
    align-items: start;
  }

  .sponsoring-tier-card__benefits li::before {
    content: "";
    width: 0.38rem;
    height: 0.38rem;
    margin-top: 0.56em;
    border-radius: 999px;
    background: rgb(var(--tier-rgb));
    box-shadow: 0 0 0 0.18rem rgba(var(--tier-rgb), 0.1);
  }

  .sponsoring-tier-card--platinum {
    --tier-rgb: 71, 85, 105;
    --tier-chip-bg: linear-gradient(180deg, rgba(71, 85, 105, 0.12), rgba(226, 232, 240, 0.55));
    --tier-chip-color: #475569;
    background:
      radial-gradient(circle at top right, rgba(203, 213, 225, 0.7), transparent 42%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(241, 245, 249, 0.92));
  }

  .sponsoring-tier-card--gold {
    --tier-rgb: 245, 158, 11;
    background:
      radial-gradient(circle at top right, rgba(253, 230, 138, 0.42), transparent 38%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(255, 251, 235, 0.92));
  }

  .sponsoring-tier-card--silver {
    --tier-rgb: 148, 163, 184;
    --tier-chip-bg: linear-gradient(180deg, rgba(226, 232, 240, 0.72), rgba(248, 250, 252, 0.96));
    --tier-chip-color: #64748b;
    background:
      radial-gradient(circle at top right, rgba(226, 232, 240, 0.44), transparent 40%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.95));
  }

  .sponsoring-tier-card--bronze {
    --tier-rgb: 192, 132, 87;
    background:
      radial-gradient(circle at top right, rgba(234, 211, 194, 0.4), transparent 38%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(252, 246, 241, 0.92));
  }

  .contribute-contributors {
    margin-top: 1.5rem;
  }

  @media (max-width: 991.98px) {
    .contribute-shell--hero {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .contribute-title {
      max-width: 14ch;
    }

    .contribute-hero__lanes {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767.98px) {
    .contribute-shell--hero {
      padding: 1.25rem;
    }

    .contribute-title {
      max-width: 11ch;
      font-size: clamp(2.35rem, 11vw, 3rem);
      line-height: 1;
    }

    .contribute-lead {
      font-size: 0.98rem;
      line-height: 1.65;
    }

    .contribute-hero__lanes,
    .sponsoring-tier-grid {
      grid-template-columns: 1fr;
    }

    .section-heading {
      width: 100%;
      max-width: 100%;
    }

    .sponsoring-title {
      font-size: clamp(1.8rem, 8.8vw, 2.45rem);
      line-height: 1.02;
      text-wrap: balance;
    }

    .sponsoring-copy,
    .foundational-sponsoring-card__desc,
    .sponsoring-tier-card__desc,
    .sponsoring-tier-card__benefits {
      font-size: 0.94rem;
      line-height: 1.56;
    }
  }

  @media (max-width: 575.98px) {
    .contribute-shell--hero {
      width: min(100%, 21rem);
      margin-inline: 0 auto;
    }

    .contribute-title {
      max-width: 10.5ch;
      font-size: clamp(2.1rem, 10.5vw, 2.75rem);
    }
  }
</style>
