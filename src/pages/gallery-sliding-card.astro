---
/**
 * Prototype gallery variant with a bottom sliding scene tray.
 *
 * This page intentionally lives beside the main showcase page so the team can
 * evaluate the interaction without replacing the current gallery.
 *
 * @module pages/gallery-sliding-card
 */
import Layout from "@/layouts/Layout.astro";
import Splat from "@/components/Splat.astro";
import SceneCard from "@/components/showcase/SceneCard.astro";
import { SHOWCASE_SCENES, DEFAULT_SCENE_ID } from "@/constants/scenes";
import { renderSceneAttributionHtml } from "@/script/showcase/runtime/renderSceneAttributionHtml";
import { renderSceneDescriptionHtml } from "@/script/showcase/runtime/renderSceneDescriptionHtml";

const base = import.meta.env.BASE_URL;
const seoTitle = "Gallery Sliding Card Prototype | LichtFeld Studio";
const seoDescription = "Prototype gallery layout with a full-bleed viewer and a sliding More Scenes tray.";

const defaultScene = SHOWCASE_SCENES.find((scene) => scene.id === DEFAULT_SCENE_ID) ?? SHOWCASE_SCENES[0];
const defaultPreviewSrc = defaultScene.previewImage
  ? `${base}static/${defaultScene.folderName}/${defaultScene.previewImage}`
  : `${base}static/${defaultScene.folderName}/preview.webp`;
const defaultControlHints = getControlHints(defaultScene.controlScheme ?? "both");

const sceneDataMap = Object.fromEntries(
  SHOWCASE_SCENES.map((scene) => [
    scene.id,
    {
      folder: scene.folderName,
      name: scene.name,
      descriptionHtml: renderSceneDescriptionHtml(scene.description),
      attributionHtml: renderSceneAttributionHtml(scene.credits),
      controlScheme: scene.controlScheme ?? "both",
      idleAnimation: scene.idleAnimation ?? "none",
      assetFile: scene.assetFile,
      documentFile: scene.documentFile,
      skyboxImage: scene.skyboxImage,
      previewSrc: scene.previewImage
        ? `${base}static/${scene.folderName}/${scene.previewImage}`
        : `${base}static/${scene.folderName}/preview.webp`,
    },
  ]),
);

function getControlHints(scheme: string): string {
  switch (scheme) {
    case "orbit":
      return "Left-drag: Orbit • Scroll: Zoom";
    case "fly":
      return "WASD: Move • Right-drag: Look";
    case "both":
    default:
      return "Left-drag: Orbit • WASD: Move • Scroll: Zoom";
  }
}
---

<Layout title={seoTitle} description={seoDescription} hideFooter={true} noindex={true}>
  <div class="gallery-sliding-card">
    <section class="gallery-sliding-card__viewer-shell showcase-player" id="player-container">
      <div class="gallery-sliding-card__viewer showcase-player__container">
        <div class="showcase-player__native-viewer" id="gallery-sliding-card-viewer">
          <Splat
            scene={defaultScene.folderName}
            previewSrc={defaultPreviewSrc}
            assetFile={defaultScene.assetFile}
            documentFile={defaultScene.documentFile}
            skyboxImage={defaultScene.skyboxImage}
            controlScheme={defaultScene.controlScheme ?? "both"}
            idleAnimation={defaultScene.idleAnimation ?? "none"}
            progressPosition="center"
            enablePoseCycling={false}
          />

          <aside class="gallery-sliding-card__overlay">
            <span class="gallery-sliding-card__overlay-eyebrow">Interactive Scene</span>
            <h1 class="gallery-sliding-card__overlay-title" id="gallery-sliding-card-title">{defaultScene.name}</h1>
            {
              renderSceneAttributionHtml(defaultScene.credits) && (
                <div
                  class="gallery-sliding-card__overlay-meta"
                  id="gallery-sliding-card-meta"
                  set:html={`Source: ${renderSceneAttributionHtml(defaultScene.credits)}`}
                />
              )
            }
            <div
              class="gallery-sliding-card__overlay-description"
              id="gallery-sliding-card-description"
              set:html={renderSceneDescriptionHtml(defaultScene.description)}
            />
          </aside>
        </div>

        <div class="showcase-player__help" id="help-panel" aria-hidden="true">
          <div class="showcase-player__help-content">
            <h3 class="showcase-player__help-title">Camera Controls</h3>
            <div class="showcase-player__help-grid">
              <div class="showcase-player__help-item">
                <span class="showcase-player__help-key">Left Click + Drag</span>
                <span class="showcase-player__help-desc">Orbit around scene</span>
              </div>
              <div class="showcase-player__help-item">
                <span class="showcase-player__help-key">Right Click + Drag</span>
                <span class="showcase-player__help-desc">Look around</span>
              </div>
              <div class="showcase-player__help-item">
                <span class="showcase-player__help-key">Scroll Wheel</span>
                <span class="showcase-player__help-desc">Zoom in/out</span>
              </div>
              <div class="showcase-player__help-item">
                <span class="showcase-player__help-key">WASD / Arrows</span>
                <span class="showcase-player__help-desc">Move camera</span>
              </div>
            </div>
            <button type="button" class="showcase-player__help-close" id="help-close">Got it</button>
          </div>
        </div>
      </div>

      <div class="showcase-player__bar">
        <div class="showcase-player__hints" id="control-hints">
          {defaultControlHints}
        </div>

        <div class="showcase-player__buttons">
          <button
            type="button"
            class="showcase-player__btn showcase-player__btn--help"
            id="help-toggle"
            aria-label="Show camera controls"
            aria-expanded="false"
            aria-controls="help-panel"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          </button>

          <button type="button" class="showcase-player__btn" id="fullscreen-toggle" aria-label="Toggle fullscreen">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              id="fullscreen-icon"
            >
              <polyline points="15 3 21 3 21 9"></polyline>
              <polyline points="9 21 3 21 3 15"></polyline>
              <line x1="21" y1="3" x2="14" y2="10"></line>
              <line x1="3" y1="21" x2="10" y2="14"></line>
            </svg>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              id="exit-fullscreen-icon"
              style="display: none;"
            >
              <polyline points="4 14 10 14 10 20"></polyline>
              <polyline points="20 10 14 10 14 4"></polyline>
              <line x1="14" y1="10" x2="21" y2="3"></line>
              <line x1="3" y1="21" x2="10" y2="14"></line>
            </svg>
          </button>
        </div>
      </div>
    </section>

    <div class="gallery-sliding-card__bottom-gap" aria-hidden="true"></div>

    <div class="showcase-content gallery-sliding-card__mobile-content">
      <section class="showcase-title">
        <span class="showcase-title__eyebrow">Interactive Scene</span>
        <h1 id="gallery-sliding-card-inline-title">{defaultScene.name}</h1>
      </section>

      <section class="showcase-description">
        <div class="showcase-description__header">
          <div class="showcase-description__intro">
            <div class="showcase-description__meta" id="gallery-sliding-card-inline-meta">
              {
                renderSceneAttributionHtml(defaultScene.credits) && (
                  <span
                    class="showcase-description__attribution"
                    set:html={`Source: ${renderSceneAttributionHtml(defaultScene.credits)}`}
                  />
                )
              }
            </div>
          </div>

          <button type="button" class="showcase-description__share" id="share-btn" aria-label="Share scene">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="18" cy="5" r="3"></circle>
              <circle cx="6" cy="12" r="3"></circle>
              <circle cx="18" cy="19" r="3"></circle>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
            </svg>
            <span>Share</span>
          </button>
        </div>
        <div
          class="showcase-description__text"
          id="gallery-sliding-card-inline-description"
          set:html={renderSceneDescriptionHtml(defaultScene.description)}
        />
      </section>

      <section class="gallery-sliding-card__mobile-gallery showcase-gallery">
        <h2 class="showcase-gallery__title">More Scenes</h2>
        <div class="showcase-gallery__grid" role="list" aria-label="Available scenes">
          {
            SHOWCASE_SCENES.map((scene) => (
              <div class="showcase-gallery__item" role="listitem" data-scene-wrapper={scene.id}>
                <SceneCard scene={scene} isSelected={scene.id === DEFAULT_SCENE_ID} basePath={base} />
              </div>
            ))
          }
        </div>
      </section>
    </div>

    <section
      class="gallery-sliding-card__tray showcase-gallery"
      id="gallery-sliding-card-tray"
      data-tray-state="peek"
      aria-label="More scenes tray"
    >
      <div class="gallery-sliding-card__tray-handle" aria-hidden="true"></div>

      <div class="gallery-sliding-card__tray-header">
        <h2 class="gallery-sliding-card__section-title showcase-gallery__title">More Scenes</h2>
      </div>

      <div class="gallery-sliding-card__tray-scroll" id="gallery-sliding-card-tray-scroll">
        <div class="gallery-sliding-card__grid showcase-gallery__grid" role="list" aria-label="Available scenes">
          {
            SHOWCASE_SCENES.map((scene) => (
              <div class="gallery-sliding-card__item showcase-gallery__item" role="listitem" data-scene-wrapper={scene.id}>
                <SceneCard scene={scene} isSelected={scene.id === DEFAULT_SCENE_ID} basePath={base} />
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <div class="showcase-toast" id="share-toast" aria-live="polite" aria-hidden="true">Link copied to clipboard!</div>
  </div>
</Layout>

<script define:vars={{ defaultSceneId: DEFAULT_SCENE_ID, sceneDataMap }}>
  (() => {
    const playerContainer = document.getElementById("player-container");
    const tray = document.getElementById("gallery-sliding-card-tray");
    const trayScroll = document.getElementById("gallery-sliding-card-tray-scroll");
    const viewerSurface = document.getElementById("gallery-sliding-card-viewer");
    const helpToggle = document.getElementById("help-toggle");
    const helpClose = document.getElementById("help-close");
    const helpPanel = document.getElementById("help-panel");
    const fullscreenToggle = document.getElementById("fullscreen-toggle");
    const fullscreenIcon = document.getElementById("fullscreen-icon");
    const exitFullscreenIcon = document.getElementById("exit-fullscreen-icon");
    const shareBtn = document.getElementById("share-btn");
    const shareToast = document.getElementById("share-toast");
    const controlHints = document.getElementById("control-hints");
    const sceneTitle = document.getElementById("gallery-sliding-card-title");
    const overlayMeta = document.getElementById("gallery-sliding-card-meta");
    const sceneDescription = document.getElementById("gallery-sliding-card-description");
    const inlineTitle = document.getElementById("gallery-sliding-card-inline-title");
    const inlineDescription = document.getElementById("gallery-sliding-card-inline-description");
    const inlineMeta = document.getElementById("gallery-sliding-card-inline-meta");
    const sceneCards = Array.from(document.querySelectorAll(".scene-card"));
    const finePointer = window.matchMedia("(hover: hover) and (pointer: fine)");
    const interactiveTrayMedia = window.matchMedia("(min-width: 1200px)");
    const header = document.querySelector(".site-header");

    if (!tray || !trayScroll || !viewerSurface || sceneCards.length === 0) {
      return;
    }

    let selectedSceneId = defaultSceneId;
    let currentTrayOffset = 0;
    let maxTrayOffset = 0;
    let isHelpOpen = false;
    const trayPeekOffset = 0;
    let trayHoverOffset = 0;

    function getControlHints(scheme) {
      switch (scheme) {
        case "orbit":
          return "Left-drag: Orbit • Scroll: Zoom";
        case "fly":
          return "WASD: Move • Right-drag: Look";
        case "both":
        default:
          return "Left-drag: Orbit • WASD: Move • Scroll: Zoom";
      }
    }

    function openHelp() {
      if (!helpPanel || !helpToggle) {
        return;
      }

      isHelpOpen = true;
      helpPanel.classList.add("is-open");
      helpPanel.setAttribute("aria-hidden", "false");
      helpToggle.setAttribute("aria-expanded", "true");
    }

    function closeHelp() {
      if (!helpPanel || !helpToggle) {
        return;
      }

      isHelpOpen = false;
      helpPanel.classList.remove("is-open");
      helpPanel.setAttribute("aria-hidden", "true");
      helpToggle.setAttribute("aria-expanded", "false");
    }

    function updateFullscreenIcon() {
      const isFullscreen = !!document.fullscreenElement;

      if (fullscreenIcon && exitFullscreenIcon) {
        fullscreenIcon.style.display = isFullscreen ? "none" : "block";
        exitFullscreenIcon.style.display = isFullscreen ? "block" : "none";
      }
    }

    function toggleFullscreen() {
      if (!playerContainer) {
        return;
      }

      if (document.fullscreenElement) {
        document.exitFullscreen();
      } else {
        playerContainer.requestFullscreen();
      }
    }

    function showToast() {
      if (!shareToast) {
        return;
      }

      shareToast.classList.add("is-visible");
      shareToast.setAttribute("aria-hidden", "false");
      window.setTimeout(() => {
        shareToast.classList.remove("is-visible");
        shareToast.setAttribute("aria-hidden", "true");
      }, 2000);
    }

    function shareScene() {
      const url = new URL(window.location.href);

      url.searchParams.set("scene", selectedSceneId);
      navigator.clipboard.writeText(url.toString()).then(() => {
        showToast();
      });
    }

    function updateSelection(newSelectedId) {
      sceneCards.forEach((card) => {
        const sceneId = card.dataset.sceneId;
        const isSelected = sceneId === newSelectedId;

        card.classList.toggle("scene-card--selected", isSelected);
        card.setAttribute("aria-pressed", String(isSelected));
      });
    }

    function resolveSceneIdFromUrl() {
      const url = new URL(window.location.href);
      const requestedSceneId = url.searchParams.get("scene");

      if (requestedSceneId && sceneDataMap[requestedSceneId]) {
        return requestedSceneId;
      }

      return defaultSceneId;
    }

    function updateSceneMeta(sceneId) {
      const sceneData = sceneDataMap[sceneId];

      if (!sceneData) {
        return;
      }

      if (sceneTitle) {
        sceneTitle.textContent = sceneData.name;
      }

      if (overlayMeta) {
        overlayMeta.innerHTML = sceneData.attributionHtml ? `Source: ${sceneData.attributionHtml}` : "";
      }

      if (sceneDescription) {
        sceneDescription.innerHTML = sceneData.descriptionHtml;
      }

      if (inlineTitle) {
        inlineTitle.textContent = sceneData.name;
      }

      if (inlineDescription) {
        inlineDescription.innerHTML = sceneData.descriptionHtml;
      }

      if (inlineMeta) {
        inlineMeta.innerHTML = sceneData.attributionHtml
          ? `<span class="showcase-description__attribution">Source: ${sceneData.attributionHtml}</span>`
          : "";
      }

      if (controlHints) {
        controlHints.textContent = getControlHints(sceneData.controlScheme);
      }
    }

    function loadScene(sceneId, options = { updateHistory: true }) {
      const splatViewer = document.querySelector("astro-splat");
      const sceneData = sceneDataMap[sceneId];

      if (!sceneData) {
        return;
      }

      updateSceneMeta(sceneId);

      if (splatViewer) {
        const event = new CustomEvent("splatviewer:load-scene", {
          detail: {
            scene: sceneData.folder,
            controlScheme: sceneData.controlScheme,
            assetFile: sceneData.assetFile,
            documentFile: sceneData.documentFile,
            skyboxImage: sceneData.skyboxImage,
            previewSrc: sceneData.previewSrc,
          },
          bubbles: true,
        });

        splatViewer.dispatchEvent(event);
      }

      if (options.updateHistory) {
        const url = new URL(window.location.href);

        url.searchParams.set("scene", sceneId);
        window.history.replaceState({}, "", url.toString());
      }
    }

    function updateTrayMeasurements() {
      if (!interactiveTrayMedia.matches) {
        maxTrayOffset = 0;
        trayHoverOffset = 0;
        currentTrayOffset = 0;
        tray.style.setProperty("--gallery-sliding-card-offset", "0px");
        tray.dataset.trayState = "peek";
        trayScroll.scrollTop = 0;
        viewerSurface.style.setProperty("--gallery-sliding-card-blur", "0px");

        return;
      }

      const availableHeight = tray.parentElement?.clientHeight ?? window.innerHeight;
      const trayTopInset = 12;
      const peekHeight = 104;
      const maxVisibleHeight = Math.max(peekHeight, availableHeight - trayTopInset);

      maxTrayOffset = Math.max(0, Math.min(tray.offsetHeight, maxVisibleHeight) - peekHeight);
      trayHoverOffset = Math.min(maxTrayOffset, 220);
      currentTrayOffset = Math.min(currentTrayOffset, maxTrayOffset);

      tray.style.setProperty("--gallery-sliding-card-offset", `${currentTrayOffset}px`);
    }

    function applyTrayState(nextState, nextOffset) {
      currentTrayOffset = Math.max(trayPeekOffset, Math.min(maxTrayOffset, nextOffset));
      tray.style.setProperty("--gallery-sliding-card-offset", `${currentTrayOffset}px`);

      const blurProgress = maxTrayOffset > 0 ? currentTrayOffset / maxTrayOffset : 0;
      const nextBlur = Number((blurProgress * 10).toFixed(2));

      tray.dataset.trayState = nextState;
      viewerSurface.style.setProperty("--gallery-sliding-card-blur", `${nextBlur}px`);
    }

    function syncTrayStateFromOffset() {
      let nextState = "peek";

      if (currentTrayOffset >= maxTrayOffset - 2) {
        nextState = "expanded";
      } else if (currentTrayOffset > trayPeekOffset) {
        nextState = "preview";
      }

      applyTrayState(nextState, currentTrayOffset);
    }

    function expandTrayBy(delta) {
      applyTrayState("preview", currentTrayOffset + delta);
      syncTrayStateFromOffset();
    }

    function collapseTrayBy(delta) {
      applyTrayState("preview", currentTrayOffset - delta);
      syncTrayStateFromOffset();
    }

    function handleTrayWheel(event) {
      if (!interactiveTrayMedia.matches) {
        return;
      }

      let remainingDelta = event.deltaY;

      if (remainingDelta > 0) {
        if (currentTrayOffset < maxTrayOffset) {
          const consumed = Math.min(maxTrayOffset - currentTrayOffset, remainingDelta);

          expandTrayBy(consumed);
          remainingDelta -= consumed;
        }

        if (remainingDelta > 0) {
          const maxScrollTop = trayScroll.scrollHeight - trayScroll.clientHeight;
          const nextScrollTop = Math.min(maxScrollTop, trayScroll.scrollTop + remainingDelta);

          trayScroll.scrollTop = nextScrollTop;
        }

        event.preventDefault();

        return;
      }

      if (remainingDelta < 0) {
        let upwardDelta = Math.abs(remainingDelta);

        if (trayScroll.scrollTop > 0) {
          const nextScrollTop = Math.max(0, trayScroll.scrollTop - upwardDelta);
          const consumed = trayScroll.scrollTop - nextScrollTop;

          trayScroll.scrollTop = nextScrollTop;
          upwardDelta -= consumed;
        }

        if (upwardDelta > 0 && currentTrayOffset > trayPeekOffset) {
          collapseTrayBy(upwardDelta);
        }

        event.preventDefault();
      }
    }

    function handleTrayEnter() {
      if (!interactiveTrayMedia.matches) {
        return;
      }

      if (!finePointer.matches || currentTrayOffset >= trayHoverOffset) {
        return;
      }

      applyTrayState("preview", trayHoverOffset);
      syncTrayStateFromOffset();
    }

    function handleTrayLeave() {
      if (!interactiveTrayMedia.matches) {
        return;
      }

      if (!finePointer.matches) {
        return;
      }

      if (trayScroll.scrollTop === 0 && currentTrayOffset <= trayHoverOffset) {
        applyTrayState("peek", trayPeekOffset);
      }
    }

    function handlePointerDownAway(event) {
      if (!interactiveTrayMedia.matches) {
        return;
      }

      if (currentTrayOffset <= trayPeekOffset) {
        return;
      }

      const target = event.target;

      if (!(target instanceof Node)) {
        return;
      }

      if (header?.contains(target) || tray.contains(target)) {
        return;
      }

      trayScroll.scrollTop = 0;
      applyTrayState("peek", trayPeekOffset);
    }

    function loadInitialViewerScene() {
      if (selectedSceneId !== defaultSceneId) {
        loadScene(selectedSceneId, { updateHistory: false });
      } else {
        updateSceneMeta(selectedSceneId);
      }
    }

    sceneCards.forEach((card) => {
      card.addEventListener("click", () => {
        const sceneId = card.dataset.sceneId;

        if (!sceneId || sceneId === selectedSceneId) {
          return;
        }

        selectedSceneId = sceneId;
        updateSelection(sceneId);
        loadScene(sceneId);
      });
    });

    tray.addEventListener("mouseenter", handleTrayEnter);
    tray.addEventListener("mouseleave", handleTrayLeave);
    tray.addEventListener("wheel", handleTrayWheel, { passive: false });
    document.addEventListener("pointerdown", handlePointerDownAway);
    helpToggle?.addEventListener("click", () => {
      if (isHelpOpen) {
        closeHelp();
      } else {
        openHelp();
      }
    });
    helpClose?.addEventListener("click", closeHelp);
    helpPanel?.addEventListener("click", (event) => {
      if (event.target === helpPanel) {
        closeHelp();
      }
    });
    fullscreenToggle?.addEventListener("click", toggleFullscreen);
    document.addEventListener("fullscreenchange", updateFullscreenIcon);
    shareBtn?.addEventListener("click", shareScene);
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && isHelpOpen) {
        closeHelp();
      }
    });

    window.addEventListener("resize", () => {
      updateTrayMeasurements();
      syncTrayStateFromOffset();
    });

    selectedSceneId = resolveSceneIdFromUrl();
    updateSelection(selectedSceneId);
    updateTrayMeasurements();
    applyTrayState("peek", trayPeekOffset);

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", loadInitialViewerScene, { once: true });
    } else {
      loadInitialViewerScene();
    }
  })();
</script>

<style>
  .gallery-sliding-card {
    position: relative;
    height: calc(100dvh - var(--nav-height));
    overflow: hidden;
    background: #ffffff;
    --gallery-sliding-card-offset: 0px;
    --gallery-sliding-card-tray-peek: 104px;
  }

  .gallery-sliding-card__viewer-shell {
    position: relative;
    height: calc(100dvh - (var(--nav-height) * 2));
    overflow: hidden;
  }

  .gallery-sliding-card__bottom-gap {
    height: var(--nav-height);
    background: #ffffff;
  }

  .gallery-sliding-card__overlay {
    position: absolute;
    top: clamp(1rem, 2vw, 1.75rem);
    right: clamp(1rem, 2vw, 1.75rem);
    z-index: 4;
    width: min(25rem, calc(100% - 2rem));
    padding: 0.95rem 1rem 1rem;
    border-radius: 1rem;
    background: linear-gradient(180deg, rgba(255, 250, 241, 0.82), rgba(255, 255, 255, 0.74));
    border: 1px solid rgba(148, 163, 184, 0.18);
    box-shadow: 0 18px 36px rgba(15, 23, 42, 0.16);
    backdrop-filter: blur(18px) saturate(140%);
  }

  .gallery-sliding-card__overlay-eyebrow {
    display: inline-flex;
    margin-bottom: 0.45rem;
    color: #9a6700;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .gallery-sliding-card__overlay-title {
    margin: 0;
    font-size: clamp(1.15rem, 1.6vw, 1.5rem);
    line-height: 1.12;
    color: #0f172a;
  }

  .gallery-sliding-card__overlay-meta {
    margin-top: 0.45rem;
    font-size: 0.78rem;
