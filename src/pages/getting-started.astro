---
/**
 * getting-started.astro
 *
 * Comprehensive onboarding guide for new LichtFeld Studio users.
 * Targets search queries: "how to use gaussian splatting", "lichtfeld studio tutorial", "3dgs getting started"
 *
 * Features:
 * - Schema.org HowTo structured data for rich search results
 * - Step-by-step numbered instructions with progress indicator
 * - Screenshot placeholders for visual guidance
 * - Code blocks for commands
 * - Tips and warnings callouts
 * - Video tutorial embeds
 * - Sponsor/donor CTA
 */

import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config/site.config";
import {
  GITHUB_RELEASES_URL,
  GITHUB_WIKI_URL,
  GITHUB_REPO_URL,
  DISCORD_URL,
  GITHUB_SPONSORS_URL,
  PAYPAL_URL,
  DONORBOX_URL,
} from "@/constants/project";

const base = import.meta.env.BASE_URL;

// SEO metadata
const seoTitle = "Getting Started with LichtFeld Studio: 3D Gaussian Splatting Tutorial";
const seoDescription =
  "Learn how to use LichtFeld Studio for 3D Gaussian Splatting. Step-by-step tutorial covering installation, your first training run, and basic editing.";

// HowTo structured data for Schema.org
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Getting Started with LichtFeld Studio",
  description: seoDescription,
  image: `${SITE.url}/static/social-card.png`,
  totalTime: "PT30M",
  estimatedCost: {
    "@type": "MonetaryAmount",
    currency: "USD",
    value: "0",
  },
  supply: [
    {
      "@type": "HowToSupply",
      name: "NVIDIA GPU with 8GB+ VRAM",
    },
    {
      "@type": "HowToSupply",
      name: "Windows 10/11 or Linux",
    },
    {
      "@type": "HowToSupply",
      name: "Dataset of images (20-200 photos)",
    },
  ],
  tool: [
    {
      "@type": "HowToTool",
      name: "LichtFeld Studio",
    },
    {
      "@type": "HowToTool",
      name: "COLMAP (optional, for custom datasets)",
    },
  ],
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Prepare Your Images",
      text: "Capture 20-200 photos of your subject with 60-80% overlap between shots. Ensure good lighting and avoid reflective or transparent surfaces.",
      url: `${SITE.url}/getting-started/#step-1`,
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Import Dataset",
      text: "Import your images into LichtFeld Studio. The app will automatically run COLMAP to estimate camera positions, or you can import an existing COLMAP dataset.",
      url: `${SITE.url}/getting-started/#step-2`,
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Start Training",
      text: "Configure training parameters and start the 3D Gaussian Splatting training process. Monitor progress in real-time.",
      url: `${SITE.url}/getting-started/#step-3`,
    },
    {
      "@type": "HowToStep",
      position: 4,
      name: "View and Edit Your Scene",
      text: "Use the built-in editor to clean up your scene with brush, lasso, and polygon tools. Adjust alignment and crop as needed.",
      url: `${SITE.url}/getting-started/#step-4`,
    },
    {
      "@type": "HowToStep",
      position: 5,
      name: "Export Your Splat",
      text: "Export your trained scene in standard 3D Gaussian Splatting format (.ply) for use in other applications or web viewers.",
      url: `${SITE.url}/getting-started/#step-5`,
    },
  ],
};

// Progress steps data
const steps = [
  { id: "prerequisites", label: "Prerequisites", icon: "cpu" },
  { id: "installation", label: "Installation", icon: "download" },
  { id: "step-1", label: "Prepare Images", icon: "camera" },
  { id: "step-2", label: "Import Dataset", icon: "folder-open" },
  { id: "step-3", label: "Start Training", icon: "play-circle" },
  { id: "step-4", label: "Edit Scene", icon: "vector-pen" },
  { id: "step-5", label: "Export", icon: "box-arrow-up-right" },
  { id: "next-steps", label: "Next Steps", icon: "rocket" },
];

// Hardware requirements
const hardwareRequirements = [
  { item: "GPU", value: "NVIDIA with 8GB+ VRAM", recommended: "RTX 3060 or better" },
  { item: "RAM", value: "16GB minimum", recommended: "32GB+ for large scenes" },
  { item: "Storage", value: "10GB free space", recommended: "SSD for faster I/O" },
  { item: "OS", value: "Windows 10/11 or Linux", recommended: "Windows 11 / Ubuntu 22.04" },
];

// Video tutorials from wiki
const videoTutorials = [
  {
    title: "First Training Run Walkthrough",
    embedId: "zWIzBHRc-60",
    duration: "12:34",
    description: "Complete walkthrough of your first 3D Gaussian Splatting training session.",
  },
];

// Troubleshooting quick links
const troubleshootingLinks = [
  { label: "Training fails to start", href: `${base}faq/#training-fails` },
  { label: "Out of memory errors", href: `${base}faq/#oom-errors` },
  { label: "Poor reconstruction quality", href: `${base}faq/#quality-issues` },
  { label: "Importing custom datasets", href: `${base}faq/#custom-datasets` },
];

// Next steps resources
const nextSteps = [
  {
    title: "Plugin Development",
    description: "Extend LichtFeld Studio with Python plugins for custom workflows.",
    href: `${base}docs/`,
    icon: "code-square",
  },
  {
    title: "MCP Integration",
    description: "Control the editor programmatically via Model Context Protocol.",
    href: `${base}docs/mcp/`,
    icon: "command",
  },
  {
    title: "Advanced Training",
    description: "Learn about advanced training parameters and optimization techniques.",
    href: GITHUB_WIKI_URL,
    icon: "sliders",
    external: true,
  },
  {
    title: "Capture Tips",
    description: "Best practices for capturing photos that reconstruct well.",
    href: `${base}tutorials/capture-tips/`,
    icon: "camera-fill",
  },
];
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Schema.org HowTo Structured Data -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(howToSchema)} />

  <!-- Hero Section -->
  <header class="guide-hero">
    <div class="container content-frame px-4">
      <div class="guide-hero__content">
        <nav class="guide-breadcrumb" aria-label="Breadcrumb">
          <ol class="guide-breadcrumb__list">
            <li class="guide-breadcrumb__item">
              <a href={base} class="guide-breadcrumb__link">Home</a>
            </li>
            <li class="guide-breadcrumb__item" aria-current="page">
              <span>Getting Started</span>
            </li>
          </ol>
        </nav>
        
        <h1 class="guide-hero__title">Getting Started with LichtFeld Studio</h1>
        <p class="guide-hero__lead">
          From your first photo capture to a finished 3D scene—follow this step-by-step tutorial to master 3D Gaussian
          Splatting with the open-source studio built for artists and researchers.
        </p>
        
        <div class="guide-hero__meta">
          <span class="guide-hero__reading-time">
            <svg class="bi" width="16" height="16" aria-hidden="true">
              <use href={`${base}static/bootstrap-icons.svg#clock`}></use>
            </svg>
            ~30 minutes
          </span>
          <span class="guide-hero__updated">
            Beginner friendly
          </span>
          <span class="guide-hero__updated">
            Free & open source
          </span>
        </div>
      </div>
    </div>
  </header>

  <!-- Progress Indicator -->
  <nav class="guide-progress" aria-label="Getting started progress">
    <div class="container content-frame px-4">
      <div class="guide-progress__track">
        {
          steps.map((step, index) => (
            <a href={`#${step.id}`} class="guide-progress__item" data-step={index + 1}>
              <span class="guide-progress__icon" aria-hidden="true">
                <svg class="bi" width="1em" height="1em">
                  <use href={`${base}static/bootstrap-icons.svg#${step.icon}`} />
                </svg>
              </span>
              <span class="guide-progress__label">{step.label}</span>
            </a>
          ))
        }
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="guide-content">
    <div class="container content-frame px-4">
      <div class="guide-content__layout">
        <!-- Article Body -->
        <div class="guide-content__main">
          
          <!-- Prerequisites Section -->
          <section id="prerequisites" class="guide-section">
            <h2 class="guide-section__title">Prerequisites</h2>

            <div class="guide-innovation">
              <h3>Hardware Requirements</h3>
              <p>
                3D Gaussian Splatting requires a modern NVIDIA GPU for training. Ensure your system meets these
                requirements before proceeding.
              </p>

              <div class="guide-specs-list">
                {hardwareRequirements.map((req) => (
                  <div class="guide-requirement">
                    <span class="guide-requirement__item">{req.item}</span>
                    <span class="guide-requirement__value">{req.value}</span>
                    <span class="guide-requirement__rec">Recommended: {req.recommended}</span>
                  </div>
                ))}
              </div>

              <div class="guide-info-box">
                <div class="guide-info-box__icon" aria-hidden="true">
                  <svg class="bi" width="24" height="24">
                    <use href={`${base}static/bootstrap-icons.svg#info-circle`}></use>
                  </svg>
                </div>
                <div class="guide-info-box__content">
                  <strong>Don't have a suitable GPU?</strong>
                  <p>
                    You can still use LichtFeld Studio to view and edit splats on lower-end hardware. Training requires the
                    GPU, but viewing works on most modern systems.
                  </p>
                </div>
              </div>
            </div>

            <div class="guide-innovation">
              <h3>Software Requirements</h3>
              <ul class="guide-list">
                <li>Windows 10/11 (64-bit) or Linux (Ubuntu 20.04+)</li>
                <li>NVIDIA Driver >= 570 required</li>
                <li>CUDA Toolkit 12.8+ (for building from source)</li>
                <li>CMake 3.20+ (for building from source)</li>
              </ul>
            </div>
          </section>

          <!-- Installation Section -->
          <section id="installation" class="guide-section">
            <h2 class="guide-section__title">Installation</h2>

            <div class="guide-install-tabs">
              <div class="guide-install-tab guide-install-tab--active" data-tab="windows">
                <svg class="bi" width="16" height="16" aria-hidden="true">
                  <use href={`${base}static/bootstrap-icons.svg#windows`}></use>
                </svg>
                Windows Binary
              </div>
              <div class="guide-install-tab" data-tab="source">
                <svg class="bi" width="16" height="16" aria-hidden="true">
                  <use href={`${base}static/bootstrap-icons.svg#terminal`}></use>
                </svg>
                Build from Source
              </div>
            </div>

            <!-- Windows Binary -->
            <div class="guide-install-content guide-install-content--active" data-content="windows">
              <div class="guide-innovation">
                <h3>Download Pre-built Windows Binary</h3>
                <p>
                  The fastest way to get started. Download the latest stable release and run the installer.
                </p>

                <div class="guide-cta-box">
                  <a
                    href={GITHUB_RELEASES_URL}
                    class="btn btn-primary btn-lg"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <svg class="bi" width="20" height="20" aria-hidden="true">
                      <use href={`${base}static/bootstrap-icons.svg#download`}></use>
                    </svg>
                    Download for Windows
                  </a>
                </div>

                <ol class="guide-list guide-list--numbered">
                  <li>Download the <code>LichtFeld-Studio_Windows_vX.X.X.zip</code> file</li>
                  <li>Extract the ZIP file to your preferred location</li>
                  <li>Run <code>bin/LichtFeld-Studio.exe</code> from the extracted folder</li>
                </ol>
              </div>
            </div>

            <!-- Build from Source -->
            <div class="guide-install-content" data-content="source">
              <div class="guide-innovation">
                <h3>Build from Source</h3>
                <p>
                  For Linux users or those who want the latest development features, build from source.
                </p>

                <div class="guide-warning-box">
                  <div class="guide-warning-box__icon" aria-hidden="true">
                    <svg class="bi" width="24" height="24">
                      <use href={`${base}static/bootstrap-icons.svg#exclamation-triangle`}></use>
                    </svg>
                  </div>
                  <div class="guide-warning-box__content">
                    <strong>Advanced users only</strong>
                    <p>
                      Building from source requires familiarity with CMake, C++ compilers, and CUDA development tools.
                    </p>
                  </div>
                </div>

                <h4>Quick Build Commands</h4>
                <div class="guide-code-block">
                  <pre><code># Set up vcpkg (one-time setup)
git clone https://github.com/microsoft/vcpkg.git
cd vcpkg && ./bootstrap-vcpkg.sh -disableMetrics && cd ..

## If you want you can specify vcpkg locally without globally setting env variable (see -DCMAKE_TOOLCHAIN_FILE version)
export VCPKG_ROOT=/path/to/vcpkg  # Add to ~/.bashrc

# Clone repository and submodules
git clone --recursive https://github.com/MrNeRF/LichtFeld-Studio
cd LichtFeld-Studio

# Build
cmake -B build -DCMAKE_BUILD_TYPE=Release -G Ninja

## Or if you want you can specify your own vcpkg 
# cmake -B build -DCMAKE_BUILD_TYPE=Release -DCMAKE_TOOLCHAIN_FILE="&lt;path-to-vcpkg&gt;/scripts/buildsystems/vcpkg.cmake" -G Ninja 

cmake --build build -- -j$(nproc)</code></pre>
                  <button class="guide-code-block__copy" aria-label="Copy code to clipboard">
                    <svg class="bi" width="16" height="16">
                      <use href={`${base}static/bootstrap-icons.svg#clipboard`}></use>
                    </svg>
                  </button>
                </div>

                <p>
                  For detailed build instructions, see the <a href={GITHUB_WIKI_URL} target="_blank" rel="noopener noreferrer" class="guide-link">Build Guide on our Wiki</a>.
                </p>
              </div>
            </div>
          </section>

          <!-- Step 1: Prepare Your Images -->
          <section id="step-1" class="guide-section">
            <h2 class="guide-section__title">Step 1: Prepare Your Images</h2>

            <div class="guide-innovation">
              <h3>Capture Guidelines</h3>
              <p>
                Good input photos are essential for quality 3D reconstructions. Follow these guidelines for best results:
              </p>

              <div class="guide-tips-grid">
                <div class="guide-tip-card guide-tip-card--do">
                  <span class="guide-tip-card__icon">
                    <svg class="bi" width="24" height="24" aria-hidden="true">
                      <use href={`${base}static/bootstrap-icons.svg#check-circle-fill`}></use>
                    </svg>
                  </span>
                  <div class="guide-tip-card__content">
                    <h4>Do</h4>
                    <ul>
                      <li>Use 20-200 photos with 60-80% overlap</li>
                      <li>Capture from multiple angles and heights</li>
                      <li>Ensure good, even lighting</li>
                      <li>Keep the subject static during capture</li>
                      <li>Use a tripod for challenging lighting</li>
                    </ul>
                  </div>
                </div>

                <div class="guide-tip-card guide-tip-card--dont">
                  <span class="guide-tip-card__icon">
                    <svg class="bi" width="24" height="24" aria-hidden="true">
                      <use href={`${base}static/bootstrap-icons.svg#x-circle-fill`}></use>
                    </svg>
                  </span>
                  <div class="guide-tip-card__content">
                    <h4>Don't</h4>
                    <ul>
                      <li>Capture reflective or transparent surfaces</li>
                      <li>Move too quickly between shots</li>
                      <li>Use extreme wide-angle lenses</li>
                      <li>Include moving objects in the scene</li>
                      <li>Shoot in harsh, direct sunlight</li>
                    </ul>
                  </div>
                </div>
              </div>

              <p>
                <a href={`${base}tutorials/capture-tips/`} class="guide-link">
                  Read the full Capture Tips guide
                  <svg class="bi" width="16" height="16" aria-hidden="true">
                    <use href={`${base}static/bootstrap-icons.svg#arrow-right`}></use>
                  </svg>
                </a>
              </p>
            </div>
          </section>

          <!-- Step 2: Import Dataset -->
          <section id="step-2" class="guide-section">
            <h2 class="guide-section__title">Step 2: Import Dataset (COLMAP)</h2>

            <div class="guide-innovation">
              <h3>Import Your COLMAP Dataset</h3>
              <p>
                <strong>Important:</strong> You must run structure from motion separately before importing into LichtFeld Studio. 
                LFS does not run COLMAP automatically. Use COLMAP CLI, RealityScan, or similar tools 
                to process your images first, then import the COLMAP output into LFS.
              </p>

              <h4>Prerequisites</h4>
              <ul class="guide-list">
                <li>Process your images with COLMAP CLI, RealityScan, or similar SfM tools</li>
                <li>Ensure you have a valid COLMAP-format sparse reconstruction (cameras.txt, images.txt, points3D.txt)</li>
              </ul>

              <h4>Import Steps</h4>
              <ol class="guide-list guide-list--numbered">
                <li>
                  <strong>Launch LichtFeld Studio</strong>
                  <p>Start the application and wait for the main workspace to load.</p>
                </li>
                <li>
                  <strong>Import COLMAP Dataset</strong>
                  <p>Click <kbd>Import</kbd> → <kbd>COLMAP Dataset</kbd> and select your folder containing the COLMAP sparse reconstruction</p>
                  <p>Alternatively you can drag and drop the COLMAP sparse reconstruction folder into the application</p>
                </li>
                <li>
                  <strong>Verify Import</strong>
                  <p>
                    Check that camera poses and point cloud data loaded correctly in the preview.
                  </p>
                </li>
              </ol>

              <div class="guide-info-box">
                <div class="guide-info-box__icon" aria-hidden="true">
                  <svg class="bi" width="24" height="24">
                    <use href={`${base}static/bootstrap-icons.svg#info-circle`}></use>
                  </svg>
                </div>
                <div class="guide-info-box__content">
                  <strong>Using External COLMAP Tools</strong>
                  <p>
                    Popular alternatives include: <a href="https://colmap.github.io/" target="_blank" rel="noopener noreferrer" class="guide-link">COLMAP CLI</a>, 
                    <a href="https://www.unrealengine.com/realityscan" target="_blank" rel="noopener noreferrer" class="guide-link">RealityScan</a>. 
                    Export your results in COLMAP format, then import into LFS.
                  </p>
                </div>
              </div>
            </div>
          </section>

          <!-- Step 3: Start Training -->
          <section id="step-3" class="guide-section">
            <h2 class="guide-section__title">Step 3: Start Training</h2>

            <div class="guide-innovation">
              <h3>Configure and Launch Training</h3>
              <p>
                Once your dataset is imported with camera poses, you're ready to start 3D Gaussian Splatting training.
              </p>

              <ol class="guide-list guide-list--numbered">
                <li>
                  <strong>Open Training Panel</strong>
                  <p>Click on the <kbd>Training</kbd> panel on the right-hand side</p>
                </li>
                <li>
                  <strong>Verify Dataset</strong>
                  <p>Confirm the image count and camera poses look correct in the viewport and scene graph</p>
                </li>
                <li>
                  <strong>Adjust Settings (Optional)</strong>
                  <p>
                    For your first run, use defaults. Advanced users can tweak iterations, learning rates, and densification
                    settings.
                  </p>
                </li>
                <li>
                  <strong>Start Training</strong>
                  <p>Click <kbd>Start Training</kbd> and monitor progress in real-time. You can navigate, rotate, and zoom in the viewport while training progresses.</p>
                </li>
              </ol>

              <p>
                <a href={`${base}tutorials/first-training/`} class="guide-link">
                  Read the detailed First Training tutorial
                  <svg class="bi" width="16" height="16" aria-hidden="true">
                    <use href={`${base}static/bootstrap-icons.svg#arrow-right`}></use>
                  </svg>
                </a>
              </p>
            </div>
          </section>

          <!-- Step 4: View and Edit -->
          <section id="step-4" class="guide-section">
            <h2 class="guide-section__title">Step 4: View and Edit Your Scene</h2>

            <div class="guide-innovation">
              <h3>Interactive Scene Editor</h3>
              <p>
                Once training completes, your 3D scene appears in the viewer. Use the built-in editing tools to clean up
                and refine the result.
              </p>

              <div class="guide-editor-tools">
                <div class="guide-editor-tool">
                  <span class="guide-editor-tool__icon">
                    <svg class="bi" width="24" height="24" aria-hidden="true">
                      <use href={`${base}static/bootstrap-icons.svg#brush`}></use>
                    </svg>
                  </span>
                  <h4 class="guide-editor-tool__name">Brush Tool</h4>
                  <p class="guide-editor-tool__desc">Paint over splats to select or delete them</p>
                </div>
                <div class="guide-editor-tool">
                  <span class="guide-editor-tool__icon">
                    <svg class="bi" width="24" height="24" aria-hidden="true">
                      <use href={`${base}static/bootstrap-icons.svg#bullseye`}></use>
                    </svg>
                  </span>
                  <h4 class="guide-editor-tool__name">Lasso Select</h4>
                  <p class="guide-editor-tool__desc">Draw freehand selections around regions</p>
                </div>
                <div class="guide-editor-tool">
                  <span class="guide-editor-tool__icon">
                    <svg class="bi" width="24" height="24" aria-hidden="true">
                      <use href={`${base}static/bootstrap-icons.svg#hexagon`}></use>
                    </svg>
                  </span>
                  <h4 class="guide-editor-tool__name">Polygon Tool</h4>
                  <p class="guide-editor-tool__desc">Create precise polygonal selections</p>
                </div>
                <div class="guide-editor-tool">
                  <span class="guide-editor-tool__icon">
                    <svg class="bi" width="24" height="24" aria-hidden="true">
                      <use href={`${base}static/bootstrap-icons.svg#crop`}></use>
                    </svg>
                  </span>
                  <h4 class="guide-editor-tool__name">Crop & Align</h4>
                  <p class="guide-editor-tool__desc">Adjust scene boundaries and alignment</p>
                </div>
              </div>

              <h4>Basic Editing Workflow</h4>
              <ol class="guide-list guide-list--numbered">
                <li>
                  <strong>Navigate the Scene</strong>
                  <p>Left-click and drag to rotate, right-click to pan, scroll to zoom</p>
                </li>
                <li>
                  <strong>Identify Artifacts</strong>
                  <p>Look for floating splats, noise, or reconstruction errors</p>
                </li>
                <li>
                  <strong>Select and Delete</strong>
                  <p>Use the Brush or Lasso tool to select unwanted splats, then press <kbd>Delete</kbd></p>
                </li>
                <li>
                  <strong>Refine Selections</strong>
                  <p>Adjust brush size and use the mask view to verify selections</p>
                </li>
              </ol>

              <div class="guide-info-box">
                <div class="guide-info-box__icon" aria-hidden="true">
                  <svg class="bi" width="24" height="24">
                    <use href={`${base}static/bootstrap-icons.svg#lightbulb`}></use>
                  </svg>
                </div>
                <div class="guide-info-box__content">
                  <strong>Multiple Render Modes</strong>
                  <p>
                    Switch between render modes (RGB, Depth, Normal, etc.) to better identify artifacts and verify your
                    edits.
                  </p>
                </div>
              </div>
            </div>
          </section>

          <!-- Step 5: Export -->
          <section id="step-5" class="guide-section">
            <h2 class="guide-section__title">Step 5: Export Your Splat</h2>

            <div class="guide-innovation">
              <h3>Export Options</h3>
              <p>
                Save your trained and edited scene in standard formats for use in other applications, web viewers, or
                rendering pipelines.
              </p>

              <div class="guide-export-formats">
                <div class="guide-export-format guide-export-format--recommended">
                  <span class="guide-export-format__badge">Primary</span>
                  <h4 class="guide-export-format__name">PLY (Standard 3DGS)</h4>
                  <p class="guide-export-format__desc">
                    Standard 3D Gaussian Splatting format compatible with most viewers and renderers
                  </p>
                  <code class="guide-export-format__ext">.ply</code>
                </div>
                <div class="guide-export-format">
                  <h4 class="guide-export-format__name">SOG (Compressed)</h4>
                  <p class="guide-export-format__desc">Compressed format specifically for efficient storage and web deployment</p>
                  <code class="guide-export-format__ext">.sog</code>
                </div>
              </div>

              <h4>Export Steps</h4>
              <ol class="guide-list guide-list--numbered">
                <li>
                  <strong>Open Export Dialog</strong>
