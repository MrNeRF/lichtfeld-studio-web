<script>
  // Installation tab switching
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll(".guide-install-tab");
    const contents = document.querySelectorAll(".guide-install-content");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.getAttribute("data-tab");

        // Update tabs
        tabs.forEach((t) => t.classList.remove("guide-install-tab--active"));
        tab.classList.add("guide-install-tab--active");

        // Update content
        contents.forEach((c) => {
          c.classList.remove("guide-install-content--active");
          if (c.getAttribute("data-content") === target) {
            c.classList.add("guide-install-content--active");
          }
        });
      });
    });

    // Code block copy functionality
    const copyButtons = document.querySelectorAll(".guide-code-block__copy");
    copyButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const code = btn.previousElementSibling?.textContent;
        if (code) {
          navigator.clipboard.writeText(code).then(() => {
            const originalIcon = btn.innerHTML;
            btn.innerHTML = '<svg class="bi" width="16" height="16"><use href="' + document.querySelector('base')?.href + 'static/bootstrap-icons.svg#check-lg"></use></svg>';
            setTimeout(() => {
              btn.innerHTML = originalIcon;
            }, 2000);
          });
        }
      });
    });

    // Progress indicator active state on scroll
    const sections = document.querySelectorAll(".guide-section[id]");
    const progressItems = document.querySelectorAll(".guide-progress__item");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute("id");
            progressItems.forEach((item) => {
              item.classList.remove("guide-progress__item--active");
              if (item.getAttribute("href") === `#${id}`) {
                item.classList.add("guide-progress__item--active");
              }
            });
          }
        });
      },
      { rootMargin: "-20% 0px -60% 0px" }
    );

    sections.forEach((section) => observer.observe(section));

    // Share button functionality
    const shareBtn = document.getElementById('share-page-btn');
    const toast = document.getElementById('share-toast');

    if (shareBtn && toast) {
      shareBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          
          // Show toast
          toast.classList.add('is-visible');
          toast.setAttribute('aria-hidden', 'false');
          
          // Hide after 3 seconds
          setTimeout(() => {
            toast.classList.remove('is-visible');
            toast.setAttribute('aria-hidden', 'true');
          }, 3000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    }
  });
</script>

