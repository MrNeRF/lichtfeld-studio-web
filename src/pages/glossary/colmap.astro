                  <span class="guide-file-tree__name">0/</span>
                  <span class="guide-file-tree__desc">— Reconstruction folder (numbered)</span>
                </div>
                <div class="guide-file-tree__item guide-file-tree__item--deep">
                  <span class="guide-file-tree__icon">📄</span>
                  <span class="guide-file-tree__name">cameras.bin</span>
                  <span class="guide-file-tree__desc">— Camera intrinsic parameters</span>
                </div>
                <div class="guide-file-tree__item guide-file-tree__item--deep">
                  <span class="guide-file-tree__icon">📄</span>
                  <span class="guide-file-tree__name">images.bin</span>
