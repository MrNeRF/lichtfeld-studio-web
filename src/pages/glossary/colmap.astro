---
/**
 * colmap.astro
 *
 * Educational glossary page targeting:
 * - "what is colmap"
 * - "colmap 3d gaussian splatting"
 * - "colmap tutorial"
 *
 * Features:
 * - Schema.org Definition + Article structured data
 * - Breadcrumb navigation
 * - Code blocks for commands
 * - File structure diagrams
 * - Tips and warnings
 * - Internal links to related pages
 */

import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config/site.config";
import {
  GITHUB_REPO_URL,
  GITHUB_WIKI_URL,
  DISCORD_URL,
} from "@/constants/project";

const base = import.meta.env.BASE_URL;

// SEO metadata
const seoTitle = "What is COLMAP? Complete Guide for 3D Gaussian Splatting";
const seoDescription = "Learn what COLMAP is and how to use it with LichtFeld Studio for 3D Gaussian Splatting. Step-by-step guide to structure-from-motion and camera calibration.";

// Article metadata for Schema.org
const articlePublishedDate = new Date();
const articleModifiedDate = new Date();

// FAQ data
const faqs = [
  {
    question: "What is COLMAP used for?",
    answer: "COLMAP is a Structure-from-Motion (SfM) and Multi-View Stereo (MVS) pipeline used to reconstruct 3D geometry from 2D images. It's primarily used for estimating camera poses, creating sparse point clouds, and generating dense reconstructions for applications like 3D Gaussian Splatting."
  },
  {
    question: "Is COLMAP free to use?",
    answer: "Yes, COLMAP is completely free and open-source under the BSD license. You can use it for personal, academic, and commercial projects without restrictions."
  },
  {
    question: "Do I need to install COLMAP separately for LichtFeld Studio?",
    answer: "Yes, COLMAP is a separate prerequisite tool that you must run independently before using LichtFeld Studio. LFS does not include or automatically run COLMAP. You need to use COLMAP CLI, RealityScan, or similar photogrammetry tools first to generate the sparse reconstruction (cameras.bin, images.bin, points3D.bin), then import that output into LFS."
  },
  {
    question: "How long does COLMAP processing take?",
    answer: "Processing time depends on the number of images and your hardware. Feature extraction typically takes 1-3 minutes per 100 images, and matching can take 5-30 minutes depending on image overlap and resolution."
  },
  {
    question: "What image formats does COLMAP support?",
    answer: "COLMAP supports common image formats including JPG, PNG, TIFF, and BMP. RAW files should be converted to one of these formats before processing."
  }
];

// Related glossary terms (for future expansion)
const relatedTerms = [
  {
    term: "3D Gaussian Splatting",
    description: "A real-time 3D rendering technique using millions of colored 3D Gaussians.",
    href: `${base}what-is-gaussian-splatting/`
  },
  {
    term: "Structure from Motion",
    description: "The process of estimating 3D structure from 2D image sequences.",
    href: `${base}glossary/sfm/`
  },
  {
    term: "Camera Calibration",
    description: "Determining camera intrinsic and extrinsic parameters for accurate 3D reconstruction.",
    href: `${base}glossary/camera-calibration/`
  }
];

// Build Schema.org Definition structured data
const definitionSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "name": "COLMAP",
  "description": "A general-purpose Structure-from-Motion and Multi-View Stereo pipeline for 3D reconstruction from images.",
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "name": "3D Gaussian Splatting Glossary"
  }
};

// Build Schema.org Article structured data
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": seoTitle,
  "description": seoDescription,
  "image": new URL(`${base}static/social-card.png`, Astro.site).toString(),
  "author": {
    "@type": "Organization",
    "name": SITE.name,
    "url": SITE.url
  },
  "publisher": {
    "@type": "Organization",
    "name": SITE.name,
    "logo": {
      "@type": "ImageObject",
      "url": new URL(`${base}static/favicon.svg`, Astro.site).toString()
    }
  },
  "datePublished": articlePublishedDate.toISOString(),
  "dateModified": articleModifiedDate.toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, Astro.site).toString()
  }
};

// Build FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

// Breadcrumb schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": new URL(base, Astro.site).toString()
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Glossary",
      "item": new URL(`${base}glossary/`, Astro.site).toString()
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "COLMAP",
      "item": new URL(Astro.url.pathname, Astro.site).toString()
    }
  ]
};
---

<Layout 
  title={seoTitle} 
  description={seoDescription}
  ogType="article"
>
  <!-- Schema.org Structured Data -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(definitionSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="guide-page">
    <!-- Hero Section -->
    <header class="guide-hero">
      <div class="container content-frame px-4">
        <div class="guide-hero__content">
          <nav class="guide-breadcrumb" aria-label="Breadcrumb">
            <ol class="guide-breadcrumb__list">
              <li class="guide-breadcrumb__item">
                <a href={base} class="guide-breadcrumb__link">Home</a>
              </li>
              <li class="guide-breadcrumb__item">
                <a href={`${base}glossary/`} class="guide-breadcrumb__link">Glossary</a>
              </li>
              <li class="guide-breadcrumb__item" aria-current="page">
                <span>COLMAP</span>
              </li>
            </ol>
          </nav>
          
          <h1 class="guide-hero__title">What is COLMAP?</h1>
          <p class="guide-hero__lead">
            <strong>COLMAP</strong> is a powerful open-source Structure-from-Motion (SfM) and Multi-View Stereo (MVS) 
            pipeline that transforms 2D images into accurate 3D reconstructions. It's the essential first step in 
            creating 3D Gaussian Splats and many other 3D vision workflows.
          </p>
          
          <div class="guide-hero__meta">
            <span class="guide-hero__reading-time">
              <svg class="bi" width="16" height="16" aria-hidden="true">
                <use href={`${base}static/bootstrap-icons.svg#clock`}></use>
              </svg>
              8 min read
            </span>
            <span class="guide-hero__updated">
              Updated {articleModifiedDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
            </span>
          </div>
        </div>
      </div>
    </header>

    <!-- Table of Contents -->
    <nav class="guide-toc" aria-label="Table of contents">
      <div class="container content-frame px-4">
        <div class="guide-toc__shell shell shell--compact">
          <h2 class="guide-toc__title">Contents</h2>
          <ol class="guide-toc__list">
            <li><a href="#what-is" class="guide-toc__link">What is COLMAP?</a></li>
            <li><a href="#how-it-works" class="guide-toc__link">How COLMAP Works</a></li>
            <li><a href="#why-important" class="guide-toc__link">Why COLMAP is Important for 3DGS</a></li>
            <li><a href="#capture-guidelines" class="guide-toc__link">Capture Guidelines</a></li>
            <li><a href="#installing" class="guide-toc__link">Installing COLMAP</a></li>
            <li><a href="#lichtfeld" class="guide-toc__link">Using COLMAP with LichtFeld Studio</a></li>
            <li><a href="#output-format" class="guide-toc__link">COLMAP Output Format</a></li>
            <li><a href="#faq" class="guide-toc__link">FAQ</a></li>
            <li><a href="#related" class="guide-toc__link">Related Terms</a></li>
          </ol>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <div class="guide-content">
      <div class="container content-frame px-4">
        <div class="guide-content__layout">
          <!-- Article Body -->
          <div class="guide-content__main">
            
            <!-- Section 1: What is COLMAP? -->
            <section id="what-is" class="guide-section">
              <h2 class="guide-section__title">What is COLMAP?</h2>
              
              <p class="guide-section__lead">
                <strong>COLMAP</strong> (short for "COLlection MAPping") is a general-purpose photogrammetry pipeline 
                that reconstructs 3D geometry from a collection of 2D images. Developed by Johannes Schönberger and 
                colleagues, it's become the industry standard for Structure-from-Motion tasks and serves as the 
                foundation for many 3D reconstruction workflows, including 3D Gaussian Splatting.
              </p>

              <p>
                At its core, COLMAP solves a fundamental computer vision problem: given multiple photographs of a 
                scene taken from different viewpoints, determine where each photo was taken (camera pose) and build 
                a 3D representation of the scene geometry. This process is essential for any 3D reconstruction 
                pipeline that starts with regular photographs.
              </p>

              <h3>Key Capabilities</h3>
              <ul class="guide-list">
                <li><strong>Feature Extraction:</strong> Identifies distinctive visual features in each image</li>
                <li><strong>Feature Matching:</strong> Finds corresponding features across multiple images</li>
                <li><strong>Sparse Reconstruction:</strong> Estimates camera poses and creates a sparse point cloud</li>
                <li><strong>Dense Reconstruction:</strong> Generates detailed depth maps and dense point clouds</li>
                <li><strong>Mesh Reconstruction:</strong> Creates textured 3D meshes from dense point clouds</li>
              </ul>

              <div class="guide-info-box">
                <div class="guide-info-box__icon" aria-hidden="true">
                  <svg class="bi" width="24" height="24">
                    <use href={`${base}static/bootstrap-icons.svg#book`}></use>
                  </svg>
                </div>
                <div class="guide-info-box__content">
                  <strong>Getting Started:</strong> New to COLMAP and 3D Gaussian Splatting? 
                  See our <a href={`${base}getting-started/`} class="guide-link">Getting Started guide</a> for a 
                  complete walkthrough from capture to final splat.
                </div>
              </div>

              <div class="guide-info-box">
                <div class="guide-info-box__icon" aria-hidden="true">
                  <svg class="bi" width="24" height="24">
                    <use href={`${base}static/bootstrap-icons.svg#lightbulb`}></use>
                  </svg>
                </div>
                <div class="guide-info-box__content">
                  <strong>Key Insight:</strong> COLMAP doesn't create the final 3D Gaussian Splat directly. Instead, 
                  it provides the essential camera calibration and initial point cloud that 3D Gaussian Splatting 
                  algorithms use as their starting point for training.
                </div>
              </div>
            </section>

            <!-- Section 2: How COLMAP Works -->
            <section id="how-it-works" class="guide-section">
              <h2 class="guide-section__title">How COLMAP Works</h2>
              
              <p class="guide-section__lead">
                COLMAP operates in two main stages: <strong>Structure-from-Motion (SfM)</strong> for sparse 
                reconstruction and <strong>Multi-View Stereo (MVS)</strong> for dense reconstruction. 
                Understanding these stages helps you use COLMAP more effectively.
              </p>

              <h3>Stage 1: Structure-from-Motion (SfM)</h3>
              <p>
                Structure-from-Motion is the process of estimating camera poses and sparse 3D structure from images. 
                COLMAP's SfM pipeline follows these steps:
              </p>
              
              <ol class="guide-list guide-list--numbered">
                <li>
                  <strong>Feature Extraction:</strong> COLMAP analyzes each image and extracts distinctive visual 
                  features using algorithms like SIFT (Scale-Invariant Feature Transform). These features are 
                  points in the image that are likely to be recognizable from different viewpoints.
                </li>
                <li>
                  <strong>Feature Matching:</strong> The extracted features are compared across image pairs to find 
                  correspondences—points that appear in multiple images. COLMAP uses geometric verification to 
                  ensure matches are consistent with 3D geometry.
                </li>
                <li>
                  <strong>Geometric Estimation:</strong> Using the matched features, COLMAP estimates the relative 
                  positions and orientations of cameras, as well as the 3D positions of feature points. This creates 
                  a sparse point cloud representing the scene.
                </li>
                <li>
                  <strong>Bundle Adjustment:</strong> This optimization step refines all camera parameters and 3D 
                  point positions simultaneously to minimize reprojection error—the difference between where 
                  points appear in images and where the model predicts they should appear.
                </li>
              </ol>

              <h3>Stage 2: Multi-View Stereo (MVS)</h3>
              <p>
                While SfM produces a sparse point cloud, Multi-View Stereo creates dense depth maps and a 
                comprehensive point cloud with millions of points:
              </p>
              
              <ol class="guide-list guide-list--numbered">
                <li>
                  <strong>Stereo Matching:</strong> For each image, COLMAP finds corresponding pixels in 
                  neighboring views and calculates depth using triangulation.
                </li>
                <li>
                  <strong>Depth Map Fusion:</strong> Depth estimates from multiple views are fused into a 
                  consistent 3D point cloud, filtering out outliers and noise.
                </li>
                <li>
                  <strong>Mesh Reconstruction (Optional):</strong> The dense point cloud can be converted 
                  into a textured mesh using Poisson surface reconstruction or Delaunay triangulation.
                </li>
              </ol>

              <div class="guide-tech-specs">
                <h4>Technical Specifications</h4>
                <dl class="guide-specs-list">
                  <dt>Feature Types</dt>
                  <dd>SIFT, SURF, ORB, AKAZE (configurable)</dd>
                  
                  <dt>Matching Strategies</dt>
                  <dd>Exhaustive, sequential, vocabulary tree, spatial</dd>
                  
                  <dt>Camera Models</dt>
                  <dd>PINHOLE, OPENCV, OPENCV_FISHEYE, FULL_OPENCV, FOV, SIMPLE_RADIAL, RADIAL</dd>
                  
                  <dt>Output Formats</dt>
                  <dd>TXT, BIN, PLY, OBJ, VRML</dd>
                </dl>
              </div>
            </section>

            <!-- Section 3: Why COLMAP is Important for 3DGS -->
            <section id="why-important" class="guide-section">
              <h2 class="guide-section__title">Why COLMAP is Important for 3D Gaussian Splatting</h2>
              
              <p class="guide-section__lead">
                3D Gaussian Splatting (3DGS) requires accurate camera calibration and an initial point cloud 
                to begin training. COLMAP provides both, making it an indispensable tool in the 3DGS workflow.
              </p>

              <h3>The 3DGS Pipeline Dependency</h3>
              <p>
                The standard 3D Gaussian Splatting training pipeline looks like this:
              </p>
              
              <div class="guide-pipeline">
                <div class="guide-pipeline__step">
                  <span class="guide-pipeline__number">1</span>
                  <span class="guide-pipeline__label">Capture Images</span>
                </div>
                <div class="guide-pipeline__arrow">→</div>
                <div class="guide-pipeline__step guide-pipeline__step--highlight">
                  <span class="guide-pipeline__number">2</span>
                  <span class="guide-pipeline__label">COLMAP SfM</span>
                </div>
                <div class="guide-pipeline__arrow">→</div>
                <div class="guide-pipeline__step">
                  <span class="guide-pipeline__number">3</span>
                  <span class="guide-pipeline__label">3DGS Training</span>
                </div>
                <div class="guide-pipeline__arrow">→</div>
                <div class="guide-pipeline__step">
                  <span class="guide-pipeline__number">4</span>
                  <span class="guide-pipeline__label">Rendered Splat</span>
                </div>
              </div>

              <p>
                Without COLMAP (or a similar SfM tool), 3DGS has no way to know:
              </p>
              
              <ul class="guide-list">
                <li><strong>Camera positions:</strong> Where each photo was taken in 3D space</li>
                <li><strong>Camera orientations:</strong> Which direction each camera was facing</li>
                <li><strong>Camera intrinsics:</strong> Focal length, principal point, and lens distortion parameters</li>
                <li><strong>Initial geometry:</strong> A starting point for the 3D Gaussian positions</li>
              </ul>

              <h3>Why COLMAP Specifically?</h3>
              <p>
                Several SfM solutions exist, but COLMAP has become the de facto standard for 3DGS for several reasons:
              </p>
              
              <ul class="guide-list">
                <li><strong>Accuracy:</strong> Produces highly accurate camera calibrations</li>
                <li><strong>Robustness:</strong> Handles challenging datasets better than many alternatives</li>
                <li><strong>Open Source:</strong> Free to use and actively maintained by the research community</li>
                <li><strong>Compatibility:</strong> Output format is directly compatible with 3DGS implementations</li>
                <li><strong>Documentation:</strong> Extensive tutorials and community support available</li>
              </ul>

              <div class="guide-warning-box">
                <div class="guide-warning-box__icon" aria-hidden="true">
                  <svg class="bi" width="24" height="24">
                    <use href={`${base}static/bootstrap-icons.svg#exclamation-triangle`}></use>
                  </svg>
                </div>
                <div class="guide-warning-box__content">
                  <strong>Important:</strong> The quality of your COLMAP reconstruction directly impacts 
                  your final 3D Gaussian Splat quality. Poor camera calibration will result in blurry, 
                  misaligned, or incomplete splats. Always verify your COLMAP output before proceeding 
                  to 3DGS training. For capture best practices, see our <a href={`${base}tutorials/capture-tips/`} class="guide-link">Capture Tips guide</a>.
                </div>
              </div>
            </section>

            <!-- Section 4: Capture Guidelines for COLMAP -->
            <section id="capture-guidelines" class="guide-section">
              <h2 class="guide-section__title">Capture Guidelines for COLMAP</h2>
              
              <p class="guide-section__lead">
                The quality of your input images directly determines COLMAP's reconstruction accuracy. 
                Follow these essential guidelines for best results.
              </p>

              <h3>Essential Capture Settings</h3>
              <div class="guide-tips-grid">
                <div class="guide-tip-card">
                  <span class="guide-tip-card__number">1</span>
                  <p class="guide-tip-card__text"><strong>Scene Overlap:</strong> Maintain 60-80% overlap between consecutive images. This ensures COLMAP can find enough matching features.</p>
                </div>
                <div class="guide-tip-card">
                  <span class="guide-tip-card__number">2</span>
                  <p class="guide-tip-card__text"><strong>Image Count:</strong> Use 100-200 images for single objects, 200+ for larger scenes. More images improve accuracy but increase processing time.</p>
                </div>
                <div class="guide-tip-card">
                  <span class="guide-tip-card__number">3</span>
                  <p class="guide-tip-card__text"><strong>Lighting:</strong> Use soft, diffused, even lighting. Avoid harsh shadows, specular highlights, and changing light conditions.</p>
                </div>
              </div>

              <div class="guide-info-box">
                <div class="guide-info-box__icon" aria-hidden="true">
                  <svg class="bi" width="24" height="24">
                    <use href={`${base}static/bootstrap-icons.svg#book`}></use>
                  </svg>
                </div>
                <div class="guide-info-box__content">
                  <strong>Detailed Guide:</strong> For comprehensive capture techniques including camera settings, 
                  shooting patterns, and advanced tips, see our <a href={`${base}tutorials/capture-tips/`} class="guide-link">Capture Tips guide</a>.
                </div>
              </div>
            </section>

            <!-- Section 5: Installing COLMAP -->
            <section id="installing" class="guide-section">
              <h2 class="guide-section__title">Installing COLMAP</h2>
              
              <p class="guide-section__lead">
                COLMAP is a separate prerequisite tool that you must run independently 
                before using LichtFeld Studio. This section explains how to use external 
                COLMAP output with LFS for 3D Gaussian Splatting workflows.
              </p>

              <h3>Windows Installation</h3>
              <div class="guide-code-block">
                <pre><code># Download pre-built binaries from GitHub releases
# https://github.com/colmap/colmap/releases

# Extract the ZIP file and add to PATH, or use the portable version
# The installer includes both COLMAP GUI and command-line tools</code></pre>
                <button class="guide-code-block__copy" aria-label="Copy code to clipboard">
                  <svg class="bi" width="16" height="16">
                    <use href={`${base}static/bootstrap-icons.svg#clipboard`}></use>
                  </svg>
                </button>
              </div>

              <h3>Linux Installation (Ubuntu/Debian)</h3>
              <div class="guide-code-block">
                <pre><code># Install from package manager (may not be latest version)
sudo apt-get update
sudo apt-get install colmap

# Or build from source for latest features
# See: https://colmap.github.io/install.html</code></pre>
                <button class="guide-code-block__copy" aria-label="Copy code to clipboard">
                  <svg class="bi" width="16" height="16">
                    <use href={`${base}static/bootstrap-icons.svg#clipboard`}></use>
                  </svg>
                </button>
              </div>

              <h3>macOS Installation</h3>
              <div class="guide-code-block">
                <pre><code># Using Homebrew
brew install colmap

# Note: macOS builds may have limited CUDA support
# For full GPU acceleration, Linux or Windows is recommended</code></pre>
                <button class="guide-code-block__copy" aria-label="Copy code to clipboard">
                  <svg class="bi" width="16" height="16">
                    <use href={`${base}static/bootstrap-icons.svg#clipboard`}></use>
                  </svg>
                </button>
              </div>

              <div class="guide-info-box">
                <div class="guide-info-box__icon" aria-hidden="true">
                  <svg class="bi" width="24" height="24">
                    <use href={`${base}static/bootstrap-icons.svg#info-circle`}></use>
                  </svg>
                </div>
                <div class="guide-info-box__content">
                  <strong>External Tool Required:</strong> COLMAP is a separate application that you must 
                  run independently before using LichtFeld Studio. LFS does not include or automatically 
                  run COLMAP. Use COLMAP CLI, RealityScan, or similar SfM tools first, then import the 
                  output into LFS.
                </div>
              </div>

              <h3>COLMAP Tutorial</h3>
              <p>
                For a comprehensive walkthrough of COLMAP's features and workflows, refer to the 
                <a href="https://colmap.github.io/tutorial.html" target="_blank" rel="noopener noreferrer" class="guide-link">official COLMAP tutorial</a>. 
                It covers feature extraction, matching strategies, and advanced reconstruction options.
              </p>
            </section>

            <!-- Section 5: Using COLMAP with LichtFeld Studio -->
            <section id="lichtfeld" class="guide-section">
              <h2 class="guide-section__title">Using COLMAP with LichtFeld Studio</h2>
              
              <div class="guide-warning-box">
                <div class="guide-warning-box__icon" aria-hidden="true">
                  <svg class="bi" width="24" height="24">
                    <use href={`${base}static/bootstrap-icons.svg#exclamation-triangle`}></use>
                  </svg>
                </div>
                <div class="guide-warning-box__content">
                  <strong>Important Prerequisite:</strong> COLMAP is a <em>separate external tool</em> that you 
                  must run independently BEFORE using LichtFeld Studio. LFS does NOT include or automatically 
                  run COLMAP. You need to use COLMAP CLI, RealityScan, or similar photogrammetry tools first, 
                  then import the generated output (sparse/ folder with cameras.bin, images.bin, points3D.bin) 
                  into LFS.
                </div>
              </div>
              
              <p class="guide-section__lead">
                LichtFeld Studio works with existing COLMAP output to create 3D Gaussian Splats. 
                You must first run COLMAP externally using the tools below, then import the 
                resulting dataset into LFS.
              </p>

              <h3>Step-by-Step Workflow</h3>
              
              <div class="guide-steps">
                <div class="guide-step">
                  <span class="guide-step__number">1</span>
                  <div class="guide-step__content">
                    <h4>Run COLMAP Externally</h4>
                    <p>
                      Use one of these tools to process your images and generate COLMAP output:
                    </p>
                    <ul>
                      <li><strong>COLMAP CLI:</strong> Command-line tool for feature extraction, matching, and sparse reconstruction</li>
                      <li><strong>COLMAP GUI:</strong> Desktop application with visual interface</li>
                      <li><strong>RealityScan (Epic Games):</strong> Mobile/desktop photogrammetry app that exports COLMAP format</li>
                      <li><strong>Other SfM tools:</strong> Any tool that outputs COLMAP-compatible sparse reconstruction</li>
                    </ul>
                    <p>
                      Your output should include a <code>sparse/</code> folder containing 
                      <code>cameras.bin</code>, <code>images.bin</code>, and <code>points3D.bin</code>.
                    </p>
                  </div>
                </div>
                
                <div class="guide-step">
                  <span class="guide-step__number">2</span>
                  <div class="guide-step__content">
                    <h4>Import COLMAP Output into LFS</h4>
                    <p>
                      Launch LichtFeld Studio and import your existing COLMAP dataset. 
                      Click <kbd>Import</kbd> → <kbd>COLMAP Dataset</kbd> and select your 
                      dataset folder containing the <code>sparse/</code> folder and images.
                    </p>
                  </div>
                </div>
                
                <div class="guide-step">
                  <span class="guide-step__number">3</span>
                  <div class="guide-step__content">
                    <h4>Verify Camera Registration</h4>
                    <p>
                      Once imported, review the camera poses in the 3D viewer. Ensure all 
