  .pillar-card--core {
    --pillar-accent: 37, 99, 235;
  }

  .pillar-card--workspace {
    --pillar-accent: 8, 145, 178;
  }

  .pillar-card--automation {
    --pillar-accent: 194, 89, 37;
  }

  .pillar-card__header {
    display: flex;
    align-items: center;
    gap: 0.95rem;
    margin-bottom: 1rem;
  }

  .pillar-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 1rem;
    background: rgba(var(--pillar-accent), 0.1);
