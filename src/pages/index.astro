  }

  .hero__release-card-main {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    flex: 1;
  }

  .hero__release-icon {
    display: inline-flex;
    align-items: center;
