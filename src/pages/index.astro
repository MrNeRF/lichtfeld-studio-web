---
/**
 * index.astro
 *
 * Homepage for LichtFeld Studio website.
 * Features:
 * - Interactive 3D Gaussian Splatting demo in the hero section
 * - Workflow overview section
 */
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config/site.config";
import core11Logo from "@/assets/core11-logo.svg";
import gaussianSplatKingLogo from "@/assets/gaussian-splatking-logo.jpg";

import { SmartVideo } from "@alos-no/astro-media";
import Splat from "@/components/Splat.astro";
import BlogCard from "@/components/BlogCard.astro";
import { HOMEPAGE_MIN_VIEWPORT_VISIBILITY_FOR_RENDER } from "@/constants/splat-viewer";
import { ANALYTICS_EVENTS } from "@/utils/analytics";
import { withBase } from "@/utils/navigation";
import { getContributors, getLatestRelease, getRepoStats } from "@/services/github";

// Centralized external links (avoid magic strings):
import {
  DISCORD_URL,
  GAUSSIAN_SPLATKING_APP_STORE_URL,
  GITHUB_REPO_URL,
  LICHTFELD_PORTAL_URL,
  VOLINGA_URL,
} from "@/constants/project";

const base = import.meta.env.BASE_URL;
const volingaLogo = `${base}static/volinga-logo.png`;

/** Base-aware internal routes used by homepage sections. */
const ROUTES = {
  blog: withBase(base, "/blog/"),
  docs: withBase(base, "/docs/"),
  showcase: withBase(base, "/showcase/"),
  plugins: withBase(base, "/plugins/"),
  contribute: withBase(base, "/contribute/"),
} as const;

// Build-time project data: latest release, traction numbers, and recent posts.
// Every fetch degrades gracefully (null / 0 / []) so the page still builds
// without a GitHub token — dependent sections simply hide themselves.
const [latestRelease, contributors, repoStats] = await Promise.all([
  getLatestRelease(),
  getContributors(),
  getRepoStats(),
]);

const latestPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const compactNumber = new Intl.NumberFormat("en", { notation: "compact", maximumFractionDigits: 1 });

const stableWindowsVersion = latestRelease ? `v${latestRelease.version}` : "Latest build";

type TrustStat = { value: string; label: string; href: string; external?: boolean };
const trustStats: TrustStat[] = [
  repoStats && repoStats.stars > 0
    ? { value: compactNumber.format(repoStats.stars), label: "GitHub stars", href: GITHUB_REPO_URL, external: true }
    : null,
  contributors.length > 0
    ? { value: compactNumber.format(contributors.length), label: "Contributors", href: ROUTES.contribute }
    : null,
  latestRelease
    ? { value: `v${latestRelease.version}`, label: "Latest release", href: latestRelease.htmlUrl, external: true }
    : null,
].filter((stat): stat is TrustStat => stat !== null);
type SponsorWallEntry = {
  name: string;
  href: string;
  ariaLabel: string;
  logo?: string;
  logoClass?: string;
  lang?: string;
};

const sponsorWallGroups: Array<{ label: string; sponsors: SponsorWallEntry[] }> = [
  {
    label: "Foundational Sponsor",
    sponsors: [
      {
        name: "Core11",
        href: "https://www.core11.eu/",
        logo: core11Logo.src,
        ariaLabel: "Visit Core11 website",
      },
    ],
  },
  {
    label: "Gold",
    sponsors: [
      {
        name: "Volinga",
        href: VOLINGA_URL,
        logo: volingaLogo,
        logoClass: "portal-sponsors__logo--volinga",
        ariaLabel: "Visit Volinga website",
      },
    ],
  },
  {
    label: "Bronze",
    sponsors: [
      { name: "Opsiclear", href: "https://www.opsiclear.com/", ariaLabel: "Visit Opsiclear website" },
      { name: "Arcana Mfg.Co.,Ltd", href: "https://arcana-mfg.com/", ariaLabel: "Visit Arcana Mfg.Co.,Ltd website" },
      { name: "CGSLAB LLC.", href: "https://site.cgslab.info/", ariaLabel: "Visit CGSLAB LLC. website" },
      { name: "Alos Engineering", href: "https://alos.app/", ariaLabel: "Visit Alos Engineering website" },
      { name: "Yewth", href: "https://www.yewthstudios.com/", ariaLabel: "Visit Yewth website" },
      { name: "Vincent Woo", href: "https://vincentwoo.com/", ariaLabel: "Visit Vincent Woo website" },
      { name: "YUMA株式会社", href: "https://yuma.jp/", lang: "ja", ariaLabel: "YUMA株式会社のWebサイトを開く" },
      {
        name: "Arcturus Industries",
        href: "https://arcturus.industries/",
        ariaLabel: "Visit Arcturus Industries website",
      },
      { name: "steam-studio", href: "https://www.steam-studio.jp/", ariaLabel: "Visit steam-studio website" },
      {
        name: "Nakanihon Air Co., Ltd.",
        href: "https://www.nnk.co.jp/",
        ariaLabel: "Visit Nakanihon Air Co., Ltd. website",
      },
    ],
  },
];
const heroProofItems = ["Native 3DGS training", "Splat editing", "Python + MCP", "Windows & Linux", "GPLv3"];
const workflowSteps = [
  {
    title: "Train on a native core",
    description:
      "Run 3DGS pipelines on a C++23 and CUDA foundation with save-and-resume built into the same desktop workflow.",
    link: { href: ROUTES.docs, label: "Read the docs" },
  },
  {
    title: "Edit in context",
    description: "Brush, lasso, polygon, crop, align, and compose splats while working against the live scene.",
    link: { href: ROUTES.showcase, label: "See scenes in the gallery" },
  },
  {
    title: "Automate the workflow",
    description:
      "Use Python plugins and MCP endpoints to build custom panels, operators, batch tools, and external workflows.",
    link: { href: ROUTES.plugins, label: "Browse plugins" },
  },
];
const captureRecommendation = {
  eyebrow: "Optional capture tip",
  title: "Capturing on iPhone?",
  description:
    "Gaussian SplatKing captures 4K footage, optional LiDAR depth, and the media plus sensor data needed for reconstruction.",
  note: "Optional, lightweight iPhone capture front end before LichtFeld Studio.",
  highlights: ["iPhone only", "4K capture", "LiDAR-ready"],
  href: GAUSSIAN_SPLATKING_APP_STORE_URL,
  label: "View on the App Store",
};
// SEO metadata for the homepage.
// Keywords ("3D Gaussian Splatting", "3DGS") lead the title so the homepage
// ranks for those queries; the Seo component appends "| LichtFeld Studio".
const seoTitle = "Open-Source 3D Gaussian Splatting (3DGS) Software";
const seoDescription = SITE.description;
const seoImage = `${base}static/social-preview.png`;
const seoImageAlt = "LichtFeld Studio — open-source 3D Gaussian Splatting software";

// FAQ content targeting common 3DGS search queries.
// Rendered as visible page content and emitted as FAQPage JSON-LD below.
// `answer` is the plain-text form used in the JSON-LD; optional `answerHtml`
// carries inline links for the visible rendering only.
type FaqItem = { question: string; answer: string; answerHtml?: string };
const faqItems: FaqItem[] = [
  {
    question: "What is 3D Gaussian Splatting (3DGS)?",
    answer:
      "3D Gaussian Splatting is a technique for reconstructing photorealistic 3D scenes from ordinary photos or video. The scene is represented as millions of 3D Gaussians — splats — that rasterize in real time, making 3DGS a fast alternative to NeRF for radiance field rendering.",
  },
  {
    question: "Is LichtFeld Studio free?",
    answer:
      "LichtFeld Studio is open source under the GPLv3 license, so you can always build it for free from source on GitHub for Windows and Linux. The prebuilt Windows binary is available through the LichtFeld portal for a minimum contribution of $30, which funds ongoing development.",
    answerHtml: `LichtFeld Studio is open source under the GPLv3 license, so you can always build it for free from source on GitHub for Windows and Linux. The prebuilt Windows binary is available through the <a href="${LICHTFELD_PORTAL_URL}" target="_blank" rel="noopener noreferrer">LichtFeld portal</a> for a minimum contribution of $30, which funds ongoing development.`,
  },
  {
    question: "What hardware do I need to train Gaussian Splats?",
    answer:
      "Training runs locally on an NVIDIA GPU with compute capability 7.5 or newer and at least 8 GB of VRAM. The core is written in C++23 and CUDA for fast 3DGS training and real-time rendering.",
  },
  {
    question: "Can I edit and automate Gaussian Splat scenes?",
    answer:
      "Yes. LichtFeld Studio includes a full splat editing suite — brush, lasso, and polygon selection, cropping, alignment, and composition — plus Python plugins and MCP endpoints for automating 3DGS workflows.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
};
---

<Layout title={seoTitle} description={seoDescription} image={seoImage} imageAlt={seoImageAlt}>
  <!-- Big Splat Header (Hero) -->
  <header class="hero">
    <div class="hero__splat">
      <!-- The Splat canvas is the visual anchor in the header -->
      <div class="splat-wrapper">
        <Splat
          scene="botanics"
          style="--preview-blur-px: 7px;"
          progressPosition="bottom-center"
          progressOffsetY={50}
          controlScheme="none"
          minViewportVisibilityForRender={HOMEPAGE_MIN_VIEWPORT_VISIBILITY_FOR_RENDER}
          disableDriftOnMobile={true}
          trackFirstFrameAnalytics={false}
        />
      </div>
    </div>

    <!-- Value proposition and CTAs overlayed above the splat -->
    <div class="hero__content">
      <!-- Backdrop panel -->
      <div class="container content-frame px-4">
        <div
          class="hero__scene-cue"
          role="note"
          aria-label="Interactive scene. Click to switch to the next camera angle."
        >
          <span class="hero__scene-cue-label">
            <span class="hero__scene-cue-icon" aria-hidden="true">
              <svg class="bi" width="0.95em" height="0.95em">
                <use href={`${base}static/bootstrap-icons.svg#hand-index-thumb`}></use>
              </svg>
            </span>
            <span class="hero__scene-cue-copy">
              <span class="hero__scene-cue-title">Click scene</span>
              <span class="hero__scene-cue-subtitle">Jump to the next camera angle</span>
            </span>
          </span>
          <span class="hero__scene-cue-steps" aria-hidden="true">
            <span class="hero__scene-cue-step"></span>
            <span class="hero__scene-cue-step"></span>
            <span class="hero__scene-cue-step"></span>
          </span>
        </div>

        <div class="hero__stack">
          <!-- inner animated wrapper to avoid multiplying parent/child opacities -->
          <div class="hero__stack-content">
            <p class="hero__eyebrow">LichtFeld Studio</p>
            <h1 class="hero__title">Open-source 3D Gaussian Splatting, end to end</h1>
            <p class="hero__lead">
              Train, edit, and render photorealistic 3D scenes from photos or video — locally on your GPU, with Python
              plugins and MCP automation built in.
            </p>
            <p class="hero__facts">
              {heroProofItems.map((item) => <span class="hero__facts-item">{item}</span>)}
            </p>

            <div class="hero__actions">
              <div class="hero__release-actions">
                <a
                  class="btn btn-lg hero__release-card hero__release-card--stable"
                  href={LICHTFELD_PORTAL_URL}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Open the LichtFeld Studio download portal for Windows binaries"
                  data-analytics-event={ANALYTICS_EVENTS.ctaClicked}
                  data-analytics-prop-placement="home_hero"
                  data-analytics-prop-target="lichtfeld_portal"
                >
                  <span class="hero__release-card-main">
                    <span class="hero__release-icon" aria-hidden="true">
                      <i class="bi bi-windows"></i>
                    </span>
                    <span class="hero__release-copy">
                      <span class="hero__release-kicker">Windows Binary</span>
                      <span class="hero__release-title">Windows Build</span>
                      <span class="hero__release-meta">{stableWindowsVersion}</span>
                    </span>
                  </span>
                  <span class="hero__release-pill hero__release-pill--new">New</span>
                </a>
                <a
                  class="btn btn-lg hero__release-card hero__release-card--donate"
                  href={`${base}contribute/#support-the-project`}
                  aria-label="Support the project with a donation"
                  data-analytics-event={ANALYTICS_EVENTS.ctaClicked}
                  data-analytics-prop-placement="home_hero"
                  data-analytics-prop-target="donate"
                >
                  <span class="hero__release-card-main">
                    <span class="hero__release-icon hero__release-icon--donate" aria-hidden="true">
                      <i class="bi bi-heart"></i>
                    </span>
                    <span class="hero__release-copy">
                      <span class="hero__release-kicker">Support The Project</span>
                      <span class="hero__release-title">Donate</span>
                      <span class="hero__release-meta">Help fund development</span>
                    </span>
                  </span>
                </a>
                <a
                  class="btn btn-lg hero__release-card hero__release-card--source"
                  href={GITHUB_REPO_URL}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="View LichtFeld Studio source code on GitHub"
                  data-analytics-event={ANALYTICS_EVENTS.ctaClicked}
                  data-analytics-prop-placement="home_hero"
                  data-analytics-prop-target="github_repo"
                >
                  <span class="hero__release-card-main">
                    <span class="hero__release-icon hero__release-icon--source" aria-hidden="true">
                      <i class="bi bi-github"></i>
                    </span>
                    <span class="hero__release-copy">
                      <span class="hero__release-kicker">Open Source</span>
                      <span class="hero__release-title">Source Code</span>
                      <span class="hero__release-meta">View on GitHub</span>
                    </span>
                  </span>
                  <span class="hero__release-pill hero__release-pill--license" title="GNU General Public License v3.0">
                    GPLv3
                  </span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </header>

  {
    trustStats.length > 0 && (
      <section class="home-stats" aria-label="Project traction">
        <div class="container content-frame px-6">
          <ul class="home-stats__grid">
            {trustStats.map((stat) => (
              <li>
                <a
                  class="stat-block home-stats__item"
                  href={stat.href}
                  target={stat.external ? "_blank" : undefined}
                  rel={stat.external ? "noopener noreferrer" : undefined}
                  data-analytics-event={ANALYTICS_EVENTS.ctaClicked}
                  data-analytics-prop-placement="home_stats"
                  data-analytics-prop-target={stat.label}
                >
                  <strong>{stat.value}</strong>
                  <span>{stat.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <section id="workflow" class="story-section hash-section">
    <div class="container content-frame px-6 pt-14 pb-8">
      <div class="story-header-grid">
        <div class="story-copy">
          <p class="kicker mb-3">Workflow</p>
          <div class="section-heading">
            <h2 id="workflow-heading" class="story-title">From training run to finished scene in one app</h2>
            <a class="section-anchor" href="#workflow" aria-label="Link to workflow section">
              <svg class="bi" width="1em" height="1em" aria-hidden="true">
                <use href={`${base}static/bootstrap-icons.svg#link-45deg`}></use>
              </svg>
            </a>
          </div>
          <p class="story-lead">
            LichtFeld Studio brings training runs, live inspection, scene editing, plugins, and MCP control into one
            desktop workspace built around 3D Gaussian Splatting.
          </p>
          <p class="story-body">
            The same runtime handles compute, scene state, and tool extensions, so teams can work inside one consistent
            environment instead of maintaining a disconnected stack.
          </p>
        </div>

        <div class="story-media-panel">
          <div class="story-media">
            <div class="story-video-wrapper">
              <SmartVideo
                src={`${base}videos/meihogen-homepage`}
                poster={`${base}videos/meihogen-homepage-poster.jpg`}
                sizeStrategy="fill"
                fit="contain"
              />
            </div>
          </div>
          <p class="story-media__caption">
            The same application handles training output, scene editing, and live inspection.
          </p>
        </div>
      </div>

      <div class="story-steps" aria-label="Core workflow">
        {
          workflowSteps.map((step, index) => (
            <article class="story-step">
              <span class="story-step__index">0{index + 1}</span>
              <div>
                <h3 class="story-step__title">{step.title}</h3>
                <p class="story-step__desc">{step.description}</p>
                <a class="inline-link" href={step.link.href}>
                  {step.link.label}
                </a>
              </div>
            </article>
          ))
        }
      </div>

      <aside class="story-capture-tip" aria-labelledby="capture-tip-heading">
        <div class="story-capture-tip__copy">
          <div class="story-capture-tip__header">
            <img
              src={gaussianSplatKingLogo.src}
              alt="Gaussian SplatKing app icon"
              class="story-capture-tip__logo"
              width="56"
              height="56"
              loading="lazy"
              decoding="async"
            />
            <div class="story-capture-tip__heading">
              <p class="story-capture-tip__eyebrow">{captureRecommendation.eyebrow}</p>
              <h3 id="capture-tip-heading" class="story-capture-tip__title">{captureRecommendation.title}</h3>
            </div>
          </div>
          <p class="story-capture-tip__body">{captureRecommendation.description}</p>
          <p class="story-capture-tip__note">{captureRecommendation.note}</p>
        </div>

        <div class="story-capture-tip__footer">
          <div class="story-capture-tip__facts" aria-label="Capture recommendation highlights">
            {captureRecommendation.highlights.map((item) => <span class="story-capture-tip__fact">{item}</span>)}
          </div>
          <a
            class="section-link story-capture-tip__link"
            href={captureRecommendation.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View Gaussian SplatKing on the App Store"
            data-analytics-event={ANALYTICS_EVENTS.ctaClicked}
            data-analytics-prop-placement="home_capture_tip"
            data-analytics-prop-target="gaussian_splatking_app_store"
          >
            {captureRecommendation.label}
          </a>
        </div>
      </aside>
    </div>
  </section>

  {
    latestPosts.length > 0 && (
      <section id="whats-new" class="story-section hash-section" aria-labelledby="whats-new-heading">
        <div class="container content-frame px-6">
          <div class="section-head">
            <div>
              <p class="kicker mb-3">From the blog</p>
              <div class="section-heading">
                <h2 id="whats-new-heading" class="section-title">Latest from the project</h2>
                <a class="section-anchor" href="#whats-new" aria-label="Link to latest posts section">
                  <svg class="bi" width="1em" height="1em" aria-hidden="true">
                    <use href={`${base}static/bootstrap-icons.svg#link-45deg`} />
                  </svg>
                </a>
              </div>
            </div>
            <a class="section-link" href={ROUTES.blog}>
              Read the blog
            </a>
          </div>

          <div class="whats-new-grid">
            {latestPosts.map((post) => (
              <BlogCard post={post} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section id="about-3dgs" class="story-section hash-section" aria-labelledby="about-3dgs-heading">
    <div class="container content-frame px-6 pb-8">
      <div class="story-copy story-copy--wide">
        <p class="kicker mb-3">3D Gaussian Splatting</p>
        <div class="section-heading">
          <h2 id="about-3dgs-heading" class="story-title">What is 3D Gaussian Splatting?</h2>
          <a class="section-anchor" href="#about-3dgs" aria-label="Link to 3D Gaussian Splatting section">
            <svg class="bi" width="1em" height="1em" aria-hidden="true">
              <use href={`${base}static/bootstrap-icons.svg#link-45deg`}></use>
            </svg>
          </a>
        </div>
        <p class="story-lead">
          3D Gaussian Splatting (3DGS) turns ordinary photos and video into photorealistic 3D scenes that render in real
          time. LichtFeld Studio is a free, open-source Gaussian Splatting application that covers the whole workflow —
          training, editing, rendering, and automation — locally on your own GPU.
        </p>
        <p class="story-body">
          Instead of meshes or NeRF-style neural networks, a Gaussian Splat scene is built from millions of 3D Gaussians
          that rasterize in real time. That speed makes 3DGS a natural fit for scanning real places and objects, drone
          and aerial capture, virtual production, and interactive visualization.
        </p>
      </div>

      <dl class="faq-grid">
        {
          faqItems.map((item) => (
            <div class="faq-item">
              <dt class="faq-item__question">{item.question}</dt>
              {item.answerHtml ? (
                <dd class="faq-item__answer" set:html={item.answerHtml} />
              ) : (
                <dd class="faq-item__answer">{item.answer}</dd>
              )}
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- FAQPage structured data mirroring the visible FAQ above -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section id="community" class="story-section hash-section home-community" aria-labelledby="community-heading">
    <div class="container content-frame px-6">
      <p class="kicker mb-3">Community</p>
      <div class="section-heading">
        <h2 id="community-heading" class="section-title">Built in the open</h2>
        <a class="section-anchor" href="#community" aria-label="Link to community section">
          <svg class="bi" width="1em" height="1em" aria-hidden="true">
            <use href={`${base}static/bootstrap-icons.svg#link-45deg`}></use>
          </svg>
        </a>
      </div>
      <p class="section-copy home-community__copy">
        LichtFeld Studio is developed in public
        {contributors.length > 0 ? ` by ${contributors.length} contributors` : ""} under GPLv3. Development discussion,
        support, and scene sharing happen on Discord, and the contribution backlog is open to everyone.
      </p>
      <div class="home-community__actions">
        <a
          class="section-link"
          href={DISCORD_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-analytics-event={ANALYTICS_EVENTS.ctaClicked}
          data-analytics-prop-placement="home_community"
          data-analytics-prop-target="discord"
        >
          Join the Discord
        </a>
        <a class="section-link" href={ROUTES.contribute}>Start contributing</a>
      </div>
    </div>
  </section>

  <section class="sponsor-wall-section" aria-labelledby="portal-sponsors-heading">
    <div class="portal-sponsors container content-frame" id="portal-sponsors">
      <h2 id="portal-sponsors-heading" class="portal-sponsors__title">Sponsors</h2>

      {
        sponsorWallGroups.map((group) => (
          <div class="portal-sponsors__tier">
            <p class="portal-sponsors__label">{group.label}</p>
            <div class="portal-sponsors__row">
              {group.sponsors.map((sponsor) =>
                sponsor.logo ? (
                  <a
                    href={sponsor.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`portal-sponsors__logo ${sponsor.logoClass ?? ""}`.trim()}
                    aria-label={sponsor.ariaLabel}
                    data-analytics-outbound="sponsor"
                    data-analytics-placement="home_sponsors"
                    data-analytics-prop-sponsor={sponsor.name}
                  >
                    <img src={sponsor.logo} alt={sponsor.name} />
                  </a>
                ) : (
                  <a
                    href={sponsor.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="portal-sponsors__name"
                    lang={sponsor.lang}
                    aria-label={sponsor.ariaLabel}
                    data-analytics-outbound="sponsor"
                    data-analytics-placement="home_sponsors"
                    data-analytics-prop-sponsor={sponsor.name}
                  >
                    {sponsor.name}
                  </a>
                ),
              )}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="home-cta" aria-labelledby="home-cta-heading">
    <div class="container content-frame px-6">
      <div class="home-cta__inner">
        <div>
          <h2 id="home-cta-heading" class="home-cta__title">Get LichtFeld Studio</h2>
          <p class="home-cta__copy">
