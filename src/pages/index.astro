        </div>
        <div class="home-cta__actions">
          <a
            class="home-cta__primary"
            href={LICHTFELD_PORTAL_URL}
            target="_blank"
            rel="noopener noreferrer"
            data-analytics-event={ANALYTICS_EVENTS.ctaClicked}
            data-analytics-prop-placement="home_footer_cta"
            data-analytics-prop-target="lichtfeld_portal"
          >
