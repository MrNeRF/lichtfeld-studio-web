    text-align: center;
  }

  .portal-sponsors__title {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .portal-sponsors__tier {
    display: grid;
    gap: 1.4rem;
  }

  .portal-sponsors__label {
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--color-primary);
    font-size: 0.92rem;
    font-weight: 500;
  }

  .portal-sponsors__label::before,
  .portal-sponsors__label::after {
    content: "";
    flex: 1;
    max-width: 14rem;
    height: 1px;
    background: rgba(15, 23, 42, 0.16);
  }

  .portal-sponsors__row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1.75rem 3rem;
  }

  .portal-sponsors__logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 0.4rem;
    border-radius: 6px;
    opacity: 0.92;
    transition:
      opacity 0.18s ease,
      transform 0.18s ease;
  }

  .portal-sponsors__logo:hover {
    opacity: 1;
    transform: translateY(-1px);
  }

  .portal-sponsors__logo:focus-visible {
    outline: none;
    box-shadow: var(--focus-shadow);
  }

  .portal-sponsors__logo img {
    display: block;
    height: 2.5rem;
    max-width: 12rem;
    width: auto;
    object-fit: contain;
  }

  .portal-sponsors__logo--volinga img {
    width: min(100%, 75px);
    height: auto;
    max-width: none;
  }

  .portal-sponsors__name {
    font-size: 0.98rem;
    font-weight: 600;
    color: var(--color-heading);
