  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .pillar-card {
    --pillar-accent: 20, 87, 255;
    display: flex;
    flex-direction: column;
    min-height: 100%;
