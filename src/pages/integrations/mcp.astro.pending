              <!-- Workflow 3: Training Monitoring -->
              <div class="mcp-workflow">
                <h3 class="mcp-workflow__title">
                  <i class="bi bi-activity" aria-hidden="true"></i>
                  Workflow 3: Training Monitoring Dashboard
                </h3>
                <p class="mcp-workflow__desc">
                  Real-time training monitoring with automatic checkpointing when
                  loss plateaus and early stopping detection.
                </p>

                <div class="gs-code-block">
                  <pre><code>import asyncio
import requests
from collections import deque

class TrainingMonitor:
    def __init__(self, window_size=100):
        self.loss_history = deque(maxlen=window_size)
        self.best_loss = float('inf')
        self.plateau_count = 0

    async def monitor(self):
        """Monitor training with plateau detection."""

        # Connect to SSE stream
        import aiohttp

        async with aiohttp.ClientSession() as session:
            async with session.get(
                "http://localhost:8080/mcp/sse"
            ) as response:
                async for line in response.content:
                    if line.startswith(b"data: "):
                        data = json.loads(line[6:])

                        if data.get("resource") == "training/status":
                            status = data["data"]
                            await self._process_status(status)

    async def _process_status(self, status):
        """Process training status update."""

        iteration = status["iteration"]
        loss = status["loss"]
        self.loss_history.append(loss)

        # Track best loss
        if loss &lt; self.best_loss:
            self.best_loss = loss
            self.plateau_count = 0
        else:
            self.plateau_count += 1

        # Auto-checkpoint on improvement
        if loss &lt; self.best_loss * 0.99:
            requests.post(
                "http://localhost:8080/mcp/tools/training/export_checkpoint",
                json={"path": f"./checkpoints/auto_{iteration}.ckpt"}
            )
            print(f"Checkpoint saved at iteration {iteration}")

        # Early stopping detection
        if self.plateau_count > 500:
            print("Loss plateau detected. Consider adjusting learning rate.")

        # Print progress
        if iteration % 100 == 0:
            avg_loss = sum(self.loss_history) / len(self.loss_history)
            print(f"Iter {iteration}: Loss={loss:.6f}, Avg={avg_loss:.6f}")

if __name__ == "__main__":
    monitor = TrainingMonitor()
    asyncio.run(monitor.monitor())</code></pre>
