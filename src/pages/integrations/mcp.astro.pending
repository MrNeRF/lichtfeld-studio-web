---
/**
 * mcp.astro
 *
 * Integration guide for Model Context Protocol (MCP) with LichtFeld Studio.
 * Targets search queries: "lichtfeld studio mcp integration", "mcp server gaussian splatting",
 * "model context protocol tutorial"
 *
 * Features:
 * - Schema.org TechArticle structured data
 * - Technical documentation style with code blocks
 * - Step-by-step setup instructions
 * - Static HTML tables (no JSX mapping)
 * - Example workflows for automation
 * - Breadcrumb navigation
 */

import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config/site.config";
import {
  GITHUB_REPO_URL,
  GITHUB_WIKI_URL,
  DISCORD_URL,
  GITHUB_SPONSORS_URL,
  PAYPAL_URL,
  DONORBOX_URL,
} from "@/constants/project";

const base = import.meta.env.BASE_URL;

// SEO metadata
const seoTitle = "MCP Integration Guide: Control LichtFeld Studio Programmatically";
const seoDescription = "Complete guide to integrating LichtFeld Studio via Model Context Protocol. Setup, endpoints, examples, and best practices for automation.";

// Article metadata for Schema.org
const articlePublishedDate = new Date("2025-03-28");
const articleModifiedDate = new Date("2025-03-28");

// Build Schema.org TechArticle structured data
const techArticleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": seoTitle,
  "description": seoDescription,
  "image": new URL(base + "static/social-card.png", Astro.site).toString(),
  "author": {
    "@type": "Organization",
    "name": SITE.name,
    "url": SITE.url,
  },
  "publisher": {
    "@type": "Organization",
    "name": SITE.name,
    "logo": {
      "@type": "ImageObject",
      "url": new URL(base + "static/favicon.svg", Astro.site).toString(),
    },
  },
  "datePublished": articlePublishedDate.toISOString(),
  "dateModified": articleModifiedDate.toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, Astro.site).toString(),
  },
  "proficiencyLevel": "Intermediate",
  "dependencies": "LichtFeld Studio v0.5.0+, Python 3.10+",
};

// Breadcrumb schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": new URL(base, Astro.site).toString(),
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Integrations",
      "item": new URL(base + "integrations/", Astro.site).toString(),
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "MCP",
      "item": new URL(Astro.url.pathname, Astro.site).toString(),
    },
  ],
};
---

<Layout
  title={seoTitle}
  description={seoDescription}
  ogType="article"
>
  <!-- Schema.org Structured Data -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(techArticleSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="guide-page">
    <!-- Hero Section -->
    <header class="guide-hero guide-hero--mcp">
      <div class="container content-frame px-4">
        <div class="guide-hero__content">
          <nav class="guide-breadcrumb" aria-label="Breadcrumb">
            <ol class="guide-breadcrumb__list">
              <li class="guide-breadcrumb__item">
                <a href={base} class="guide-breadcrumb__link">Home</a>
              </li>
              <li class="guide-breadcrumb__item">
                <a href={base + "integrations/"} class="guide-breadcrumb__link">Integrations</a>
              </li>
              <li class="guide-breadcrumb__item" aria-current="page">
                <span>MCP</span>
              </li>
            </ol>
          </nav>

          <div class="mcp-hero__badge">
            <span class="mcp-badge">
              <i class="bi bi-command" aria-hidden="true"></i>
              Model Context Protocol
            </span>
          </div>

          <h1 class="guide-hero__title">MCP Integration Guide</h1>
          <p class="guide-hero__lead">
            Control <strong>LichtFeld Studio programmatically</strong> via the Model Context Protocol.
            Automate training runs, orchestrate camera sequences, build scene analysis pipelines,
            and integrate with AI assistants like Claude and Cursor.
          </p>

          <div class="guide-hero__meta">
            <span class="guide-hero__meta-item">
              <i class="bi bi-clock" aria-hidden="true"></i>
              15 min read
            </span>
            <span class="guide-hero__meta-item">
              <i class="bi bi-code-slash" aria-hidden="true"></i>
              Intermediate
            </span>
            <span class="guide-hero__meta-item">
              <i class="bi bi-lightning-charge" aria-hidden="true"></i>
              v0.5.0+
            </span>
          </div>

          <div class="mcp-hero__cta">
            <a href="#setup" class="btn btn-primary btn-lg">
              <i class="bi bi-rocket" aria-hidden="true"></i>
              Get Started
            </a>
            <a href={base + "features/mcp-automation/"} class="btn btn-outline-primary btn-lg">
              <i class="bi bi-stars" aria-hidden="true"></i>
              Feature Overview
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Table of Contents -->
    <nav class="guide-toc" aria-label="Table of contents">
      <div class="container content-frame px-4">
        <div class="guide-toc__shell shell shell--compact">
          <h2 class="guide-toc__title">Contents</h2>
          <ol class="guide-toc__list">
            <li><a href="#what-is-mcp" class="guide-toc__link">What is Model Context Protocol?</a></li>
            <li><a href="#prerequisites" class="guide-toc__link">Prerequisites</a></li>
            <li><a href="#setup" class="guide-toc__link">Setting Up MCP</a></li>
            <li><a href="#resources" class="guide-toc__link">Available Resources</a></li>
            <li><a href="#tools" class="guide-toc__link">Available Tools</a></li>
            <li><a href="#python-client" class="guide-toc__link">Python Client Example</a></li>
            <li><a href="#ai-assistants" class="guide-toc__link">Connecting AI Assistants</a></li>
            <li><a href="#workflows" class="guide-toc__link">Example Workflows</a></li>
            <li><a href="#api-reference" class="guide-toc__link">API Reference</a></li>
            <li><a href="#troubleshooting" class="guide-toc__link">Troubleshooting</a></li>
            <li><a href="#advanced" class="guide-toc__link">Advanced Topics</a></li>
          </ol>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <div class="guide-content">
      <div class="container content-frame px-4">
        <div class="guide-content__layout">
          <!-- Article Body -->
          <div class="guide-content__main">

            <!-- Section: What is MCP? -->
            <section id="what-is-mcp" class="guide-section">
              <h2 class="guide-section__title">What is Model Context Protocol?</h2>

              <p class="guide-section__lead">
                The <strong>Model Context Protocol (MCP)</strong> is an open standard for connecting AI assistants
                to external tools and data sources. Developed by Anthropic, MCP enables secure, structured
                communication between AI models and applications like LichtFeld Studio.
              </p>

              <p>
                Think of MCP as a "USB-C for AI applications"—a standardized way for AI assistants to discover
                capabilities, read data, and execute actions in external software. For LichtFeld Studio, this means
                you can:
              </p>

              <ul class="guide-list">
                <li><strong>Automate workflows</strong> — Script complex training and rendering pipelines</li>
                <li><strong>Integrate with AI assistants</strong> — Control the editor via Claude, Cursor, or other MCP-compatible AI</li>
                <li><strong>Build custom tools</strong> — Create Python scripts that orchestrate scene manipulation</li>
                <li><strong>Enable real-time monitoring</strong> — Stream training progress and scene updates to external systems</li>
              </ul>

              <div class="guide-info-box">
                <div class="guide-info-box__icon" aria-hidden="true">
                  <i class="bi bi-lightbulb"></i>
                </div>
                <div class="guide-info-box__content">
                  <strong>Key Concept:</strong> MCP separates <em>resources</em> (read-only data like scene info)
                  from <em>tools</em> (actions like camera movement). This clear separation makes it easy to
                  build safe, predictable automation workflows.
                </div>
              </div>

              <h3>How It Works</h3>
              <p>
                When LichtFeld Studio runs with MCP enabled, it exposes a local HTTP server (default: localhost:8080)
                that implements the MCP protocol. Clients can:
              </p>
              <ol class="guide-list guide-list--numbered">
                <li>Query available <strong>resources</strong> to read scene state, training progress, etc.</li>
                <li>Invoke <strong>tools</strong> to execute actions like camera moves or training commands</li>
                <li>Subscribe to <strong>SSE streams</strong> for real-time updates during long-running operations</li>
              </ol>
            </section>

            <!-- Section: Prerequisites -->
            <section id="prerequisites" class="guide-section">
              <h2 class="guide-section__title">Prerequisites</h2>

              <div class="guide-requirements">
                <div class="guide-requirement">
                  <h4><i class="bi bi-laptop" aria-hidden="true"></i> Software</h4>
                  <ul>
                    <li>LichtFeld Studio v0.5.0 or later</li>
                    <li>Python 3.10+ (for client scripts)</li>
                    <li><code>mcp</code> Python package</li>
                  </ul>
                </div>
                <div class="guide-requirement guide-requirement--recommended">
                  <h4><i class="bi bi-cpu" aria-hidden="true"></i> Optional</h4>
                  <ul>
                    <li>Claude Desktop or Cursor IDE</li>
                    <li>Familiarity with REST APIs</li>
                    <li>Basic Python knowledge</li>
                  </ul>
                </div>
              </div>

              <div class="mcp-install-box">
                <h4>Install MCP Python Package</h4>
                <div class="gs-code-block">
                  <pre><code>pip install mcp</code></pre>
                  <button class="gs-code-block__copy" aria-label="Copy to clipboard">
                    <i class="bi bi-clipboard" aria-hidden="true"></i>
                  </button>
                </div>
              </div>
            </section>

            <!-- Section: Setting Up MCP -->
            <section id="setup" class="guide-section">
              <h2 class="guide-section__title">Setting Up MCP in LichtFeld Studio</h2>

              <p class="guide-section__lead">
                Enabling MCP takes just a few clicks. Once activated, LichtFeld Studio exposes a local
                MCP server that accepts connections from authorized clients.
              </p>

              <h3>Step-by-Step Setup</h3>
              <ol class="guide-steps">
                <li class="guide-step">
                  <span class="guide-step__number">1</span>
                  <div class="guide-step__content">
                    <h4>Open Preferences</h4>
                    <p>Launch LichtFeld Studio and navigate to <kbd>Edit</kbd> → <kbd>Preferences</kbd> → <kbd>Integration</kbd>.</p>
                  </div>
                </li>
                <li class="guide-step">
                  <span class="guide-step__number">2</span>
                  <div class="guide-step__content">
                    <h4>Enable MCP Server</h4>
                    <p>Toggle the "Enable MCP Server" switch. The server will start automatically on the default port.</p>
                  </div>
                </li>
                <li class="guide-step">
                  <span class="guide-step__number">3</span>
                  <div class="guide-step__content">
                    <h4>Configure Port (Optional)</h4>
                    <p>Change the port if 8080 is in use. Note the server URL for client configuration.</p>
                  </div>
                </li>
                <li class="guide-step">
                  <span class="guide-step__number">4</span>
                  <div class="guide-step__content">
                    <h4>Verify Connection</h4>
                    <p>Test the server by visiting <code>http://localhost:8080/mcp/manifest</code> in your browser.</p>
                  </div>
                </li>
              </ol>

              <div class="gs-callout gs-callout--info">
                <span class="gs-callout__icon" aria-hidden="true">
                  <i class="bi bi-info-circle-fill"></i>
                </span>
                <div class="gs-callout__content">
                  <strong>Security Note:</strong> The MCP server only binds to localhost (127.0.0.1) by default,
                  preventing external network access. This ensures your scene data stays local and secure.
                </div>
              </div>

              <h3>Configuration File</h3>
              <p>
                Advanced users can configure MCP via the settings file located at:
              </p>
              <div class="gs-code-block">
                <pre><code># Windows
%APPDATA%\LichtFeldStudio\mcp.json

# Linux
~/.config/LichtFeldStudio/mcp.json</code></pre>
                <button class="gs-code-block__copy" aria-label="Copy to clipboard">
                  <i class="bi bi-clipboard" aria-hidden="true"></i>
                </button>
              </div>
            </section>

            <!-- Section: Available Resources -->
            <section id="resources" class="guide-section">
              <h2 class="guide-section__title">Available MCP Resources</h2>

              <p class="guide-section__lead">
                Resources provide read-only access to LichtFeld Studio's internal state. Query these endpoints
                to monitor scenes, training progress, and editor state.
              </p>

              <div class="mcp-table-wrapper">
                <table class="mcp-table">
                  <thead>
                    <tr>
                      <th>Resource Name</th>
                      <th>Description</th>
                      <th>Type</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>
                        <code class="mcp-code">scene/info</code>
                        <button class="mcp-copy-btn" data-copy="scene/info" aria-label="Copy scene/info">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Current scene metadata including splat count, bounds, and camera position</td>
                      <td><span class="mcp-type">JSON</span></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">scene/cameras</code>
                        <button class="mcp-copy-btn" data-copy="scene/cameras" aria-label="Copy scene/cameras">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>List of all cameras in the scene with transforms and parameters</td>
                      <td><span class="mcp-type">JSON</span></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">training/status</code>
                        <button class="mcp-copy-btn" data-copy="training/status" aria-label="Copy training/status">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Real-time training progress, loss curves, and iteration count</td>
                      <td><span class="mcp-type">JSON</span></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">training/checkpoints</code>
                        <button class="mcp-copy-btn" data-copy="training/checkpoints" aria-label="Copy training/checkpoints">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Available training checkpoints with timestamps and metrics</td>
                      <td><span class="mcp-type">JSON</span></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">editor/selection</code>
                        <button class="mcp-copy-btn" data-copy="editor/selection" aria-label="Copy editor/selection">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Currently selected splats and selection statistics</td>
                      <td><span class="mcp-type">JSON</span></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">render/viewport</code>
                        <button class="mcp-copy-btn" data-copy="render/viewport" aria-label="Copy render/viewport">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Current viewport screenshot as base64 PNG</td>
                      <td><span class="mcp-type">Base64 Image</span></td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <h3>Example: Reading Scene Info</h3>
              <div class="gs-code-block">
                <pre><code>import requests

# Read scene information
response = requests.get("http://localhost:8080/mcp/resources/scene/info")
scene_info = response.json()

print(f"Splats: {scene_info['splat_count']}")
print(f"Bounds: {scene_info['bounds']}")
print(f"Camera: {scene_info['camera_position']}")</code></pre>
                <button class="gs-code-block__copy" aria-label="Copy to clipboard">
                  <i class="bi bi-clipboard" aria-hidden="true"></i>
                </button>
              </div>
            </section>

            <!-- Section: Available Tools -->
            <section id="tools" class="guide-section">
              <h2 class="guide-section__title">Available MCP Tools</h2>

              <p class="guide-section__lead">
                Tools are actions that modify the editor state, control the camera, manage training,
                or manipulate scenes. All tool invocations are synchronous and return results immediately.
              </p>

              <div class="mcp-table-wrapper mcp-table-wrapper--tools">
                <table class="mcp-table">
                  <thead>
                    <tr>
                      <th>Tool Name</th>
                      <th>Description</th>
                      <th>Parameters</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>
                        <code class="mcp-code">camera/set_position</code>
                        <button class="mcp-copy-btn" data-copy="camera/set_position" aria-label="Copy camera/set_position">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Move camera to specified position and orientation</td>
                      <td><code class="mcp-params">position: Vec3, rotation: Quat, fov?: float</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">camera/animate</code>
                        <button class="mcp-copy-btn" data-copy="camera/animate" aria-label="Copy camera/animate">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Animate camera along keyframes with easing</td>
                      <td><code class="mcp-params">keyframes: CameraKey[], duration: float, easing?: string</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">training/start</code>
                        <button class="mcp-copy-btn" data-copy="training/start" aria-label="Copy training/start">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Start a new training run with specified parameters</td>
                      <td><code class="mcp-params">iterations: int, learning_rate?: float, densify?: bool</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">training/pause</code>
                        <button class="mcp-copy-btn" data-copy="training/pause" aria-label="Copy training/pause">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Pause or resume current training</td>
                      <td><code class="mcp-params">resume: bool</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">training/export_checkpoint</code>
                        <button class="mcp-copy-btn" data-copy="training/export_checkpoint" aria-label="Copy training/export_checkpoint">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Export current training state to checkpoint file</td>
                      <td><code class="mcp-params">path: string, include_optimizer?: bool</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">editor/select_brush</code>
                        <button class="mcp-copy-btn" data-copy="editor/select_brush" aria-label="Copy editor/select_brush">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Select splats using brush tool at screen coordinates</td>
                      <td><code class="mcp-params">x: int, y: int, radius: int, mode: 'add'|'remove'|'toggle'</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">editor/select_lasso</code>
                        <button class="mcp-copy-btn" data-copy="editor/select_lasso" aria-label="Copy editor/select_lasso">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Select splats using lasso/polygon selection</td>
                      <td><code class="mcp-params">points: Vec2[], mode: 'add'|'remove'|'toggle'</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">editor/delete_selection</code>
                        <button class="mcp-copy-btn" data-copy="editor/delete_selection" aria-label="Copy editor/delete_selection">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Delete currently selected splats</td>
                      <td><code class="mcp-params">confirm?: bool</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">editor/crop_to_selection</code>
                        <button class="mcp-copy-btn" data-copy="editor/crop_to_selection" aria-label="Copy editor/crop_to_selection">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Crop scene to current selection bounds</td>
                      <td><code class="mcp-params">padding?: float</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">render/set_mode</code>
                        <button class="mcp-copy-btn" data-copy="render/set_mode" aria-label="Copy render/set_mode">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Change render mode (RGB, depth, normal, etc.)</td>
                      <td><code class="mcp-params">mode: 'rgb'|'depth'|'normal'|'shading'</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">render/capture_frame</code>
                        <button class="mcp-copy-btn" data-copy="render/capture_frame" aria-label="Copy render/capture_frame">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Capture high-resolution render to file</td>
                      <td><code class="mcp-params">path: string, resolution?: Vec2, samples?: int</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">scene/load</code>
                        <button class="mcp-copy-btn" data-copy="scene/load" aria-label="Copy scene/load">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Load a scene from PLY or project file</td>
                      <td><code class="mcp-params">path: string, options?: LoadOptions</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">scene/save</code>
                        <button class="mcp-copy-btn" data-copy="scene/save" aria-label="Copy scene/save">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Save current scene to file</td>
                      <td><code class="mcp-params">path: string, format: 'ply'|'splat'|'lfproj'</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">sequencer/add_keyframe</code>
                        <button class="mcp-copy-btn" data-copy="sequencer/add_keyframe" aria-label="Copy sequencer/add_keyframe">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Add keyframe to animation sequencer</td>
                      <td><code class="mcp-params">time: float, camera: CameraState, properties?: object</code></td>
                    </tr>
                    <tr>
                      <td>
                        <code class="mcp-code">sequencer/render_sequence</code>
                        <button class="mcp-copy-btn" data-copy="sequencer/render_sequence" aria-label="Copy sequencer/render_sequence">
                          <i class="bi bi-clipboard" aria-hidden="true"></i>
                        </button>
                      </td>
                      <td>Render animation sequence to video frames</td>
                      <td><code class="mcp-params">output_dir: string, fps: int, quality?: string</code></td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <h3>Example: Camera Animation</h3>
              <div class="gs-code-block">
                <pre><code>import requests

# Animate camera around the scene
response = requests.post(
    "http://localhost:8080/mcp/tools/camera/animate",
    json={
        "keyframes": [
            {"position": [5, 2, 5], "rotation": [0, 0.785, 0], "time": 0},
            {"position": [0, 3, 7], "rotation": [0, 0, 0], "time": 2},
            {"position": [-5, 2, 5], "rotation": [0, -0.785, 0], "time": 4},
        ],
        "duration": 4.0,
        "easing": "ease_in_out"
    }
)

print(f"Animation started: {response.json()['success']}")</code></pre>
                <button class="gs-code-block__copy" aria-label="Copy to clipboard">
                  <i class="bi bi-clipboard" aria-hidden="true"></i>
