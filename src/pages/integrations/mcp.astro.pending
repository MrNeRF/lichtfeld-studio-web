            <!-- Section: Python Client -->
            <section id="python-client" class="guide-section">
              <h2 class="guide-section__title">Python Client Example</h2>

              <p class="guide-section__lead">
                The official <code>mcp</code> Python package provides a high-level client for interacting
                with LichtFeld Studio. Here's a complete example for common workflows.
              </p>

              <h3>Basic Client Setup</h3>
              <div class="gs-code-block">
                <pre><code>from mcp import ClientSession, StdioServerParameters
from mcp.client.stdio import stdio_client
import asyncio

async def main():
    # Connect to LichtFeld Studio MCP server
    server_params = StdioServerParameters(
        command="python",
        args=["-m", "mcp.server.http", "--url", "http://localhost:8080"]
    )

    async with stdio_client(server_params) as (read, write):
        async with ClientSession(read, write) as session:
            # Initialize connection
            await session.initialize()

            # List available resources and tools
            resources = await session.list_resources()
            tools = await session.list_tools()

            print(f"Available resources: {len(resources)}")
            print(f"Available tools: {len(tools)}")

            # Read scene info
            scene_data = await session.read_resource("scene/info")
            print(f"Scene: {scene_data}")

            # Execute a tool
            result = await session.call_tool(
                "camera/set_position",
                arguments={"position": [0, 2, 5], "rotation": [0, 0, 0]}
            )
            print(f"Camera moved: {result}")

if __name__ == "__main__":
    asyncio.run(main())</code></pre>
                <button class="gs-code-block__copy" aria-label="Copy to clipboard">
                  <i class="bi bi-clipboard" aria-hidden="true"></i>
                </button>
              </div>

              <h3>Training Automation Script</h3>
              <div class="gs-code-block">
                <pre><code>import asyncio
from mcp import ClientSession
from mcp.client.sse import sse_client

async def training_workflow():
    """Automated training with progress monitoring."""

    async with sse_client("http://localhost:8080/mcp/sse") as streams:
        async with ClientSession(*streams) as session:
            await session.initialize()

            # Start training
            print("Starting training...")
            await session.call_tool(
                "training/start",
                arguments={"iterations": 30000, "learning_rate": 0.01}
            )

            # Monitor progress via SSE
            async for message in session.receive_messages():
                if message.type == "resource_updated":
                    if message.resource == "training/status":
                        status = message.data
                        print(f"Iteration {status['iteration']}/{status['total']}")
                        print(f"Loss: {status['loss']:.6f}")

                        if status['completed']:
                            print("Training complete!")
                            break

            # Export checkpoint
            await session.call_tool(
                "training/export_checkpoint",
                arguments={"path": "./checkpoints/final.ckpt"}
            )

if __name__ == "__main__":
    asyncio.run(training_workflow())</code></pre>
                <button class="gs-code-block__copy" aria-label="Copy to clipboard">
