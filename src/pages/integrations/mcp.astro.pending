              <!-- Workflow 1: Render Sequence -->
              <div class="mcp-workflow">
                <h3 class="mcp-workflow__title">
                  <i class="bi bi-film" aria-hidden="true"></i>
                  Workflow 1: Render Sequence Automation
                </h3>
                <p class="mcp-workflow__desc">
                  Automatically render a camera fly-through animation with multiple keyframes
                  and export frames for video composition.
                </p>

                <div class="gs-code-block">
                  <pre><code>import asyncio
import requests
from pathlib import Path

async def render_sequence():
    """Render a cinematic camera sequence."""

    output_dir = Path("./render_output")
    output_dir.mkdir(exist_ok=True)

    # Define camera path
    keyframes = [
        {"time": 0.0, "position": [10, 5, 10], "rotation": [0, 0.785, 0], "fov": 60},
        {"time": 2.0, "position": [5, 3, 8], "rotation": [0, 0.5, 0], "fov": 55},
        {"time": 4.0, "position": [0, 2, 6], "rotation": [0, 0, 0], "fov": 50},
        {"time": 6.0, "position": [-5, 3, 8], "rotation": [0, -0.5, 0], "fov": 55},
        {"time": 8.0, "position": [-10, 5, 10], "rotation": [0, -0.785, 0], "fov": 60},
    ]

    # Add keyframes to sequencer
    for kf in keyframes:
        requests.post(
            "http://localhost:8080/mcp/tools/sequencer/add_keyframe",
            json=kf
        )

    # Render sequence at 30fps
    response = requests.post(
        "http://localhost:8080/mcp/tools/sequencer/render_sequence",
        json={
            "output_dir": str(output_dir),
            "fps": 30,
            "quality": "high"
        }
    )

    result = response.json()
    print(f"Rendered {result['frame_count']} frames to {output_dir}")
    print(f"Duration: {result['duration_seconds']:.2f}s")

if __name__ == "__main__":
    asyncio.run(render_sequence())</code></pre>
