              <!-- Workflow 2: Scene Analysis -->
              <div class="mcp-workflow">
                <h3 class="mcp-workflow__title">
                  <i class="bi bi-search" aria-hidden="true"></i>
                  Workflow 2: Scene Analysis Pipeline
                </h3>
                <p class="mcp-workflow__desc">
                  Analyze scene quality, detect artifacts, and generate a report with
                  recommended cleanup actions.
                </p>

                <div class="gs-code-block">
                  <pre><code>import requests
import json
from datetime import datetime

def analyze_scene():
    """Analyze scene quality and generate report."""

    report = {
        "timestamp": datetime.now().isoformat(),
        "scene_analysis": {},
        "recommendations": []
    }

    # Get scene info
    scene = requests.get(
        "http://localhost:8080/mcp/resources/scene/info"
    ).json()

    report["scene_analysis"] = {
        "splat_count": scene["splat_count"],
        "bounds": scene["bounds"],
        "density": scene["splat_count"] / scene["bounds_volume"]
    }

    # Capture viewport for visual analysis
    viewport = requests.get(
        "http://localhost:8080/mcp/resources/render/viewport"
    ).json()

    # Check for common issues
    if scene["splat_count"] &lt; 100000:
        report["recommendations"].append({
            "type": "warning",
            "message": "Low splat count may indicate incomplete training",
            "action": "training/continue"
        })

    if scene["bounds"]["y_max"] > 50:
        report["recommendations"].append({
            "type": "cleanup",
            "message": "Floating artifacts detected above scene",
            "action": "editor/select_brush",
            "params": {"y_threshold": 10}
        })

    # Save report
    with open("scene_analysis.json", "w") as f:
        json.dump(report, f, indent=2)

    print(f"Analysis complete. {len(report['recommendations'])} recommendations.")
    return report

if __name__ == "__main__":
    analyze_scene()</code></pre>
