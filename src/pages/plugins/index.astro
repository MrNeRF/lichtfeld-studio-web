---
import Layout from "@/layouts/Layout.astro";
import PluginCard from "@/components/plugins/PluginCard.astro";
import { getPluginRegistry } from "@/services/plugin-registry";
import { GITHUB_REPO_URL } from "@/constants/project";

const plugins = await getPluginRegistry();

const seoTitle = "Plugins";
const seoDescription =
  "Browse the LichtFeld Studio plugin registry: Python plugins for training workflows, scene tools, VR viewing, measurement, and automation.";
---

<Layout title={seoTitle} description={seoDescription}>
  <section class="plugins-page">
    <div class="container content-frame px-4 py-5">
      <div class="shell plugins-shell--hero">
        <p class="kicker">Plugin registry</p>
        <h1 class="plugins-title">Python plugins for LichtFeld Studio</h1>
        <p class="plugins-lead">
          The plugin registry turns LichtFeld Studio into an extensible desktop platform. Install compatible plugins,
          keep dependencies isolated per plugin, and extend the app with panels, operators, tools, overlays, and
          workflow-specific capabilities.
        </p>

        <div class="plugins-stats">
          <div class="stat-block">
            <strong>Install in-app</strong>
            <span>Plugins are meant to be discovered and installed through the marketplace.</span>
          </div>
          <div class="stat-block">
            <strong>Compatibility-aware</strong>
            <span>Registry versions can be matched against LichtFeld and plugin API versions.</span>
          </div>
          <div class="stat-block">
            <strong>Plugin-local deps</strong>
            <span>Each plugin can carry its own Python dependencies without polluting the host.</span>
          </div>
          <div class="stat-block">
            <strong>Panels, operators, tools</strong>
            <span>Extend the UI, workflow logic, scene tools, and automation surface.</span>
          </div>
        </div>
      </div>

      <div class="shell mt-4">
        <div class="section-head">
          <div>
            <p class="kicker mb-2">Registry-backed listing</p>
            <h2 class="section-title mb-2">Browse the current plugin catalog</h2>
            <p class="section-copy mb-0">
              These entries are seeded from the LichtFeld Studio plugin ecosystem and structured around the real
              registry contract used by the application.
            </p>
          </div>
          <a
            href={`${GITHUB_REPO_URL}/tree/master/docs/plugins`}
            target="_blank"
            rel="noopener noreferrer"
            class="section-link"
          >
            Plugin docs
          </a>
        </div>

        <div class="plugins-grid mt-4">
          {plugins.map((plugin) => <PluginCard plugin={plugin} />)}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .plugins-page {
    background: var(--page-bg);
  }

  .plugins-shell--hero {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: 2.8rem;
    align-items: start;
  }

  .plugins-shell--hero > .kicker,
  .plugins-shell--hero > .plugins-title,
  .plugins-shell--hero > .plugins-lead {
    grid-column: 1;
  }

  .plugins-title {
    margin: 0 0 0.9rem;
    color: var(--color-heading);
    font-size: clamp(2.6rem, 5vw, 4.2rem);
    line-height: 0.96;
    max-width: 10ch;
  }

  .plugins-lead {
    margin: 0;
    color: #344054;
    font-size: 1.06rem;
    line-height: 1.76;
    max-width: 42rem;
  }

  .plugins-stats {
    grid-column: 2;
    grid-row: 1 / span 3;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.4rem;
    margin-top: 0;
  }

  .plugins-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 991.98px) {
    .plugins-shell--hero {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .plugins-title,
    .plugins-lead,
    .plugins-stats {
      grid-column: 1;
    }

    .plugins-stats {
      grid-row: auto;
      margin-top: 0.25rem;
    }

    .plugins-stats,
    .plugins-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 575.98px) {
    .plugins-title {
      max-width: 12ch;
      font-size: clamp(2.15rem, 10vw, 3rem);
    }

    .plugins-lead {
      font-size: 0.98rem;
      line-height: 1.7;
    }
  }
</style>
