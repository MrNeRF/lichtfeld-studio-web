---
/**
 * statistics.astro
 *
 * Download statistics dashboard for LichtFeld Studio.
 * Showcases download metrics, growth trends, and release breakdowns
 * to demonstrate project traction for investors and users.
 *
 * Features:
 * - Key metric cards (total downloads, this month, latest release)
 * - Stacked area chart showing downloads by version
 * - Line chart showing cumulative growth
 * - Release breakdown table
 * - Contributors wall
 */
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config/site.config";

// Stats components
import StatCard from "@/components/stats/StatCard.astro";
import TimeRangeSelector from "@/components/stats/TimeRangeSelector.astro";
import StackedAreaChart from "@/components/stats/StackedAreaChart.astro";
import StackedBarChart from "@/components/stats/StackedBarChart.astro";
import PieChart from "@/components/stats/PieChart.astro";
import ReleaseTable from "@/components/stats/ReleaseTable.astro";

// Reuse contributors wall from homepage
import ContributorsWall from "@/components/contribute/ContributorsWall.astro";

// SEO metadata
const seoTitle = `Download Statistics | ${SITE.name}`;
const seoDescription =
  "Daily download statistics and growth metrics for LichtFeld Studio. Track releases, monitor adoption, and review the current release breakdown.";
---

<Layout title={seoTitle} description={seoDescription}>
  <!-- Hero Section with Key Metrics -->
  <section class="stats-hero">
    <div class="container content-frame px-4 py-5">
      <div class="stats-shell shell shell--spacious">
        <div class="stats-hero__header">
          <p class="kicker">Statistics</p>
          <h1 class="stats-hero__title">Download Statistics</h1>
          <p class="stats-hero__subtitle">Daily metrics showing LichtFeld Studio adoption and release momentum</p>
        </div>

        <!-- Key Metric Cards -->
        <div class="stats-cards">
          <StatCard label="Total Downloads" icon="bi-download" loading={true} />
          <StatCard label="Last 30 Days" icon="bi-calendar-range" loading={true} />
          <StatCard label="Latest Release" icon="bi-tag" loading={true} />
          <StatCard label="Active Releases" icon="bi-collection" loading={true} />
        </div>
      </div>
    </div>
  </section>

  <!-- Charts Row 1: Downloads by Version + Cumulative -->
  <section class="container content-frame px-4 py-4">
    <div class="stats-shell shell shell--spacious">
      <div class="stats-section__header">
        <h2 class="stats-section__title">Download Trends</h2>
        <div class="stats-controls">
          <div class="chart-type-toggle" role="group" aria-label="Chart type">
            <button
              type="button"
              class="chart-type-toggle__button chart-type-toggle__button--active"
              data-chart-type="bar"
              title="Bar chart"
            >
              <i class="bi bi-bar-chart-fill"></i>
            </button>
            <button type="button" class="chart-type-toggle__button" data-chart-type="area" title="Area chart">
              <i class="bi bi-graph-up"></i>
            </button>
          </div>
          <TimeRangeSelector selected="daily" id="main-chart-range" />
        </div>
      </div>

      <div class="stats-grid">
        <div class="stats-grid__item">
          <div data-chart-slot="cumulative-bar">
            <StackedBarChart id="cumulative-bar" height={380} title="Cumulative Downloads" />
          </div>
          <div data-chart-slot="cumulative-area" style="display: none;">
            <StackedAreaChart id="cumulative-area" height={380} title="Cumulative Downloads" />
          </div>
        </div>

        <div class="stats-grid__item">
          <div data-chart-slot="downloads-bar">
            <StackedBarChart id="downloads-bar" height={380} title="Downloads by Day" />
          </div>
          <div data-chart-slot="downloads-area" style="display: none;">
            <StackedAreaChart id="downloads-area" height={380} title="Downloads by Day" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Charts Row 2: Version Adoption + Release Table -->
  <section class="container content-frame px-4 py-4">
    <div class="stats-shell shell shell--spacious">
      <div class="stats-grid">
        <div class="stats-grid__item">
          <PieChart id="adoption-chart" height={380} title="Version Adoption" />
        </div>

        <div class="stats-grid__item">
          <ReleaseTable title="Release Breakdown" />
        </div>
      </div>
    </div>
  </section>

  <!-- Data Attribution -->
  <section class="container content-frame px-4 py-3">
    <div class="stats-shell stats-shell--compact shell shell--compact">
      <p class="stats-attribution">
        <i class="bi bi-info-circle"></i>
        Statistics are updated hourly and reflect download counts from GitHub releases. Data shown is as of <span
          id="stats-as-of"
        >
          loading...
        </span>
      </p>
    </div>
  </section>

  <!-- Contributors Section -->
  <section class="stats-contributors">
    <ContributorsWall title="Our Growing Community" />
  </section>
</Layout>

<script>
  /**
   * Client-side data fetching and chart initialization.
   * Fetches stats from the API and dispatches events to components.
   */

  /**
   * API response types.
   */
  interface StatsResponse {
    asOf: string;
    totals: {
      allTime: number;
    };
    releases: Array<{
      tag: string;
      name: string;
      downloads: number;
      publishedAt: number | null;
      daily: Array<{ date: number; downloads: number }>;
      weekly: Array<{ week: number; downloads: number }>;
      monthly: Array<{ month: number; downloads: number }>;
    }>;
  }

  /**
   * Chart data point structure.
   */
  interface ChartDataPoint {
    x: number;
    y: number;
  }

  /**
   * Chart series structure.
   */
  interface ChartSeries {
    name: string;
    data: ChartDataPoint[];
  }

  /**
   * Current time range selection.
   */
  type TimeRange = "daily" | "weekly" | "monthly";

  /**
   * Chart display type: bar or area (line).
   */
  type ChartType = "bar" | "area";

  let currentRange: TimeRange = "daily";
  let currentChartType: ChartType = "bar";
  let statsData: StatsResponse | null = null;

  /**
   * One day in milliseconds.
   */
  const ONE_DAY_MS = 24 * 60 * 60 * 1000;

  /**
   * Interpolates missing daily data points by distributing values evenly across gaps.
   * When data collection misses one or more days, this function fills in the gaps
   * with linearly interpolated cumulative values.
   *
   * @param dailyData - Array of daily cumulative snapshots (must be sorted by date ascending)
   * @returns Array with interpolated data points filling any gaps
   */
  function interpolateMissingDays(
    dailyData: Array<{ date: number; downloads: number }>,
  ): Array<{ date: number; downloads: number }> {
    if (dailyData.length < 2) return dailyData;

    const result: Array<{ date: number; downloads: number }> = [];

    for (let i = 0; i < dailyData.length; i++) {
      const current = dailyData[i];

      result.push(current);

      // Check if there's a next point
      if (i < dailyData.length - 1) {
        const next = dailyData[i + 1];
        const daysBetween = Math.round((next.date - current.date) / ONE_DAY_MS);

        // If there's a gap of more than 1 day, interpolate
        if (daysBetween > 1) {
          const downloadsDelta = next.downloads - current.downloads;
          const dailyIncrement = downloadsDelta / daysBetween;

          // Insert interpolated points for each missing day
          for (let j = 1; j < daysBetween; j++) {
            const interpolatedDate = current.date + j * ONE_DAY_MS;
            const interpolatedDownloads = Math.round(current.downloads + dailyIncrement * j);

            result.push({
              date: interpolatedDate,
              downloads: interpolatedDownloads,
            });
          }
        }
      }
    }

    return result;
  }

  /**
   * Formats a number with locale-aware separators.
   */
  function formatNumber(num: number): string {
    return new Intl.NumberFormat().format(num);
  }

  /**
   * Updates a StatCard with a new value.
   */
  function updateStatCard(index: number, value: number): void {
    const cards = document.querySelectorAll(".stat-card");
    const card = cards[index];

    if (!card) return;

    // Remove loading state
    card.classList.remove("stat-card--loading");

    // Update value
    const valueEl = card.querySelector(".stat-card__value");

    if (valueEl) {
      valueEl.innerHTML = formatNumber(value);
    }
  }

  /**
   * Parses a version string (e.g., "v1.2.3") into comparable numeric parts.
   */
  function parseVersion(tag: string): number[] {
    if (tag === "nightly") return [Infinity, 0, 0];

    const match = tag.match(/v?(\d+)\.(\d+)\.(\d+)/);

    if (!match) return [0, 0, 0];

    return [parseInt(match[1]), parseInt(match[2]), parseInt(match[3])];
  }

  /**
   * Compares two version arrays. Returns negative if a < b, positive if a > b, 0 if equal.
   */
  function compareVersions(a: number[], b: number[]): number {
    for (let i = 0; i < 3; i++) {
      if (a[i] !== b[i]) {
        return a[i] - b[i];
      }
    }

    return 0;
  }

  /**
   * Finds the first day currently covered by the daily snapshots.
   */
  function getDailyWindowStart(releases: StatsResponse["releases"]): number | null {
    let earliest = Infinity;

    releases.forEach((release) => {
      release.daily.forEach((point) => {
        earliest = Math.min(earliest, point.date);
      });
    });

    return Number.isFinite(earliest) ? earliest : null;
  }

  /**
   * Normalizes a timestamp to the start of its UTC week or month.
   */
  function getPeriodStart(timestamp: number, range: Exclude<TimeRange, "daily">): number {
    const date = new Date(timestamp);

    date.setUTCHours(0, 0, 0, 0);

    if (range === "weekly") {
      const day = date.getUTCDay();
      const diff = day === 0 ? 6 : day - 1;

      date.setUTCDate(date.getUTCDate() - diff);

      return date.getTime();
    }

    date.setUTCDate(1);

    return date.getTime();
  }

  /**
   * Converts daily cumulative snapshots into per-day deltas.
   *
   * The first daily snapshot for a release published within the visible window
   * must count as real downloads, otherwise new releases appear to lose their
   * initial download burst in the charts.
   */
  function buildDailyDeltaMap(
    release: StatsResponse["releases"][number],
    dailyWindowStart: number | null,
  ): Map<number, number> {
    const deltaMap = new Map<number, number>();
    const sorted = [...release.daily].sort((a, b) => a.date - b.date);
    const interpolated = interpolateMissingDays(sorted);

    if (interpolated.length === 0) {
      return deltaMap;
    }

    const releaseStartsWithinWindow =
      dailyWindowStart !== null && release.publishedAt !== null && release.publishedAt >= dailyWindowStart;

    interpolated.forEach((point, index) => {
      if (index === 0) {
        deltaMap.set(point.date, releaseStartsWithinWindow ? point.downloads : 0);

        return;
      }

      const previousPoint = interpolated[index - 1];
      const delta = Math.max(0, point.downloads - previousPoint.downloads);

      deltaMap.set(point.date, delta);
    });

    return deltaMap;
  }

  /**
   * Returns period deltas for the requested range.
   *
   * Weekly/monthly aggregates from the backend can undercount the first bucket
   * of a new release, so the recent buckets are rebuilt from daily snapshots
   * and replace overlapping aggregated buckets.
   */
  function getPeriodDeltas(
    release: StatsResponse["releases"][number],
    range: TimeRange,
    dailyWindowStart: number | null,
  ): Array<{ x: number; y: number }> {
    if (range === "daily") {
      return [...buildDailyDeltaMap(release, dailyWindowStart).entries()]
        .sort((a, b) => a[0] - b[0])
        .map(([x, y]) => ({ x, y }));
    }

    const sourcePoints =
      range === "weekly"
        ? release.weekly.map((point) => ({ x: point.week, y: point.downloads }))
        : release.monthly.map((point) => ({ x: point.month, y: point.downloads }));

    const rebuiltBuckets = new Map<number, number>();

    buildDailyDeltaMap(release, dailyWindowStart).forEach((downloads, date) => {
      const bucketStart = getPeriodStart(date, range);

      rebuiltBuckets.set(bucketStart, (rebuiltBuckets.get(bucketStart) ?? 0) + downloads);
    });

    const rebuiltStart = rebuiltBuckets.size > 0 ? Math.min(...rebuiltBuckets.keys()) : null;
    const mergedPoints = new Map<number, number>();

    sourcePoints.forEach((point) => {
      if (rebuiltStart !== null && point.x >= rebuiltStart) {
        return;
      }

      mergedPoints.set(point.x, point.y);
    });

    rebuiltBuckets.forEach((downloads, bucketStart) => {
      mergedPoints.set(bucketStart, downloads);
    });

    return [...mergedPoints.entries()]
      .sort((a, b) => a[0] - b[0])
      .map(([x, y]) => ({ x, y }));
  }

  /**
   * Transforms release data into chart series format showing DELTAS (new downloads per period).
   * Sorts releases so older versions are at the bottom of the stack
   * and newer versions are at the top (latest on top).
   * All series are aligned to the same set of x values so stacked bars render correctly.
   *
   * Note: Daily data is stored as cumulative snapshots, so we calculate deltas.
   * Weekly/monthly data is already stored as deltas.
   */
  function transformToChartSeries(releases: StatsResponse["releases"], range: TimeRange): ChartSeries[] {
    // Sort releases by version: older first (bottom of stack), newer last (top of stack)
    const sortedReleases = [...releases].sort((a, b) => {
      const versionA = parseVersion(a.tag);
      const versionB = parseVersion(b.tag);

      return compareVersions(versionA, versionB);
    });

    const dailyWindowStart = getDailyWindowStart(releases);

    // Build per-release delta maps and collect all unique x values
    const allXValues = new Set<number>();
    const releaseMaps: Map<number, number>[] = [];

    sortedReleases.forEach((release) => {
      const deltaMap = new Map<number, number>();

      getPeriodDeltas(release, range, dailyWindowStart).forEach((point) => {
        deltaMap.set(point.x, point.y);
        allXValues.add(point.x);
      });

      releaseMaps.push(deltaMap);
    });

    // Align all series to the same sorted x values, filling gaps with 0
    const sortedXValues = [...allXValues].sort((a, b) => a - b);

    return sortedReleases.map((release, i) => {
      const deltaMap = releaseMaps[i];

      return {
        name: release.tag,
        data: sortedXValues.map((x) => ({ x, y: deltaMap.get(x) ?? 0 })),
      };
    });
  }

  /**
   * Transforms release data into cumulative growth series.
   * Shows how total downloads have grown over time (monotonically increasing).
   * Sorts releases so older versions are at the bottom and newer versions are on top.
   * All series are aligned to the same set of x-values so stacked areas render correctly.
   *
   * Note: Daily data is already cumulative snapshots, so we use it directly.
   * Weekly/monthly data is stored as deltas, so we accumulate them.
   */
  function transformToCumulativeSeries(releases: StatsResponse["releases"], range: TimeRange): ChartSeries[] {
    // Sort releases by version: older first (bottom of stack), newer last (top of stack)
    const sortedReleases = [...releases].sort((a, b) => {
      const versionA = parseVersion(a.tag);
      const versionB = parseVersion(b.tag);

      return compareVersions(versionA, versionB);
    });

    const limitedReleases = sortedReleases.slice(-5);
    const dailyWindowStart = getDailyWindowStart(releases);

    // Build per-release cumulative maps and collect all unique x-values
    const allXValues = new Set<number>();
    const releaseMaps: Map<number, number>[] = [];

    limitedReleases.forEach((release) => {
      const map = new Map<number, number>();

      if (range === "daily") {
        // Daily data is already cumulative snapshots
        const sorted = [...release.daily].sort((a, b) => a.date - b.date);
        const interpolated = interpolateMissingDays(sorted);

        interpolated.forEach((d) => {
          map.set(d.date, d.downloads);
          allXValues.add(d.date);
        });
      } else {
        // Weekly/monthly data is stored as period deltas.
        const deltas = getPeriodDeltas(release, range, dailyWindowStart);
        let cumulative = 0;

        deltas.forEach((point) => {
          cumulative += point.y;
          map.set(point.x, cumulative);
          allXValues.add(point.x);
        });
      }

      releaseMaps.push(map);
    });

    // Align all series to the same sorted x-values
    const sortedXValues = [...allXValues].sort((a, b) => a - b);

    return limitedReleases.map((release, i) => {
      const map = releaseMaps[i];

      // Track the last known value for carry-forward.
      // Starts at 0 so dates before a release's first data point stay at 0.
      let lastKnownValue = 0;

      const data: ChartDataPoint[] = sortedXValues.map((x) => {
        const value = map.get(x);

        if (value !== undefined) {
          lastKnownValue = value;

          return { x, y: value };
        }

        // No data for this x-value:
        // - Before the release started → lastKnownValue is still 0
        // - After the last data point → carry forward the last cumulative value
        return { x, y: lastKnownValue };
      });

      return { name: release.tag, data };
    });
  }

  /**
   * Maps time range to display label for chart title.
   */
  const RANGE_LABELS: Record<TimeRange, string> = {
    daily: "Day",
    weekly: "Week",
    monthly: "Month",
  };

  /**
   * Toggles chart slot visibility based on chart type.
   * Shows the matching slot and hides the other for a given chart pair.
   */
  function setChartSlotVisibility(chartType: ChartType): void {
    const barTypes = ["bar", "area"] as const;

    barTypes.forEach((type) => {
      // Toggle cumulative chart slots
      const cumulativeSlot = document.querySelector(`[data-chart-slot="cumulative-${type}"]`) as HTMLElement | null;

      if (cumulativeSlot) {
        cumulativeSlot.style.display = type === chartType ? "" : "none";
      }

      // Toggle downloads chart slots
      const downloadsSlot = document.querySelector(`[data-chart-slot="downloads-${type}"]`) as HTMLElement | null;

      if (downloadsSlot) {
        downloadsSlot.style.display = type === chartType ? "" : "none";
      }
    });
  }

  /**
   * Updates all charts with data for the specified range.
   * Dispatches data to the currently visible chart type.
   */
  function updateCharts(range: TimeRange): void {
    if (!statsData) return;

    // Chart IDs based on current chart type
    const downloadsId = `downloads-${currentChartType}`;
    const cumulativeId = `cumulative-${currentChartType}`;

    // Determine the parent CSS class for title lookup
    const parentClass = currentChartType === "bar" ? "stacked-bar-chart" : "stacked-area-chart";

    // Update downloads chart title based on range
    const downloadsChartTitle = document
      .querySelector(`[data-chart-id='${downloadsId}']`)
      ?.closest(`.${parentClass}`)
      ?.querySelector(`.${parentClass}__title`);

    if (downloadsChartTitle) {
      downloadsChartTitle.textContent = `Downloads by ${RANGE_LABELS[range]}`;
    }

    // Update downloads chart
    const downloadsChart = document.querySelector(`[data-chart-id='${downloadsId}']`);

    if (downloadsChart) {
      const series = transformToChartSeries(statsData.releases, range);
      const event = new CustomEvent("chartdata", {
        detail: { series, granularity: range },
      });

      downloadsChart.dispatchEvent(event);
    }

    // Update cumulative chart
    const cumulativeChart = document.querySelector(`[data-chart-id='${cumulativeId}']`);

    if (cumulativeChart) {
      const series = transformToCumulativeSeries(statsData.releases, range);
      const event = new CustomEvent("chartdata", {
        detail: { series, granularity: range },
      });

      cumulativeChart.dispatchEvent(event);
    }
  }

  /**
   * Handles chart type toggle.
   * Switches visibility and re-dispatches data to the new chart type.
   */
  function handleChartTypeChange(chartType: ChartType): void {
    if (chartType === currentChartType) return;

    currentChartType = chartType;

    // Update toggle button active state
    const toggleButtons = document.querySelectorAll(".chart-type-toggle__button");

    toggleButtons.forEach((btn) => {
      const type = (btn as HTMLElement).dataset.chartType;

      btn.classList.toggle("chart-type-toggle__button--active", type === chartType);
    });

    // Switch visible chart slots
    setChartSlotVisibility(chartType);

    // Re-dispatch data to the newly visible charts
    updateCharts(currentRange);
  }

  /**
   * Updates the release table with data.
   */
  function updateReleaseTable(): void {
    if (!statsData) return;

    const table = document.querySelector(".release-table");

    if (table) {
      const event = new CustomEvent("tabledata", {
        detail: {
          releases: statsData.releases,
          totalDownloads: statsData.totals.allTime,
        },
      });

      table.dispatchEvent(event);
    }
  }

  /**
   * Updates the version adoption pie chart.
   */
  function updateAdoptionChart(): void {
    if (!statsData) return;

    const pieChart = document.querySelector("[data-chart-id='adoption-chart']");

    if (pieChart) {
      // Sort releases by version (newest first for display)
      const sortedReleases = [...statsData.releases].sort((a, b) => {
        const versionA = parseVersion(a.tag);
        const versionB = parseVersion(b.tag);

        return compareVersions(versionB, versionA);
      });

      const labels = sortedReleases.map((r) => r.tag);
      const values = sortedReleases.map((r) => r.downloads);

      const event = new CustomEvent("chartdata", {
        detail: { labels, values },
      });

      pieChart.dispatchEvent(event);
    }
  }

  /**
   * Gets total downloads for the last 30 days.
   * Calculates from daily cumulative data by finding the difference
   * between the latest value and the value from ~30 days ago.
   */
  function getLast30DaysDownloads(releases: StatsResponse["releases"]): number {
    const now = Date.now();
    const thirtyDaysAgo = now - 30 * ONE_DAY_MS;

    let total = 0;

    releases.forEach((release) => {
      if (release.daily.length < 1) return;

      // Sort by date ascending
      const sorted = [...release.daily].sort((a, b) => a.date - b.date);

      // Get the latest cumulative value
      const latestValue = sorted[sorted.length - 1].downloads;

      // Find the value closest to 30 days ago (but not after it)
      let valueThirtyDaysAgo = 0;
      let foundDataPoint = false;

      for (let i = sorted.length - 1; i >= 0; i--) {
        if (sorted[i].date <= thirtyDaysAgo) {
          valueThirtyDaysAgo = sorted[i].downloads;
          foundDataPoint = true;
          break;
        }
      }

      // If no data point before 30 days ago
      if (!foundDataPoint) {
        // If the release was published within the last 30 days, all downloads are within this period
        if (release.publishedAt && release.publishedAt > thirtyDaysAgo) {
          valueThirtyDaysAgo = 0; // No downloads before the release existed
        } else {
          // Release is older than 30 days but we don't have data going back that far
          // Use the earliest available data point as a conservative estimate
          valueThirtyDaysAgo = sorted[0].downloads;
        }
      }

      total += latestValue - valueThirtyDaysAgo;
    });

    return total;
  }

  /**
   * Returns the stats API URL based on environment.
   * Uses production API on localhost for development with real data.
   */
  function getStatsApiUrl(): string {
    const isLocalhost = window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1";

    return isLocalhost ? "https://lichtfeld.io/api/stats" : "/api/stats";
  }

  /**
   * Fetches stats data and initializes the dashboard.
   */
  async function initDashboard(): Promise<void> {
    try {
      // Fetch stats from API (uses production API on localhost)
      const response = await fetch(getStatsApiUrl());

      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }

      statsData = (await response.json()) as StatsResponse;

      // Update stat cards
      updateStatCard(0, statsData.totals.allTime);
      updateStatCard(1, getLast30DaysDownloads(statsData.releases));

      // Latest release downloads (find by highest semver, excluding nightly)
      const taggedReleases = statsData.releases.filter((r) => r.tag !== "nightly");

      if (taggedReleases.length > 0) {
        const latestRelease = taggedReleases.reduce((latest, current) => {
          const latestVersion = parseVersion(latest.tag);
          const currentVersion = parseVersion(current.tag);

          return compareVersions(currentVersion, latestVersion) > 0 ? current : latest;
        }, taggedReleases[0]);

        updateStatCard(2, latestRelease.downloads);
      }

      // Active releases count
      updateStatCard(3, statsData.releases.length);

      // Update "as of" date
      const asOfEl = document.getElementById("stats-as-of");

      if (asOfEl) {
        asOfEl.textContent = new Date(statsData.asOf).toLocaleDateString(undefined, {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
      }

      // Initialize charts with default range
      updateCharts(currentRange);

      // Update release table
      updateReleaseTable();

      // Update adoption pie chart
      updateAdoptionChart();
    } catch (error) {
      console.error("Failed to fetch stats:", error);

      // Show error state
      const cards = document.querySelectorAll(".stat-card");

      cards.forEach((card) => {
        card.classList.remove("stat-card--loading");

        const valueEl = card.querySelector(".stat-card__value");

        if (valueEl) {
          valueEl.textContent = "—";
        }
      });
    }
  }

  /**
   * Handles range change events from the TimeRangeSelector.
   */
  function handleRangeChange(event: CustomEvent): void {
    const { range } = event.detail;

    currentRange = range as TimeRange;
    updateCharts(currentRange);
  }

  // Initialize on DOM ready
  document.addEventListener("DOMContentLoaded", () => {
    initDashboard();

    // Listen for range changes
    document.addEventListener("rangechange", handleRangeChange as EventListener);

    // Listen for chart type toggle clicks
    const toggleButtons = document.querySelectorAll(".chart-type-toggle__button");

    toggleButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const chartType = (btn as HTMLElement).dataset.chartType as ChartType;

        if (chartType) {
          handleChartTypeChange(chartType);
        }
      });
    });
  });
</script>

