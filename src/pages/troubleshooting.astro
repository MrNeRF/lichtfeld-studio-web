    cta: "Join Discord"
  },
  {
    title: "GitHub Issues",
    description: "Report bugs and request features",
    icon: "bi-github",
    href: `${GITHUB_REPO_URL}/issues`,
    external: true,
    cta: "Open Issue"
  },
  {
    title: "Documentation",
    description: "Comprehensive guides and API reference",
    icon: "bi-book",
    href: "/docs/",
    external: false,
    cta: "Read Docs"
  },
  {
    title: "FAQ",
    description: "Answers to common questions",
    icon: "bi-question-circle",
    href: "/faq/",
    external: false,
    cta: "View FAQ"
  }
];

// Flatten all issues for search and structured data
const allIssues = [
  ...problemCategories.flatMap(cat => cat.issues.map(issue => ({ ...issue, category: cat.title }))),
  ...featuredIssues.map(issue => ({ ...issue, category: "Featured" }))
];

// Generate Schema.org FAQPage structured data
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": allIssues.map(item => ({
    "@type": "Question",
    "name": item.title,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": typeof item.solution === 'string' 
        ? item.solution.replace(/<[^>]*>/g, '').substring(0, 500)
        : item.description || item.title
    }
  }))
};
---

<Layout title={seoTitle} description={seoDescription}>
  {/* Schema.org structured data */}
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  
  <section class="troubleshooting-page">
    <div class="container content-frame px-4 py-5">
      {/* Hero Section */}
      <div class="shell troubleshooting-hero">
        <p class="kicker">Support Center</p>
        <h1 class="troubleshooting-title">Troubleshooting Guide</h1>
        <p class="troubleshooting-lead">
          Find solutions to common LichtFeld Studio and 3D Gaussian Splatting issues. 
          From scene explosions to CUDA errors - we've got you covered.
        </p>
        
        {/* Search Bar */}
        <div class="troubleshooting-search">
          <div class="search-input-wrapper">
            <i class="bi bi-search search-icon"></i>
            <input 
              type="text" 
              id="troubleshooting-search" 
              class="search-input" 
              placeholder="Search issues... (e.g., 'explode', 'CUDA', 'slow', 'memory')"
              autocomplete="off"
            />
            <button id="search-clear" class="search-clear hidden" aria-label="Clear search">
              <i class="bi bi-x-lg"></i>
            </button>
          </div>
          <p class="search-hint">
            <i class="bi bi-lightbulb"></i>
            Popular: 
            <span class="search-tag" data-term="explode">scene explodes</span>,
            <span class="search-tag" data-term="cuda">CUDA error</span>,
            <span class="search-tag" data-term="memory">out of memory</span>,
            <span class="search-tag" data-term="slow">slow training</span>
          </p>
        </div>
      </div>
      
      {/* Quick Diagnostics */}
      <section class="shell diagnostics-section" id="diagnostics">
        <div class="diagnostics-header">
          <div class="diagnostics-icon">
            <i class="bi bi-activity"></i>
          </div>
          <div class="diagnostics-title-wrap">
            <h2 class="diagnostics-title">Quick Diagnostics</h2>
            <p class="diagnostics-subtitle">Run these checks to identify common problems</p>
          </div>
        </div>
        
        <div class="diagnostics-grid">
          <div class="diagnostic-card">
            <div class="diagnostic-header">
              <i class="bi bi-gpu-card"></i>
              <span class="diagnostic-name">CUDA Check</span>
            </div>
            <code class="diagnostic-command">nvidia-smi</code>
            <p class="diagnostic-expected">Should show GPU name, driver version, and processes</p>
          </div>
          
          <div class="diagnostic-card">
            <div class="diagnostic-header">
              <i class="bi bi-memory"></i>
              <span class="diagnostic-name">VRAM Check</span>
            </div>
            <code class="diagnostic-command">nvidia-smi --query-gpu=memory.used,memory.total --format=csv</code>
            <p class="diagnostic-expected">Should show available VRAM on NVIDIA GPU (need 6GB+)</p>
          </div>
          
          <div class="diagnostic-card">
            <div class="diagnostic-header">
              <i class="bi bi-cpu"></i>
              <span class="diagnostic-name">CUDA Check</span>
            </div>
            <code class="diagnostic-command">nvidia-smi</code>
            <p class="diagnostic-expected">Should show GPU name, driver version, and processes</p>
          </div>
          
          <div class="diagnostic-card">
            <div class="diagnostic-header">
              <i class="bi bi-thermometer-half"></i>
              <span class="diagnostic-name">GPU Temperature</span>
            </div>
            <code class="diagnostic-command">nvidia-smi --query-gpu=temperature.gpu --format=csv</code>
            <p class="diagnostic-expected">Should be under 85°C during training</p>
          </div>
        </div>
        
        <div class="diagnostics-note">
          <i class="bi bi-info-circle"></i>
          <p>If any check fails, follow the corresponding solution in the sections below.</p>
        </div>
      </section>
      
      {/* Featured Issues */}
      <section class="featured-issues" id="featured">
        <h2 class="section-title">Common Problems</h2>
        <p class="section-subtitle">Detailed solutions for frequently encountered issues</p>
        
        <div class="featured-grid">
          {featuredIssues.map(issue => (
            <article class="featured-card" data-keywords={issue.keywords.join(',')} id={issue.id}>
              <div class="featured-header">
                <div class="featured-icon">
                  <i class={`bi ${issue.icon}`}></i>
                </div>
                <div class="featured-meta">
                  <span class={`severity-badge ${issue.severity.class}`}>
                    <i class={`bi ${issue.severity.icon}`}></i>
                    {issue.severity.label}
                  </span>
                </div>
              </div>
              
              <h3 class="featured-title">{issue.title}</h3>
              <p class="featured-description">{issue.description}</p>
              
              <div class="featured-causes">
                <h4><i class="bi bi-exclamation-circle"></i> Common Causes</h4>
                <ul>
                  {issue.causes.map(cause => (
                    <li>{cause}</li>
                  ))}
                </ul>
              </div>
              
              <div class="featured-solutions">
                <h4><i class="bi bi-wrench"></i> Step-by-Step Fix</h4>
                <ol class="solution-steps">
                  {issue.solutions.map(sol => (
                    <li class="solution-step">
                      <span class="step-number">{sol.step}</span>
                      <div class="step-content">
                        <strong>{sol.title}</strong>
                        <p>{sol.detail}</p>
                      </div>
                    </li>
                  ))}
                </ol>
              </div>
              
              <div class="featured-prevention">
                <i class="bi bi-shield-check"></i>
                <p><strong>Prevention:</strong> {issue.prevention}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
      
      {/* Problem Categories */}
      <section class="problem-categories" id="categories">
        <h2 class="section-title">Issue Categories</h2>
        <p class="section-subtitle">Browse all troubleshooting topics</p>
        
        <div class="categories-accordion">
          {problemCategories.map((category, catIndex) => (
            <div class="category-section shell" data-category={category.id} id={category.id}>
              <button 
                class="category-header-accordion" 
                aria-expanded="false"
                aria-controls={`category-content-${catIndex}`}
              >
                <div class="category-header-main">
                  <div class="category-icon-wrap">
                    <i class={`bi ${category.icon}`}></i>
                  </div>
                  <div class="category-header-text">
                    <h3 class="category-name">{category.title}</h3>
                    <p class="category-description">{category.description}</p>
                  </div>
                </div>
                <div class="category-header-meta">
                  <span class="issue-count">{category.issues.length} issues</span>
                  <i class="bi bi-chevron-down category-toggle"></i>
                </div>
              </button>
              
              <div class="category-content" id={`category-content-${catIndex}`}>
                <div class="issues-list">
                  {category.issues.map((issue, issueIndex) => (
                    <div 
                      class="issue-item" 
                      data-keywords={issue.keywords.join(',')}
                      data-title={issue.title.toLowerCase()}
                    >
                      <button 
                        class="issue-header"
                        aria-expanded="false"
                        aria-controls={`issue-solution-${catIndex}-${issueIndex}`}
                      >
                        <div class="issue-title-wrap">
                          <span class={`severity-indicator ${issue.severity.class}`} title={issue.severity.label}>
                            <i class={`bi ${issue.severity.icon}`}></i>
                          </span>
                          <span class="issue-title-text">{issue.title}</span>
                        </div>
                        <i class="bi bi-chevron-down issue-toggle"></i>
                      </button>
                      
                      <div class="issue-solution" id={`issue-solution-${catIndex}-${issueIndex}`}>
                        <div class="solution-inner">
                          {issue.symptoms && (
                            <div class="symptoms-block">
                              <h4><i class="bi bi-bug"></i> Symptoms</h4>
                              <ul>
                                {issue.symptoms.map(symptom => (
                                  <li><code>{symptom}</code></li>
                                ))}
                              </ul>
                            </div>
                          )}
                          <div class="solution-block">
                            <h4><i class="bi bi-wrench"></i> Solution</h4>
                            <div class="solution-content" set:html={issue.solution} />
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
      
      {/* No Results Message */}
      <div id="no-results" class="no-results hidden">
        <div class="shell no-results-content">
          <i class="bi bi-search"></i>
          <h3>No matching issues found</h3>
          <p>Try different keywords or browse the categories above.</p>
          <div class="no-results-suggestions">
            <p>Popular searches:</p>
            <div class="suggestion-tags">
              <button class="suggestion-tag" data-term="cuda">CUDA</button>
              <button class="suggestion-tag" data-term="memory">memory</button>
              <button class="suggestion-tag" data-term="slow">slow</button>
              <button class="suggestion-tag" data-term="export">export</button>
            </div>
          </div>
          <button id="clear-search-btn" class="section-link">Clear search</button>
        </div>
      </div>
      
      {/* Bug Report Checklist */}
      <section class="shell checklist-section" id="checklist">
        <div class="checklist-header">
          <i class="bi bi-clipboard-check"></i>
          <div>
            <h2 class="checklist-title">Before Reporting a Bug</h2>
            <p class="checklist-subtitle">Complete this checklist to ensure your report is effective</p>
          </div>
        </div>
        
        <div class="checklist-grid">
          {bugChecklist.map(item => (
            <label class="checklist-item">
              <input type="checkbox" class="checklist-checkbox" data-check={item.id} />
              <span class="checklist-checkmark">
                <i class={`bi ${item.icon}`}></i>
              </span>
              <span class="checklist-label-text">{item.label}</span>
            </label>
          ))}
        </div>
        
        <div class="checklist-actions">
          <a href={`${GITHUB_REPO_URL}/issues/new`} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Report Issue
          </a>
          <button id="reset-checklist" class="btn btn-secondary">
            <i class="bi bi-arrow-counterclockwise"></i>
            Reset Checklist
          </button>
        </div>
        
        <div class="checklist-tip">
          <i class="bi bi-lightbulb"></i>
          <p><strong>Tip:</strong> Include your GPU model, driver version, LFS version, and a minimal reproduction case in your bug report.</p>
        </div>
      </section>
      
      {/* Getting Help */}
      <section class="help-section" id="help">
        <h2 class="section-title">Still Need Help?</h2>
        <p class="section-subtitle">Connect with the community and get support</p>
        
        <div class="help-grid">
          {helpResources.map(resource => (
            <a 
              href={resource.href} 
              target={resource.external ? "_blank" : undefined}
              rel={resource.external ? "noopener noreferrer" : undefined}
              class="help-card"
            >
              <div class="help-icon">
                <i class={`bi ${resource.icon}`}></i>
              </div>
              <div class="help-content">
                <h3 class="help-title">{resource.title}</h3>
                <p class="help-description">{resource.description}</p>
                <span class="help-cta">
                  {resource.cta}
                  {resource.external && <i class="bi bi-arrow-up-right"></i>}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
      
      {/* Related Links */}
      <section class="related-links">
        <h3 class="related-title">Related Resources</h3>
        <div class="links-grid">
          <a href="/faq/" class="link-card">
            <i class="bi bi-question-circle"></i>
            <span>FAQ</span>
          </a>
          <a href="/getting-started/" class="link-card">
            <i class="bi bi-rocket"></i>
            <span>Getting Started</span>
          </a>
          <a href="/docs/" class="link-card">
            <i class="bi bi-book"></i>
            <span>Documentation</span>
          </a>
          <a href="/plugins/" class="link-card">
            <i class="bi bi-puzzle"></i>
            <span>Plugins</span>
          </a>
        </div>
      </section>
    </div>
  </section>
</Layout>

<script>
  // Troubleshooting Page Functionality
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('troubleshooting-search') as HTMLInputElement;
    const searchClear = document.getElementById('search-clear');
    const clearSearchBtn = document.getElementById('clear-search-btn');
    const noResults = document.getElementById('no-results');
    const searchTags = document.querySelectorAll('.search-tag, .suggestion-tag');
    
    // Category accordion functionality
    const categoryHeaders = document.querySelectorAll('.category-header-accordion');
    
    categoryHeaders.forEach(header => {
      header.addEventListener('click', () => {
        const isExpanded = header.getAttribute('aria-expanded') === 'true';
        const content = header.nextElementSibling as HTMLElement;
        const toggle = header.querySelector('.category-toggle');
        
        // Toggle current
        header.setAttribute('aria-expanded', String(!isExpanded));
        
        if (!isExpanded) {
          content.style.maxHeight = content.scrollHeight + 'px';
          content.classList.add('is-open');
          if (toggle) toggle.classList.add('is-open');
        } else {
          content.style.maxHeight = '';
          content.classList.remove('is-open');
          if (toggle) toggle.classList.remove('is-open');
        }
      });
    });
    
    // Issue accordion functionality
    const issueHeaders = document.querySelectorAll('.issue-header');
    
    issueHeaders.forEach(header => {
      header.addEventListener('click', () => {
        const isExpanded = header.getAttribute('aria-expanded') === 'true';
        const solution = header.nextElementSibling as HTMLElement;
        const toggle = header.querySelector('.issue-toggle');
        
        // Close others in same category (optional)
        const parentCategory = header.closest('.category-content');
        if (parentCategory) {
          parentCategory.querySelectorAll('.issue-header').forEach(otherHeader => {
            if (otherHeader !== header) {
              otherHeader.setAttribute('aria-expanded', 'false');
              const otherSolution = otherHeader.nextElementSibling as HTMLElement;
              const otherToggle = otherHeader.querySelector('.issue-toggle');
              if (otherSolution) {
                otherSolution.style.maxHeight = '';
                otherSolution.classList.remove('is-open');
              }
              if (otherToggle) otherToggle.classList.remove('is-open');
            }
          });
        }
        
        // Toggle current
        header.setAttribute('aria-expanded', String(!isExpanded));
        
        if (!isExpanded) {
          solution.style.maxHeight = solution.scrollHeight + 'px';
          solution.classList.add('is-open');
          if (toggle) toggle.classList.add('is-open');
        } else {
          solution.style.maxHeight = '';
          solution.classList.remove('is-open');
          if (toggle) toggle.classList.remove('is-open');
        }
      });
    });
    
    // Search functionality
    function performSearch(query: string) {
      const normalizedQuery = query.toLowerCase().trim();
      let visibleCount = 0;
      
      if (normalizedQuery === '') {
        // Show all
        document.querySelectorAll('.issue-item, .featured-card, .category-section').forEach(el => {
          el.classList.remove('hidden');
          el.classList.remove('highlighted');
        });
        noResults?.classList.add('hidden');
        searchClear?.classList.add('hidden');
        return;
      }
      
      searchClear?.classList.remove('hidden');
      
      // Search in featured issues
      document.querySelectorAll('.featured-card').forEach(card => {
        const keywords = card.getAttribute('data-keywords') || '';
        const title = card.querySelector('.featured-title')?.textContent?.toLowerCase() || '';
        const description = card.querySelector('.featured-description')?.textContent?.toLowerCase() || '';
        
        if (keywords.includes(normalizedQuery) || title.includes(normalizedQuery) || description.includes(normalizedQuery)) {
          card.classList.remove('hidden');
          card.classList.add('highlighted');
          visibleCount++;
        } else {
          card.classList.add('hidden');
          card.classList.remove('highlighted');
        }
      });
      
      // Search in category issues
      document.querySelectorAll('.issue-item').forEach(item => {
        const keywords = item.getAttribute('data-keywords') || '';
        const title = item.getAttribute('data-title') || '';
        
        if (keywords.includes(normalizedQuery) || title.includes(normalizedQuery)) {
          item.classList.remove('hidden');
          item.classList.add('highlighted');
          visibleCount++;
          
          // Expand parent category
          const parentCategory = item.closest('.category-section');
          if (parentCategory) {
            parentCategory.classList.remove('hidden');
            const header = parentCategory.querySelector('.category-header-accordion') as HTMLElement;
            const content = parentCategory.querySelector('.category-content') as HTMLElement;
            if (header && content && header.getAttribute('aria-expanded') !== 'true') {
              header.setAttribute('aria-expanded', 'true');
              content.style.maxHeight = 'none'; // Allow full expansion
              content.classList.add('is-open');
            }
          }
          
          // Auto-expand the issue
          const header = item.querySelector('.issue-header') as HTMLElement;
          const solution = item.querySelector('.issue-solution') as HTMLElement;
          if (header && solution && header.getAttribute('aria-expanded') !== 'true') {
            header.setAttribute('aria-expanded', 'true');
            solution.style.maxHeight = solution.scrollHeight + 'px';
            solution.classList.add('is-open');
          }
        } else {
          item.classList.add('hidden');
          item.classList.remove('highlighted');
        }
      });
      
      // Hide empty categories
      document.querySelectorAll('.category-section').forEach(cat => {
        const visibleItems = cat.querySelectorAll('.issue-item:not(.hidden)');
        if (visibleItems.length === 0 && normalizedQuery !== '') {
          cat.classList.add('hidden');
        } else {
          cat.classList.remove('hidden');
        }
      });
      
      // Show/hide no results
      if (visibleCount === 0) {
        noResults?.classList.remove('hidden');
      } else {
        noResults?.classList.add('hidden');
      }
    }
    
    // Search input handler
    searchInput?.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      performSearch(target.value);
    });
    
    // Clear search handlers
    searchClear?.addEventListener('click', () => {
      if (searchInput) {
        searchInput.value = '';
        performSearch('');
        searchInput.focus();
      }
    });
    
    clearSearchBtn?.addEventListener('click', () => {
      if (searchInput) {
        searchInput.value = '';
        performSearch('');
        searchInput.focus();
      }
    });
    
    // Search tag clicks
    searchTags.forEach(tag => {
      tag.addEventListener('click', () => {
        const term = tag.getAttribute('data-term') || '';
        if (searchInput) {
          searchInput.value = term;
          performSearch(term);
          searchInput.focus();
        }
      });
    });
    
    // Checklist functionality
    const checklistItems = document.querySelectorAll('.checklist-checkbox');
    const resetChecklistBtn = document.getElementById('reset-checklist');
    
    // Load saved state
    checklistItems.forEach(checkbox => {
      const id = checkbox.getAttribute('data-check');
      if (id && localStorage.getItem(`troubleshooting-check-${id}`) === 'true') {
        (checkbox as HTMLInputElement).checked = true;
      }
    });
    
    // Save state on change
    checklistItems.forEach(checkbox => {
      checkbox.addEventListener('change', () => {
        const id = checkbox.getAttribute('data-check');
        if (id) {
          localStorage.setItem(`troubleshooting-check-${id}`, String((checkbox as HTMLInputElement).checked));
        }
      });
    });
    
    // Reset checklist
    resetChecklistBtn?.addEventListener('click', () => {
      checklistItems.forEach(checkbox => {
        (checkbox as HTMLInputElement).checked = false;
        const id = checkbox.getAttribute('data-check');
        if (id) {
          localStorage.removeItem(`troubleshooting-check-${id}`);
        }
      });
    });
    
    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && searchInput) {
        searchInput.value = '';
        performSearch('');
      }
    });
    
    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const href = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
        if (href) {
          const target = document.querySelector(href);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });
  });
</script>

<style>
  .troubleshooting-page {
    background: var(--page-bg);
    min-height: 100vh;
  }
  
  /* Hero Section */
  .troubleshooting-hero {
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .troubleshooting-title {
    margin: 0 0 1rem;
    color: var(--color-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
  }
  
  .troubleshooting-lead {
    margin: 0 auto 2rem;
    color: var(--color-body);
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 55ch;
  }
  
  /* Search */
  .troubleshooting-search {
    max-width: 650px;
    margin: 0 auto 1.5rem;
  }
  
  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  
  .search-icon {
    position: absolute;
    left: 1.25rem;
    color: var(--color-muted);
    font-size: 1.1rem;
    pointer-events: none;
  }
  
  .search-input {
    width: 100%;
    padding: 1rem 3rem 1rem 3.25rem;
    border: 1px solid rgba(15, 23, 42, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.8);
    color: var(--color-heading);
    font-size: 1rem;
    font-family: var(--font-body);
    transition: all 0.2s ease;
  }
  
  .search-input:focus {
    outline: none;
    border-color: rgba(20, 87, 255, 0.3);
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 4px 20px rgba(20, 87, 255, 0.1);
  }
  
  .search-input::placeholder {
    color: var(--color-muted);
  }
  
  .search-clear {
    position: absolute;
    right: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border: none;
    border-radius: 50%;
    background: rgba(15, 23, 42, 0.08);
    color: var(--color-muted);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .search-clear:hover {
    background: rgba(15, 23, 42, 0.15);
    color: var(--color-heading);
  }
  
  .search-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0.75rem 0 0;
    color: var(--color-muted);
    font-size: 0.875rem;
    flex-wrap: wrap;
  }
  
  .search-hint i {
    color: #9a5d26;
  }
  
  .search-tag {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: rgba(20, 87, 255, 0.1);
    color: var(--color-primary-link);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .search-tag:hover {
    background: rgba(20, 87, 255, 0.2);
    transform: translateY(-1px);
  }
  
  /* Diagnostics Section */
  .diagnostics-section {
    margin-bottom: 2rem;
  }
  
  .diagnostics-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  
  .diagnostics-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, rgba(20, 87, 255, 0.1), rgba(201, 114, 52, 0.1));
    color: var(--color-primary-link);
    font-size: 1.5rem;
  }
  
  .diagnostics-title {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.5rem;
  }
  
  .diagnostics-subtitle {
    margin: 0.25rem 0 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  
  .diagnostics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
  }
  
  .diagnostic-card {
    padding: 1.25rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(15, 23, 42, 0.08);
  }
  
  .diagnostic-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-heading);
    font-weight: 600;
  }
  
  .diagnostic-header i {
    color: var(--color-primary-link);
  }
  
  .diagnostic-command {
    display: block;
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: rgba(15, 23, 42, 0.08);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-heading);
    margin-bottom: 0.75rem;
    overflow-x: auto;
  }
  
  .diagnostic-expected {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  
  .diagnostics-note {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 0.75rem;
    background: rgba(20, 87, 255, 0.08);
    color: var(--color-body);
    font-size: 0.9rem;
  }
  
  .diagnostics-note i {
    color: var(--color-primary-link);
    font-size: 1.1rem;
  }
  
  /* Section Titles */
  .section-title {
    margin: 0 0 0.5rem;
    color: var(--color-heading);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    text-align: center;
  }
  
  .section-subtitle {
    margin: 0 0 1.5rem;
    color: var(--color-muted);
    text-align: center;
  }
  
  /* Featured Issues */
  .featured-issues {
    margin-bottom: 3rem;
  }
  
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 1.5rem;
  }
  
  .featured-card {
    padding: 1.5rem;
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(15, 23, 42, 0.08);
    transition: all 0.2s ease;
  }
  
  .featured-card:hover {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(20, 87, 255, 0.15);
    transform: translateY(-2px);
  }
  
  .featured-card.hidden {
    display: none;
  }
  
  .featured-card.highlighted {
    border-color: rgba(20, 87, 255, 0.3);
    box-shadow: 0 4px 20px rgba(20, 87, 255, 0.1);
  }
  
  .featured-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  
  .featured-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.6rem;
    background: linear-gradient(135deg, rgba(20, 87, 255, 0.1), rgba(201, 114, 52, 0.1));
    color: var(--color-primary-link);
    font-size: 1.25rem;
  }
  
  .severity-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  
  .severity-badge.severity-critical {
    background: rgba(220, 38, 38, 0.1);
    color: #dc2626;
  }
  
  .severity-badge.severity-warning {
    background: rgba(234, 179, 8, 0.1);
    color: #b45309;
  }
  
  .severity-badge.severity-info {
    background: rgba(20, 87, 255, 0.1);
    color: var(--color-primary-link);
  }
  
  .featured-title {
    margin: 0 0 0.5rem;
    color: var(--color-heading);
    font-size: 1.25rem;
  }
  
  .featured-description {
    margin: 0 0 1rem;
    color: var(--color-body);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  
  .featured-causes {
    margin-bottom: 1rem;
  }
  
  .featured-causes h4,
  .featured-solutions h4 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    color: var(--color-heading);
    font-size: 0.9rem;
  }
  
  .featured-causes ul {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--color-body);
    font-size: 0.9rem;
  }
  
  .featured-causes li {
    margin: 0.35rem 0;
  }
  
  .solution-steps {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  
  .solution-step {
    display: flex;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  }
  
  .solution-step:last-child {
    border-bottom: none;
  }
  
  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: rgba(20, 87, 255, 0.1);
    color: var(--color-primary-link);
    font-size: 0.8rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  
  .step-content {
    flex: 1;
  }
  
  .step-content strong {
    display: block;
    color: var(--color-heading);
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }
  
  .step-content p {
    margin: 0;
    color: var(--color-body);
    font-size: 0.85rem;
    line-height: 1.5;
  }
  
  .featured-prevention {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 0.75rem;
    background: rgba(34, 197, 94, 0.08);
    margin-top: 1rem;
  }
  
  .featured-prevention i {
    color: #16a34a;
    font-size: 1.1rem;
    margin-top: 0.1rem;
  }
  
  .featured-prevention p {
    margin: 0;
    color: var(--color-body);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  
  /* Problem Categories */
  .problem-categories {
    margin-bottom: 3rem;
  }
  
  .categories-accordion {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .category-section {
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(15, 23, 42, 0.08);
    overflow: hidden;
  }
  
  .category-section.hidden {
    display: none;
  }
  
  .category-header-accordion {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1.25rem 1.5rem;
    border: none;
    background: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.2s ease;
  }
  
  .category-header-accordion:hover {
    background: rgba(255, 255, 255, 0.5);
  }
  
  .category-header-main {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .category-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.6rem;
    background: linear-gradient(135deg, rgba(20, 87, 255, 0.1), rgba(201, 114, 52, 0.1));
    color: var(--color-primary-link);
    font-size: 1.1rem;
  }
  
  .category-name {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.15rem;
  }
  
  .category-description {
    margin: 0.25rem 0 0;
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  
  .category-header-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .issue-count {
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.06);
    color: var(--color-muted);
    font-size: 0.8rem;
    font-weight: 600;
  }
  
  .category-toggle {
    color: var(--color-muted);
    transition: transform 0.2s ease;
  }
  
  .category-toggle.is-open {
    transform: rotate(180deg);
  }
  
  .category-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  
  .category-content.is-open {
    max-height: none;
  }
  
  .issues-list {
    padding: 0 1.5rem 1.5rem;
  }
  
  .issue-item {
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  }
  
  .issue-item:last-child {
    border-bottom: none;
  }
  
  .issue-item.hidden {
    display: none;
  }
  
  .issue-item.highlighted {
    background: rgba(20, 87, 255, 0.04);
    border-radius: 0.5rem;
  }
  
  .issue-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 1rem 0.75rem;
    border: none;
    background: none;
    cursor: pointer;
    text-align: left;
  }
  
  .issue-title-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  .severity-indicator {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    font-size: 0.85rem;
  }
  
  .severity-indicator.severity-critical {
    background: rgba(220, 38, 38, 0.1);
    color: #dc2626;
  }
  
  .severity-indicator.severity-warning {
    background: rgba(234, 179, 8, 0.1);
    color: #b45309;
  }
  
  .severity-indicator.severity-info {
    background: rgba(20, 87, 255, 0.1);
    color: var(--color-primary-link);
  }
  
  .issue-title-text {
    color: var(--color-heading);
    font-weight: 600;
    font-size: 0.95rem;
  }
  
  .issue-toggle {
    color: var(--color-muted);
    transition: transform 0.2s ease;
  }
  
  .issue-toggle.is-open {
    transform: rotate(180deg);
  }
  
  .issue-solution {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  
  .issue-solution.is-open {
    max-height: none;
  }
  
  .solution-inner {
    padding: 0 0.75rem 1rem 2.5rem;
  }
  
  .symptoms-block,
  .solution-block {
    margin-bottom: 1rem;
  }
  
  .symptoms-block h4,
  .solution-block h4 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.75rem;
    color: var(--color-heading);
    font-size: 0.9rem;
  }
  
  .symptoms-block ul {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--color-body);
    font-size: 0.9rem;
  }
  
  .symptoms-block li {
    margin: 0.35rem 0;
  }
  
  .symptoms-block code {
    padding: 0.2rem 0.4rem;
    border-radius: 0.35rem;
    background: rgba(220, 38, 38, 0.08);
    color: #dc2626;
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
  
  .solution-content :global(ol) {
    margin: 0.75rem 0;
    padding-left: 1.25rem;
    color: var(--color-body);
    font-size: 0.9rem;
  }
  
  .solution-content :global(li) {
    margin: 0.5rem 0;
    line-height: 1.6;
  }
  
  .solution-content :global(strong) {
    color: var(--color-heading);
  }
  
  .solution-content :global(code) {
    padding: 0.2rem 0.4rem;
    border-radius: 0.35rem;
    background: rgba(15, 23, 42, 0.08);
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
  
  .solution-content :global(pre) {
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: rgba(15, 23, 42, 0.06);
    overflow-x: auto;
    margin: 0.75rem 0;
  }
  
  .solution-content :global(pre code) {
    background: none;
    padding: 0;
  }
  
  .solution-content :global(a) {
    color: var(--color-primary-link);
    text-decoration: none;
    font-weight: 600;
  }
  
  .solution-content :global(a:hover) {
    text-decoration: underline;
  }
  
  .solution-content :global(.solution-note) {
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: rgba(234, 179, 8, 0.1);
    color: var(--color-body);
    font-size: 0.9rem;
    margin-top: 0.75rem;
  }
  
  /* No Results */
  .no-results {
    margin: 2rem 0;
  }
  
  .no-results-content {
    text-align: center;
    padding: 3rem 2rem;
  }
  
  .no-results-content > i {
    font-size: 3rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
    display: block;
  }
  
  .no-results-content h3 {
    margin: 0 0 0.5rem;
    color: var(--color-heading);
    font-size: 1.5rem;
  }
  
  .no-results-content p {
    margin: 0 0 1.5rem;
    color: var(--color-muted);
  }
  
  .no-results-suggestions {
    margin-bottom: 1.5rem;
  }
  
  .no-results-suggestions p {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
  }
  
  .suggestion-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
  
  .suggestion-tag {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: rgba(20, 87, 255, 0.1);
    color: var(--color-primary-link);
    font-size: 0.85rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .suggestion-tag:hover {
    background: rgba(20, 87, 255, 0.2);
    transform: translateY(-1px);
  }
  
  /* Checklist Section */
  .checklist-section {
    margin-bottom: 3rem;
  }
  
  .checklist-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  
  .checklist-header > i {
    font-size: 2rem;
    color: var(--color-primary-link);
  }
  
  .checklist-title {
    margin: 0;
    color: var(--color-heading);
    font-size: 1.5rem;
  }
  
  .checklist-subtitle {
    margin: 0.25rem 0 0;
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  
  .checklist-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  
  .checklist-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(15, 23, 42, 0.06);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .checklist-item:hover {
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(20, 87, 255, 0.15);
  }
  
  .checklist-checkbox {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  
  .checklist-checkmark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: rgba(15, 23, 42, 0.08);
    color: var(--color-muted);
    font-size: 0.9rem;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  
  .checklist-checkbox:checked + .checklist-checkmark {
    background: rgba(34, 197, 94, 0.15);
    color: #16a34a;
  }
  
  .checklist-label-text {
    color: var(--color-body);
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }
  
  .checklist-checkbox:checked ~ .checklist-label-text {
    color: var(--color-heading);
    text-decoration: line-through;
    opacity: 0.7;
  }
  
  .checklist-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 1rem;
  }
  
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    border-radius: 0.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
  }
  
  .btn-primary {
    background: var(--color-primary-link);
    color: white;
  }
  
  .btn-primary:hover {
    background: #0f6efd;
    transform: translateY(-1px);
  }
  
  .btn-secondary {
    background: rgba(15, 23, 42, 0.08);
    color: var(--color-body);
  }
  
  .btn-secondary:hover {
    background: rgba(15, 23, 42, 0.12);
  }
  
  .checklist-tip {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: 0.75rem;
    background: rgba(20, 87, 255, 0.08);
  }
  
  .checklist-tip i {
    color: var(--color-primary-link);
    font-size: 1.1rem;
    margin-top: 0.1rem;
  }
  
  .checklist-tip p {
    margin: 0;
    color: var(--color-body);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  
  /* Help Section */
  .help-section {
    margin-bottom: 3rem;
  }
  
  .help-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }
  
  .help-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(15, 23, 42, 0.08);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .help-card:hover {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(20, 87, 255, 0.2);
    transform: translateY(-2px);
  }
  
  .help-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.6rem;
    background: linear-gradient(135deg, rgba(20, 87, 255, 0.1), rgba(201, 114, 52, 0.1));
    color: var(--color-primary-link);
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  
  .help-content {
    flex: 1;
  }
  
  .help-title {
    margin: 0 0 0.35rem;
    color: var(--color-heading);
    font-size: 1rem;
  }
  
  .help-description {
    margin: 0 0 0.75rem;
    color: var(--color-muted);
    font-size: 0.85rem;
    line-height: 1.5;
  }
  
  .help-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-primary-link);
    font-size: 0.85rem;
    font-weight: 600;
  }
  
  .help-cta i {
    font-size: 0.75rem;
  }
  
  /* Related Links */
  .related-links {
    text-align: center;
  }
  
  .related-title {
    margin: 0 0 1rem;
    color: var(--color-heading);
    font-size: 1.25rem;
  }
  
  .links-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    max-width: 700px;
    margin: 0 auto;
  }
  
  .link-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(15, 23, 42, 0.08);
    color: var(--color-body);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .link-card:hover {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(20, 87, 255, 0.2);
    color: var(--color-primary-link);
    transform: translateY(-2px);
  }
  
  .link-card i {
    font-size: 1.5rem;
  }
  
