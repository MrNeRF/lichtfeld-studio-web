---
/**
 * postshot.astro
 *
 * Comparison page: LichtFeld Studio vs Postshot
 * Targets searches for "postshot alternative", "postshot vs lichtfeld",
 * "3d gaussian splatting software comparison"
 */
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config/site.config";
import {
  GITHUB_REPO_URL,
  GITHUB_RELEASES_URL,
  GITHUB_WIKI_URL,
  DISCORD_URL,
  GITHUB_SPONSORS_URL,
  PAYPAL_URL,
  DONORBOX_URL,
  CRYPTO_WALLET_BITCOIN,
} from "@/constants/project";

const base = import.meta.env.BASE_URL;

// SEO metadata
const seoTitle = "LichtFeld Studio vs Postshot: Best 3D Gaussian Splatting Software 2025";
const seoDescription =
  "Compare LichtFeld Studio vs Postshot for 3D Gaussian Splatting. Open source vs paid, features, performance, and which is right for your workflow.";

// Comparison data
const quickComparison = [
  { feature: "Price", lfs: "Free (GPL-3.0)", postshot: "Paid (Subscription)", lfsAdvantage: true },
  { feature: "License", lfs: "Open Source", postshot: "Proprietary", lfsAdvantage: true },
  { feature: "Source Code", lfs: "Full Access", postshot: "Closed", lfsAdvantage: true },
  { feature: "Custom Tensor Library", lfs: "LibTorch-Free", postshot: "Standard", lfsAdvantage: true },
  { feature: "VRAM Efficiency", lfs: "More Gaussians/GB", postshot: "Standard", lfsAdvantage: true },
  { feature: "Custom CUDA Kernels", lfs: "SSIM, L1, MCMC, Densification", postshot: "Limited", lfsAdvantage: true },
  { feature: "Custom Optimizer", lfs: "LibTorch-Free Adam", postshot: "Standard", lfsAdvantage: true },
  { feature: "Training", lfs: "Native (C++23/CUDA)", postshot: "Native", neutral: true },
  { feature: "Editing Tools", lfs: "Full Suite", postshot: "Basic", lfsAdvantage: true },
  { feature: "Plugin System", lfs: "Python + MCP", postshot: "Limited", lfsAdvantage: true },
  { feature: "Save & Resume Training", lfs: "Yes", postshot: "No", lfsAdvantage: true },
  { feature: "Platform", lfs: "Windows & Linux", postshot: "Windows & macOS", neutral: true },
  { feature: "Vendor Lock-in", lfs: "None", postshot: "Yes", lfsAdvantage: true },
  { feature: "Community", lfs: "Active (Discord/GitHub)", postshot: "Smaller", lfsAdvantage: true },
];

const detailedFeatures = [
  {
    category: "Core 3DGS & Performance",
    items: [
      { name: "3D Gaussian Splatting Training", lfs: true, postshot: true },
      { name: "Custom LibTorch-Free Tensor Library", lfs: true, postshot: false },
      { name: "Custom CUDA Kernels (SSIM, L1, MCMC)", lfs: true, postshot: false },
      { name: "Custom LibTorch-Free Adam Optimizer", lfs: true, postshot: false },
      { name: "Higher Gaussians per GB VRAM", lfs: true, postshot: false },
      { name: "Real-time Viewer", lfs: true, postshot: true },
      { name: "PLY Export/Import", lfs: true, postshot: true },
      { name: "Save & Resume Training", lfs: true, postshot: false },
      { name: "Multi-GPU Support", lfs: false, postshot: false },
    ],
  },
  {
    category: "Editing & Tools",
    items: [
      { name: "Brush Selection", lfs: true, postshot: true },
      { name: "Lasso/Polygon Tools", lfs: true, postshot: false },
      { name: "Masking & Cropping", lfs: true, postshot: false },
      { name: "Scene Alignment", lfs: true, postshot: false },
      { name: "Composition Tools", lfs: true, postshot: false },
      { name: "Transform & Scale", lfs: true, postshot: true },
    ],
  },
  {
    category: "Extensibility & Access",
    items: [
      { name: "Full Source Code (GPL-3.0)", lfs: true, postshot: false },
      { name: "Python Plugin API", lfs: true, postshot: false },
      { name: "MCP Integration", lfs: true, postshot: false },
      { name: "Custom Panels", lfs: true, postshot: false },
      { name: "External Workflow Control", lfs: true, postshot: false },
      { name: "Plugin Registry", lfs: true, postshot: false },
    ],
  },
  {
    category: "Export & Integration",
    items: [
      { name: "Standard PLY Export", lfs: true, postshot: true },
      { name: "Web Viewer Export", lfs: true, postshot: true },
      { name: "Unity Integration", lfs: true, postshot: true },
      { name: "Unreal Engine", lfs: true, postshot: true },
    ],
  },
];

const faqs = [
  {
    question: "Is LichtFeld Studio really free compared to PostShot?",
    answer:
      "Yes, LichtFeld Studio is 100% free and open source under the GPL-3.0 license. There are no subscription fees, no feature tiers, and no hidden costs. PostShot requires a paid subscription—but paying doesn't mean better performance.",
  },
  {
    question: "Does paid software like PostShot perform better than free alternatives?",
    answer:
      "Not in this case. LichtFeld Studio outperforms or matches paid alternatives thanks to our custom LibTorch-free tensor library, hand-optimized CUDA kernels, and superior VRAM efficiency. You're not paying for performance—you're paying for a paywall.",
  },
  {
    question: "Can I migrate my PostShot projects to LichtFeld Studio?",
    answer:
      "Absolutely. Both tools use standard 3D Gaussian Splatting formats (PLY). You can export your trained splats from PostShot and open them in LichtFeld Studio for superior editing and further processing.",
  },
  {
    question: "Which tool has better performance?",
    answer:
      "LichtFeld Studio delivers superior performance through our custom tensor library, optimized CUDA kernels (SSIM, L1, MCMC, densification), and LibTorch-free Adam optimizer. We pack more Gaussians per GB of VRAM than standard implementations like PostShot.",
  },
  {
    question: "What are LichtFeld Studio's key technical advantages?",
    answer:
      "LFS features a custom LibTorch-free tensor library for low-level GPU memory control, hand-optimized CUDA kernels, a custom Adam optimizer, significantly higher Gaussians-per-GB VRAM efficiency, save/resume training capability, and full source code access under GPL-3.0.",
  },
  {
    question: "Is LichtFeld Studio suitable for commercial use?",
    answer:
      "Yes, the GPL-3.0 license allows commercial use. Many studios and professionals use LichtFeld Studio for client work without any licensing concerns or ongoing costs. Keep your profits instead of paying software subscriptions.",
  },
  {
    question: "How active is LichtFeld Studio development?",
    answer:
      "Very active. With an open-source model, contributions come from the community and core team. Check our GitHub repository for the latest commits, releases, and roadmap. Features are added based on user needs, not corporate roadmaps.",
  },
];

// Schema.org structured data for comparison
const comparisonSchema = {
  "@context": "https://schema.org",
  "@type": "Comparison",
  name: "LichtFeld Studio vs Postshot Comparison",
  description: seoDescription,
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      item: {
        "@type": "SoftwareApplication",
        name: "LichtFeld Studio",
        applicationCategory: "DeveloperApplication",
        operatingSystem: ["Windows", "Linux"],
        offers: {
          "@type": "Offer",
          price: "0",
          priceCurrency: "USD",
        },
        softwareVersion: "0.5.0",
        downloadUrl: GITHUB_REPO_URL,
      },
    },
    {
      "@type": "ListItem",
      position: 2,
      item: {
        "@type": "SoftwareApplication",
        name: "Postshot",
        applicationCategory: "DeveloperApplication",
        operatingSystem: ["Windows", "macOS"],
      },
    },
  ],
};
---

<Layout title={seoTitle} description={seoDescription}>
  {/* Schema.org structured data */}
  <script type="application/ld+json" set:html={JSON.stringify(comparisonSchema)} />

  {/* Hero Section */}
  <header class="vs-hero">
    <div class="container content-frame px-4">
      <div class="vs-hero__content">
        <div class="vs-hero__badge">
          <span class="vs-hero__badge-icon">
            <i class="bi bi-shield-check"></i>
          </span>
          <span>2025 Software Comparison</span>
        </div>
        <h1 class="vs-hero__title">LichtFeld Studio vs Postshot</h1>
        <p class="vs-hero__subtitle">
          Why pay for less? LichtFeld Studio outperforms PostShot with custom CUDA kernels, superior VRAM efficiency, and zero subscription fees.
        </p>
        <div class="vs-hero__cta">
          <a href="#quick-comparison" class="btn btn-primary btn-lg vs-hero__btn-primary">
            <i class="bi bi-table mr-2"></i>
            See the Comparison
          </a>
          <a href={GITHUB_RELEASES_URL} class="btn btn-outline-primary btn-lg vs-hero__btn-secondary" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-download mr-2"></i>
            Download LFS Free
          </a>
        </div>
      </div>
    </div>
  </header>

  {/* Quick Comparison Table */}
  <section id="quick-comparison" class="vs-section hash-section">
    <div class="container content-frame px-4">
      <div class="shell shell--spacious">
        <div class="vs-section__header">
          <p class="kicker">At a Glance</p>
          <h2 class="vs-section__title">Quick Comparison</h2>
          <p class="vs-section__desc">See how LichtFeld Studio and Postshot stack up on the essentials.</p>
        </div>

        <div class="vs-table-wrapper">
          <table class="vs-table">
            <thead>
              <tr>
                <th class="vs-table__feature">Feature</th>
                <th class="vs-table__lfs">
                  <span class="vs-table__logo">LichtFeld Studio</span>
                  <span class="vs-table__tag vs-table__tag--open">Open Source</span>
                </th>
                <th class="vs-table__postshot">
                  <span class="vs-table__logo">Postshot</span>
                  <span class="vs-table__tag vs-table__tag--paid">Paid</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {
                quickComparison.map((row) => (
                  <tr>
                    <td class="vs-table__feature">{row.feature}</td>
                    <td class="vs-table__lfs">
                      <span class:list={["vs-table__value", row.lfsAdvantage && "vs-table__value--highlight"]}>
                        {row.lfsAdvantage ? <i class="bi bi-check-circle-fill vs-table__check" /> : null}
                        {row.neutral ? <i class="bi bi-check-circle vs-table__check-neutral" /> : null}
                        {row.lfs}
                      </span>
                    </td>
                    <td class="vs-table__postshot">
                      <span class="vs-table__value">
                        {row.neutral ? <i class="bi bi-check-circle vs-table__check-neutral" /> : null}
                        {!row.neutral && !row.lfsAdvantage ? <i class="bi bi-x-circle vs-table__cross" /> : null}
                        {row.postshot}
                      </span>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  {/* LFS Technical Advantages Section */}
  <section id="lfs-advantages" class="vs-section hash-section">
    <div class="container content-frame px-4">
      <div class="shell shell--spacious">
        <div class="vs-section__header">
          <p class="kicker">Why LFS Wins</p>
          <h2 class="vs-section__title">Technical Advantages Over PostShot</h2>
          <p class="vs-section__desc">
            Paid doesn't mean better performance. LichtFeld Studio's custom-built infrastructure delivers superior results at zero cost.
          </p>
        </div>

        <div class="vs-advantages">
          <div class="vs-advantage-card">
            <div class="vs-advantage-card__icon">
              <i class="bi bi-cpu"></i>
            </div>
            <h3 class="vs-advantage-card__title">Custom Tensor Library</h3>
            <p class="vs-advantage-card__desc">
              Our LibTorch-free tensor library provides low-level GPU memory control that standard implementations can't match. No bloated dependencies—just pure performance.
            </p>
          </div>

          <div class="vs-advantage-card">
            <div class="vs-advantage-card__icon">
              <i class="bi bi-memory"></i>
            </div>
            <h3 class="vs-advantage-card__title">Maximum VRAM Efficiency</h3>
            <p class="vs-advantage-card__desc">
              Pack significantly more Gaussians per GB of VRAM than PostShot and other standard implementations. Train larger scenes on the same hardware.
            </p>
          </div>

          <div class="vs-advantage-card">
            <div class="vs-advantage-card__icon">
              <i class="bi bi-lightning-charge"></i>
            </div>
            <h3 class="vs-advantage-card__title">Custom CUDA Kernels</h3>
            <p class="vs-advantage-card__desc">
              Hand-optimized CUDA kernels for SSIM, L1 loss, MCMC sampling, and densification—tailored specifically for 3D Gaussian Splatting workloads.
            </p>
          </div>

          <div class="vs-advantage-card">
            <div class="vs-advantage-card__icon">
              <i class="bi bi-gear-wide-connected"></i>
            </div>
            <h3 class="vs-advantage-card__title">Custom Adam Optimizer</h3>
            <p class="vs-advantage-card__desc">
              Our LibTorch-free Adam optimizer eliminates framework overhead, giving you faster training iterations and lower memory consumption.
            </p>
          </div>

          <div class="vs-advantage-card">
            <div class="vs-advantage-card__icon">
              <i class="bi bi-code-square"></i>
            </div>
            <h3 class="vs-advantage-card__title">Full Source Access</h3>
            <p class="vs-advantage-card__desc">
              GPL-3.0 licensed means complete transparency. Modify, extend, and understand every aspect of the training pipeline. No black boxes.
            </p>
          </div>

          <div class="vs-advantage-card">
            <div class="vs-advantage-card__icon">
              <i class="bi bi-plug"></i>
            </div>
            <h3 class="vs-advantage-card__title">Python Plugin System + MCP</h3>
            <p class="vs-advantage-card__desc">
              Extend functionality with Python plugins and Model Context Protocol integration. Build custom workflows that PostShot's closed ecosystem can't support.
            </p>
          </div>

          <div class="vs-advantage-card">
            <div class="vs-advantage-card__icon">
              <i class="bi bi-save"></i>
            </div>
            <h3 class="vs-advantage-card__title">Save & Resume Training</h3>
            <p class="vs-advantage-card__desc">
              Checkpoint your training state at any point and resume later. Experiment freely without losing progress—essential for professional workflows.
            </p>
          </div>

          <div class="vs-advantage-card">
            <div class="vs-advantage-card__icon">
              <i class="bi bi-cash-stack"></i>
            </div>
            <h3 class="vs-advantage-card__title">Zero Subscription Fees</h3>
            <p class="vs-advantage-card__desc">
              No monthly charges, no feature tiers, no surprises. Free forever with all features included. Invest in better hardware instead of software subscriptions.
            </p>
          </div>
        </div>

        <div class="vs-cta-box">
          <div class="vs-cta-box__content">
            <h3 class="vs-cta-box__title">Don't Pay for Less Performance</h3>
            <p class="vs-cta-box__desc">
              PostShot charges subscription fees for software that can't match LFS's technical capabilities. Get superior performance for free.
            </p>
          </div>
          <a href={GITHUB_RELEASES_URL} class="btn btn-primary vs-cta-box__btn" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-download mr-2"></i>
            Download LFS Free
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Detailed Feature Comparison */}
  <section id="detailed-features" class="vs-section hash-section">
    <div class="container content-frame px-4">
      <div class="shell shell--spacious">
        <div class="vs-section__header">
          <p class="kicker">Deep Dive</p>
          <h2 class="vs-section__title">Detailed Feature Comparison</h2>
          <p class="vs-section__desc">A comprehensive breakdown of capabilities across both platforms.</p>
        </div>

        <div class="vs-features">
          {
            detailedFeatures.map((category) => (
              <div class="vs-feature-category">
                <h3 class="vs-feature-category__title">{category.category}</h3>
                <div class="vs-feature-list">
                  {category.items.map((item) => (
                    <div class="vs-feature-item">
                      <span class="vs-feature-item__name">{item.name}</span>
                      <div class="vs-feature-item__status">
                        <span
                          class:list={[
                            "vs-feature-item__badge",
                            typeof item.lfs === "boolean" && item.lfs
                              ? "vs-feature-item__badge--yes"
                              : typeof item.lfs === "string"
                                ? "vs-feature-item__badge--partial"
                                : "vs-feature-item__badge--no",
                          ]}
                        >
                          {typeof item.lfs === "boolean" ? (
                            item.lfs ? (
                              <>
                                <i class="bi bi-check-lg" /> Yes
                              </>
                            ) : (
                              <>
                                <i class="bi bi-x-lg" /> No
                              </>
                            )
                          ) : (
                            item.lfs
                          )}
                        </span>
                        <span
                          class:list={[
                            "vs-feature-item__badge",
                            typeof item.postshot === "boolean" && item.postshot
                              ? "vs-feature-item__badge--yes"
                              : typeof item.postshot === "string"
                                ? "vs-feature-item__badge--partial"
                                : "vs-feature-item__badge--no",
                          ]}
                        >
                          {typeof item.postshot === "boolean" ? (
                            item.postshot ? (
                              <>
                                <i class="bi bi-check-lg" /> Yes
                              </>
                            ) : (
                              <>
                                <i class="bi bi-x-lg" /> No
                              </>
                            )
                          ) : (
                            item.postshot
                          )}
                        </span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))
          }
        </div>

        <div class="vs-legend">
          <div class="vs-legend__item">
            <span class="vs-legend__badge vs-legend__badge--yes">
              <i class="bi bi-check-lg" />
            </span>
            <span>Available</span>
          </div>
          <div class="vs-legend__item">
            <span class="vs-legend__badge vs-legend__badge--partial">Partial</span>
            <span>Limited/Community</span>
          </div>
          <div class="vs-legend__item">
            <span class="vs-legend__badge vs-legend__badge--no">
              <i class="bi bi-x-lg" />
            </span>
            <span>Not Available</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Pricing Comparison */}
  <section id="pricing" class="vs-section hash-section">
    <div class="container content-frame px-4">
      <div class="shell shell--spacious">
        <div class="vs-section__header">
          <p class="kicker">Pricing</p>
          <h2 class="vs-section__title">Pricing Comparison</h2>
          <p class="vs-section__desc">Transparent pricing vs subscription model.</p>
        </div>

        <div class="vs-pricing-grid">
          {/* LichtFeld Studio Pricing */}
          <div class="vs-pricing-card vs-pricing-card--highlight">
            <div class="vs-pricing-card__header">
              <h3 class="vs-pricing-card__name">LichtFeld Studio</h3>
              <div class="vs-pricing-card__price">
                <span class="vs-pricing-card__amount">Free</span>
                <span class="vs-pricing-card__period">Forever</span>
              </div>
              <span class="vs-pricing-card__badge">GPL-3.0 Open Source</span>
            </div>
            <ul class="vs-pricing-card__features">
              <li>
                <i class="bi bi-check-lg" />
                Full training capabilities
              </li>
              <li>
                <i class="bi bi-check-lg" />
                Custom tensor library (LibTorch-free)
              </li>
              <li>
                <i class="bi bi-check-lg" />
                Superior VRAM efficiency
              </li>
              <li>
                <i class="bi bi-check-lg" />
                Custom CUDA kernels
              </li>
              <li>
                <i class="bi bi-check-lg" />
                Complete editing suite
              </li>
              <li>
                <i class="bi bi-check-lg" />
                Python plugin system + MCP
              </li>
              <li>
                <i class="bi bi-check-lg" />
                Save & resume training
              </li>
              <li>
                <i class="bi bi-check-lg" />
                All export formats
              </li>
              <li>
                <i class="bi bi-check-lg" />
                Full source code access
              </li>
              <li>
                <i class="bi bi-check-lg" />
                No vendor lock-in
              </li>
            </ul>
            <a
              href={GITHUB_RELEASES_URL}
              class="btn btn-primary btn-lg vs-pricing-card__cta"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="bi bi-download mr-2"></i>
              Download Now
            </a>
          </div>

          {/* PostShot Pricing */}
          <div class="vs-pricing-card">
            <div class="vs-pricing-card__header">
              <h3 class="vs-pricing-card__name">PostShot</h3>
              <div class="vs-pricing-card__price">
                <span class="vs-pricing-card__amount">Paid</span>
                <span class="vs-pricing-card__period">Subscription</span>
              </div>
              <span class="vs-pricing-card__badge vs-pricing-card__badge--paid">Proprietary</span>
            </div>
            <ul class="vs-pricing-card__features">
              <li>
                <i class="bi bi-check-lg" />
                Training capabilities
              </li>
              <li>
                <i class="bi bi-x-lg" />
                No custom tensor library
              </li>
              <li>
                <i class="bi bi-x-lg" />
                Standard VRAM efficiency
              </li>
              <li>
                <i class="bi bi-x-lg" />
                No custom CUDA kernels
              </li>
              <li>
                <i class="bi bi-check-lg" />
                Basic editing tools
              </li>
              <li>
                <i class="bi bi-x-lg" />
                No plugin system
              </li>
              <li>
                <i class="bi bi-x-lg" />
                No save/resume training
              </li>
              <li>
                <i class="bi bi-check-lg" />
                Standard exports
              </li>
              <li>
                <i class="bi bi-x-lg" />
                Closed source
              </li>
              <li>
                <i class="bi bi-check-lg" />
                macOS support (paid)
              </li>
            </ul>
            <div class="vs-pricing-card__note">
              Paying subscription fees for fewer features. 
              <strong>macOS users:</strong> Try <a href="https://github.com/ArthurBrussee/brush" target="_blank" rel="noopener noreferrer">Brush</a> — free, open-source, native macOS training.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section id="faq" class="vs-section hash-section">
    <div class="container content-frame px-4">
      <div class="shell shell--spacious">
        <div class="vs-section__header">
          <p class="kicker">FAQ</p>
          <h2 class="vs-section__title">Frequently Asked Questions</h2>
          <p class="vs-section__desc">Common questions about both tools answered.</p>
        </div>

        <div class="vs-faq">
          {
            faqs.map((faq, index) => (
              <details class="vs-faq__item" open={index === 0}>
                <summary class="vs-faq__question">
                  <span>{faq.question}</span>
                  <i class="bi bi-chevron-down vs-faq__icon" />
                </summary>
                <div class="vs-faq__answer">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))
          }
        </div>

        <div class="vs-faq__more">
          <p>Have more questions?</p>
          <a href={DISCORD_URL} class="section-link" target="_blank" rel="noopener noreferrer">
            Join our Discord community
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Final CTA */}
  <section id="download" class="vs-section hash-section">
    <div class="container content-frame px-4">
      <div class="shell shell--spacious vs-shell--cta">
        <div class="vs-final-cta">
          <h2 class="vs-final-cta__title">Make the Switch Today</h2>
          <p class="vs-final-cta__desc">
            Join the open-source revolution in 3D Gaussian Splatting. Free, powerful, and community-driven.
          </p>
          <div class="vs-final-cta__actions">
            <a
              href={GITHUB_RELEASES_URL}
              class="btn btn-primary btn-lg vs-final-cta__btn-primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="bi bi-windows mr-2"></i>
