// FAQ data
const faqs = [
  {
    question: "What is Gaussian Splatting in simple terms?",
    answer: "Gaussian Splatting is a 3D rendering technique that represents scenes using millions of tiny colored blobs (3D Gaussians) instead of traditional polygons or neural networks. Each blob has position, color, size, and transparency, allowing for photorealistic real-time rendering."
  },
  {
    question: "How is 3DGS different from NeRF?",
    answer: "Unlike NeRF, which uses a neural network to represent scenes implicitly, 3D Gaussian Splatting uses an explicit representation (millions of individual Gaussians). This makes it 100-200x faster to render, faster to train (minutes vs hours), and directly editable."
  },
  {
    question: "What hardware do I need for Gaussian Splatting?",
    answer: "Training requires an NVIDIA GPU with at least 8GB VRAM (RTX 3070 or better recommended). Viewing pre-trained scenes works on most modern GPUs and even some integrated graphics."
  },
  {
    question: "What are Spherical Harmonics in 3DGS?",
    answer: "Spherical Harmonics (SH) are mathematical functions that encode how a Gaussian's color changes based on viewing angle. Higher SH degrees (0-3) capture more complex view-dependent effects like reflections and specular highlights."
  },
